<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <EnableDefaultEmbeddedResourceItems>false</EnableDefaultEmbeddedResourceItems>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="Library.fs" />
    <Compile Include="Commons.fs" />
    <Compile Include="Domain/Book.fs" />
    <Compile Include="Domain/Author.fs" />
    <Compile Include="Domain/Editor.fs" />
    <Compile Include="Domain/Reservation.fs" />
    <Compile Include="Domain/User.fs" />
    <Compile Include="Domain/Loan.fs" />
    <Compile Include="Domain/IsbnRegistry.fs" />
    <Compile Include="Domain/Review.fs" />
    <Compile Include="SearchModels.fs" />
    <Compile Include="Details/Details.fs" />
    <Compile Include="Services/IMailBodyRetriever.fs" />
    <Compile Include="Services/IAuthorService.fs" />
    <Compile Include="Services/IVectorDbService.fs" />
    <Compile Include="Services/IBookService.fs" />
    <Compile Include="Services/IEditorService.fs" />
    <Compile Include="Services/ILoanService.fs" />
    <Compile Include="Services/IReservationService.fs" />
    <Compile Include="Services/IGoogleBooksService.fs" />
    <Compile Include="Services/IAuthorsSearchService.fs" />
    <Compile Include="Services/IUserService.fs" />
    <Compile Include="Services/IReviewService.fs" />
    <Compile Include="Services/IDetailsService.fs" />
    <Compile Include="Services/IDataExportService.fs" />
    <Compile Include="Services/ITextEmbeddingService.fs" />

    <Compile Include="SearchCriteria.fs" />
    <Compile Include="Infrastructure/Services/IMailNotificator.fs" />
    <Compile Include="Resources/SharedResources.fs" />
    <Compile Include="TestSeedExtensions/AuthorSeed.fs" />
    <Compile Include="TestSeedExtensions/BookSeed.fs" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Resources/SharedResources.resx">
      <LogicalName>blazorBookLibrary.Shared.Resources.SharedResources.resources</LogicalName>
    </EmbeddedResource>
    <EmbeddedResource Include="Resources/SharedResources.it-IT.resx">
      <LogicalName>blazorBookLibrary.Shared.Resources.SharedResources.it-IT.resources</LogicalName>
    </EmbeddedResource>
    <EmbeddedResource Include="Resources/SharedResources.en-US.resx">
      <LogicalName>blazorBookLibrary.Shared.Resources.SharedResources.en-US.resources</LogicalName>
    </EmbeddedResource>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="FSharp.SystemTextJson" Version="1.4.36" />
    <PackageReference Include="FsToolkit.ErrorHandling" Version="5.2.0" />
    <PackageReference Include="Microsoft.Extensions.Configuration" Version="10.0.5" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Json" Version="10.0.5" />
    <PackageReference Include="Sharpino.Core" Version="4.8.8" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\blazorBookLibrary.Data\blazorBookLibrary.Data.csproj" />
  </ItemGroup>

</Project>
