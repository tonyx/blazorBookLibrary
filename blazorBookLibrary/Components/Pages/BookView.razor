@page "/book-view/{BookIdStr}"
@using BookLibrary.Shared.Services
@using BookLibrary.Domain
@using BookLibrary.Shared
@using static BookLibrary.Shared.Commons
@using Microsoft.FSharp.Core

@inject IBookService BookService
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<PageTitle>Book Details</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-primary mb-0"><i class="bi bi-info-circle me-2"></i>Book Details</h1>
        <button class="btn btn-outline-secondary" @onclick="GoBack">
            <i class="bi bi-arrow-left me-1"></i>Back
        </button>
    </div>

    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div class="alert @statusClass alert-dismissible fade show mb-4" role="alert">
            @statusMessage
            <button type="button" class="btn-close" @onclick='() => statusMessage = ""'></button>
        </div>
    }

    @if (isLoading)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (bookDetails != null)
    {
        <div class="row g-4">
            <!-- Book Cover Image Section -->
            <div class="col-md-3">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-header bg-info text-white py-3">
                        <h5 class="card-title mb-0"><i class="bi bi-image me-2"></i>Book Cover</h5>
                    </div>
                    <div class="card-body d-flex flex-column align-items-center">
                        <div class="book-cover-container shadow-sm border rounded p-2 bg-white d-flex align-items-center justify-content-center w-100" style="min-height: 250px; max-height: 400px; overflow: hidden;">
                            @if (FSharpOption<Uri>.get_IsSome(bookDetails.Book.ImageUrl))
                            {
                                <img src="@bookDetails.Book.ImageUrl.Value.ToString()" 
                                     class="img-fluid rounded shadow-sm" 
                                     alt="Book Cover" 
                                     style="max-height: 100%; max-width: 100%; object-fit: contain;" />
                            }
                            else
                            {
                                <div class="text-center text-muted opacity-50 p-4">
                                    <i class="bi bi-book h1 d-block mb-2"></i>
                                    <span class="small d-block">No Cover Available</span>
                                </div>
                            }
                        </div>
                        
                        @if (FSharpOption<Uri>.get_IsSome(bookDetails.Book.ImageUrl))
                        {
                            <div class="mt-3 w-100 text-center">
                                <a href="@bookDetails.Book.ImageUrl.Value.ToString()" target="_blank" class="btn btn-sm btn-outline-info w-100">
                                    <i class="bi bi-box-arrow-up-right me-1"></i> View Full Image
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Book Details & Status Section -->
            <div class="col-md-9">
                <!-- General Info Card -->
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-header bg-primary text-white py-3">
                        <h5 class="card-title mb-0"><i class="bi bi-book me-2"></i>General Information</h5>
                    </div>
                    <div class="card-body">
                        <dl class="row mb-0">
                            <dt class="col-sm-3 text-muted">Title</dt>
                            <dd class="col-sm-9 fw-bold fs-5">@bookDetails.Book.Title.Value</dd>

                            <dt class="col-sm-3 text-muted mt-2">ISBN</dt>
                            <dd class="col-sm-9 mt-2">@bookDetails.Book.Isbn.Value</dd>

                            <dt class="col-sm-3 text-muted mt-2">Publication Year</dt>
                            <dd class="col-sm-9 mt-2">@bookDetails.Book.Year.Value</dd>

                            <dt class="col-sm-3 text-muted mt-2">Main Category</dt>
                            <dd class="col-sm-9 mt-2">
                                <span class="badge bg-secondary">@bookDetails.Book.MainCategory.Value()</span>
                            </dd>
                            
                            <dt class="col-sm-3 text-muted mt-2">Additional Categories</dt>
                            <dd class="col-sm-9 mt-2">
                                <div class="d-flex flex-wrap align-items-center gap-2">
                                    @foreach (var cat in bookDetails.Book.AdditionalCategories)
                                    {
                                        <span class="badge rounded-pill bg-light text-dark border p-2">@cat.Value()</span>
                                    }
                                    @if (!bookDetails.Book.AdditionalCategories.Any())
                                    {
                                        <span class="text-muted fst-italic small">No additional categories</span>
                                    }
                                </div>
                            </dd>

                            <dt class="col-sm-3 text-muted mt-2">Authors</dt>
                            <dd class="col-sm-9 mt-2">
                                @if (bookDetails.Authors.Any())
                                {
                                    <div class="d-flex flex-wrap gap-2">
                                        @foreach (var author in bookDetails.Authors)
                                        {
                                            <span class="badge bg-info text-dark d-flex align-items-center p-2">
                                                <i class="bi bi-person me-1"></i>
                                                <a href="/author-details/@author.AuthorId.Value" class="text-dark text-decoration-none">@author.Name.Value</a>
                                            </span>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted fst-italic">No authors associated</span>
                                }
                            </dd>
                        </dl>
                    </div>
                </div>

                <!-- Status & Availability Card -->
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-success text-white py-3">
                        <h5 class="card-title mb-0"><i class="bi bi-calendar-check me-2"></i>Status & Availability</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6 border-end">
                                <h6 class="text-uppercase text-muted fw-bold mb-3 small border-bottom pb-2">Current Loan</h6>
                                @if (FSharpOption<BookLibrary.Domain.Loan>.get_IsSome(bookDetails.CurrentLoan))
                                {
                                    var loan = bookDetails.CurrentLoan.Value;
                                    <div class="alert alert-warning mb-0">
                                        <p class="mb-1"><i class="bi bi-exclamation-triangle me-2"></i><strong>Currently Loaned Out</strong></p>
                                        <ul class="list-unstyled mb-0 small mt-2">
                                            <li><strong>Start:</strong> @loan.TimeSlot.Start.ToShortDateString()</li>
                                            <li><strong>Expected Return:</strong> @loan.TimeSlot.End.ToShortDateString()</li>
                                            <li><strong>Borrower UserId:</strong> @loan.UserId</li>
                                        </ul>
                                    </div>
                                }
                                else
                                {
                                    <div class="alert alert-success mb-0">
                                        <i class="bi bi-check-circle me-2"></i><strong>Available for Loan</strong>
                                    </div>
                                }
                            </div>
                            <div class="col-md-6">
                                <h6 class="text-uppercase text-muted fw-bold mb-3 small border-bottom pb-2">Future Reservations</h6>
                                @if (bookDetails.FutureReservations.Any())
                                {
                                    <ul class="list-group list-group-flush mb-0">
                                        @foreach (var res in bookDetails.FutureReservations)
                                        {
                                            <li class="list-group-item px-0 py-2 border-0 border-bottom">
                                                <div class="d-flex align-items-center">
                                                    <i class="bi bi-calendar-event me-2 text-primary"></i>
                                                    <div>
                                                        <div class="small fw-bold">@res.TimeSlot.Start.ToShortDateString() - @res.TimeSlot.End.ToShortDateString()</div>
                                                        <div class="small text-muted">User: @res.UserId</div>
                                                    </div>
                                                </div>
                                            </li>
                                        }
                                    </ul>
                                }
                                else
                                {
                                    <p class="text-muted fst-italic small mb-0">No active future reservations.</p>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public string BookIdStr { get; set; } = "";

    private bool isLoading = true;
    private Details.BookDetails? bookDetails;
    private string statusMessage = "";
    private string statusClass = "alert-info";

    private void GoBack()
    {
        JSRuntime.InvokeVoidAsync("history.back");
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadBookDetails();
    }

    private async Task LoadBookDetails()
    {
        isLoading = true;
        statusMessage = "";

        try
        {
            if (Guid.TryParse(BookIdStr, out var guid))
            {
                var bookId = BookId.NewBookId(guid);
                var result = await BookService.GetBookDetailsAsync(bookId, FSharpOption<CancellationToken>.None);

                if (result.IsOk)
                {
                    bookDetails = result.ResultValue;
                }
                else
                {
                    ShowStatus($"Failed to load book: {result.ErrorValue}", "alert-danger");
                }
            }
            else
            {
                ShowStatus("Invalid book identifier in URL.", "alert-danger");
            }
        }
        catch (Exception ex)
        {
            ShowStatus($"Error loading data: {ex.Message}", "alert-danger");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ShowStatus(string message, string cssClass)
    {
        statusMessage = message;
        statusClass = cssClass;
    }
}
