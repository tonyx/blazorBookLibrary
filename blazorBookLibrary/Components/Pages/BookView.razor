@page "/book-view/{BookIdStr}"
@using System.Globalization
@using BookLibrary.Shared.Services
@using BookLibrary.Domain
@using BookLibrary.Shared
@using static BookLibrary.Shared.Commons
@using Microsoft.FSharp.Core

@using blazorBookLibrary.Security
@inject IBookService BookService
@inject IUserService UserService
@inject ILogger<BookView> Logger
@inject IReservationService ReservationService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IConfiguration Configuration
@inject IJSRuntime JSRuntime
@using Microsoft.Extensions.Localization
@using blazorBookLibrary.Shared.Resources
@inject IStringLocalizer<SharedResources> L
@inject BotScoreService BotScoreService
@rendermode InteractiveServer

<PageTitle>@L["BookDetails"]</PageTitle>

<div class="sanctuary-container">
    <!-- Header Area -->
    <div class="d-flex justify-content-between align-items-end mb-5 border-bottom pb-4" style="border-color: var(--outline-variant) !important;">
        <div>
            <nav aria-label="breadcrumb" class="mb-2">
                <ol class="breadcrumb mb-0" style="font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--secondary);">
                    <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-reset">@L["Home"]</a></li>
                    <li class="breadcrumb-item active" aria-current="page">@L["BookDetails"]</li>
                </ol>
            </nav>
            <h1 class="display-5 mb-0" style="font-family: var(--font-serif); font-weight: 800; color: var(--primary);">@L["BookDetails"]</h1>
        </div>
        <button class="btn-sanctuary-outline" @onclick="GoBack">
            <i class="bi bi-arrow-left me-2"></i>@L["Back"]
        </button>
    </div>

    @if (isLoading)
    {
        <div class="d-flex justify-content-center align-items-center" style="min-height: 400px;">
            <div class="spinner-grow text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (bookDetails != null)
    {
        <div class="row g-5">
            <!-- Left Column: Visual & Status Rail -->
            <div class="col-lg-4">
                <div class="card-sanctuary floating mb-4 text-center">
                    <div class="book-cover-wrap mb-4 bg-surface-low shadow-sm" style="height: 450px; border-radius: 4px; overflow: hidden; display: flex; align-items: center; justify-content: center; position: relative;">
                        @if (FSharpOption<Uri>.get_IsSome(bookDetails.Book.ImageUrl))
                        {
                            <img src="@bookDetails.Book.ImageUrl.Value.ToString()" 
                                 alt="@bookDetails.Book.Title.Value Cover" 
                                 class="w-100 h-100" 
                                 style="object-fit: cover;" />
                        }
                        else
                        {
                            <div class="text-center text-muted opacity-25">
                                <i class="bi bi-journal-text" style="font-size: 5rem;"></i>
                                <span class="d-block mt-3 serif">@L["NoCoverAvailable"]</span>
                            </div>
                        }
                    </div>

                    <div class="d-flex flex-column gap-3 mt-2">
                        <div class="d-flex justify-content-center">
                            @if (bookDetails.Book.ImmediatelyAvailable)
                            {
                                <span class="badge-sanctuary badge-available">
                                    <i class="bi bi-check2-circle"></i> @L["AvailableForLoan"]
                                </span>
                            }
                            else
                            {
                                <span class="badge-sanctuary badge-borrowed">
                                    <i class="bi bi-hourglass-split"></i> @L["NotAvailable"]
                                </span>
                            }
                        </div>
                        
                        <div class="d-flex justify-content-center">
                             <span class="badge-sanctuary badge-neutral">
                                <i class="bi @(bookDetails.Book.Availability.IsCirculating ? "bi-journal-check" : "bi-journal-lock")"></i>
                                @GetAvailabilityLocalName(bookDetails.Book.Availability)
                            </span>
                        </div>
                    </div>

                    @if (bookDetails.Book.Availability.IsCirculating)
                    {
                        <div class="mt-5 p-4 bg-surface-low rounded-xl">
                            <h6 class="serif mb-3">@L["ReserveThisVolume"]</h6>
                            @if (userReservation != null)
                            {
                                <div class="p-3 mb-1 small text-start bg-surface-lowest rounded shadow-sm border-start border-4 border-info">
                                    <i class="bi bi-check2-all me-2 text-info"></i>
                                    @L["AlreadyReservedMessage", userReservation.ReservedAt.ToLocalTime().ToString("g")]
                                </div>
                            }
                            else if (loggedInUserDetails != null && 
                                     loggedInUserDetails.FutureReservations.Length >= Configuration.GetValue<int>("BooksLibrary:MaxReservationsPerUser", 3))
                            {
                                <div class="p-3 mb-1 small text-start bg-surface-lowest rounded shadow-sm border-start border-4 border-warning">
                                    <i class="bi bi-exclamation-octagon-fill me-2 text-warning"></i>
                                    @L["MaxReservationsReachedMessage", Configuration.GetValue<int>("BooksLibrary:MaxReservationsPerUser", 3)]
                                </div>
                            }
                            else
                            {
                                <button class="btn-sanctuary-primary w-100 justify-content-center" @onclick="ReserveBook">
                                    <i class="bi bi-calendar2-check"></i> @L["Reserve"]
                                </button>
                                <p class="text-muted small mt-3 mb-0">
                                    <i class="bi bi-people-fill me-1"></i> @L["Reservations"]: @bookDetails.ReservationsDetails.Length
                                </p>
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- Right Column: Editorial Details -->
            <div class="col-lg-8">
                <div class="card-sanctuary bg-surface-lowest">
                    <h2 class="serif display-6 mb-2">@bookDetails.Book.Title.Value</h2>
                    
                    <div class="d-flex flex-wrap gap-2 mb-4">
                        @foreach (var author in bookDetails.Authors)
                        {
                            <a href="/author-view/@author.AuthorId.Value" class="text-decoration-none">
                                <span class="badge-sanctuary badge-neutral" style="color: var(--secondary);">
                                    <i class="bi bi-person-fill"></i> @author.Name.Value
                                </span>
                            </a>
                        }
                    </div>

                    <div class="row mt-5">
                        <div class="col-md-7">
                            <h5 class="serif mb-3 pb-2 border-bottom" style="border-color: var(--outline-variant) !important;">@L["Description"]</h5>
                            @if (FSharpOption<string>.get_IsSome(bookDetails.Book.Description))
                            {
                                <div class="pe-md-4" style="line-height: 1.8; color: var(--on-surface); font-size: 1.05rem;">
                                    @bookDetails.Book.Description.Value
                                </div>
                            }
                            else
                            {
                                <p class="text-muted fst-italic">@L["NoDescriptionAvailable"]</p>
                            }
                        </div>
                        
                        <div class="col-md-5 mt-4 mt-md-0">
                            <div class="p-4 bg-surface-low rounded-xl">
                                <h5 class="serif mb-4">@L["Metadata"]</h5>
                                <dl class="details-list mb-0">
                                    <dt>@L["ISBN"]</dt>
                                    <dd>@bookDetails.Book.Isbn.Value</dd>

                                    <dt>@L["PublicationYear"]</dt>
                                    <dd>@bookDetails.Book.Year.Value</dd>

                                    <dt>@L["MainCategory"]</dt>
                                    <dd>
                                        <span class="badge-sanctuary badge-neutral mt-1">@bookDetails.Book.MainCategory.Value()</span>
                                    </dd>
                                    
                                    @if (bookDetails.Book.AdditionalCategories.Any())
                                    {
                                        <dt>@L["Categories"]</dt>
                                        <dd>
                                            <div class="d-flex flex-wrap gap-1 mt-2">
                                                @foreach (var cat in bookDetails.Book.AdditionalCategories)
                                                {
                                                    <span class="badge-sanctuary bg-surface-container text-muted" style="font-size: 0.7rem;">@cat.Value()</span>
                                                }
                                            </div>
                                        </dd>
                                    }
                                </dl>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public string BookIdStr { get; set; } = "";

    private bool isLoading = true;
    private Details.BookDetails? bookDetails;
    private Details.UserDetails? loggedInUserDetails;
    private Reservation? userReservation;
    private string statusMessage = "";
    private string statusClass = "alert-info";

    private void GoBack()
    {
        JSRuntime.InvokeVoidAsync("history.back");
    }

    private async Task ReserveBook()
    {
        if (bookDetails == null) return;
        
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        
        if (user.Identity?.IsAuthenticated != true)
        {
            await ShowStatus(L["PleaseLoginToReserve"], "alert-warning");
            return;
        }

        var userIdStr = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (string.IsNullOrEmpty(userIdStr) || !Guid.TryParse(userIdStr, out var userGuid))
        {
            await ShowStatus(L["UserIdentifierNotFound"], "alert-danger");
            return;
        }

        var sharpinoUserId = UserId.NewUserId(userGuid);
        
        int maxReservations = Configuration.GetValue<int>("BooksLibrary:MaxReservationsPerUser", 3);

        if (userReservation != null)
        {
            await ShowStatus(L["AlreadyReservedMessage", userReservation.ReservedAt.ToLocalTime().ToString("g")], "alert-warning");
            return;
        }

        if (loggedInUserDetails != null && loggedInUserDetails.FutureReservations.Length >= maxReservations)
        {
            await ShowStatus(L["MaxReservationsReachedMessage", maxReservations], "alert-warning");
            return;
        }

        try 
        {
            isLoading = true;
            StateHasChanged();

            int loanDuration = Configuration.GetValue<int>("BooksLibrary::TimeSlotLoanDurationInDays", 30);
            var now = DateTime.UtcNow;
            var nextSlot = bookDetails.GetNextAvailableTimeSlot(loanDuration, now);
            
            var reservation = Reservation.New(bookDetails.Book.BookId, sharpinoUserId, nextSlot, now);
            
            var result = await ReservationService.AddReservationAsync(reservation, ShortLang.New(CultureInfo.CurrentCulture.Name.Substring(0,2)), FSharpOption<System.Threading.CancellationToken>.None);
            
            if (result.IsOk)
            {
                await ShowStatus(L["ReservationSuccessMessage"], "alert-success");
                await LoadBookDetails();
                await LoadUserReservation();
            }
            else
            {
                await ShowStatus(L["ReservationFailedMessage", result.ErrorValue], "alert-danger");
            }
        }
        catch (Exception ex)
        {
            await ShowStatus(L["ReservationFailedMessage", ex.Message], "alert-danger");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadBookDetails();
        await LoadUserReservation();
    }

    private async Task LoadBookDetails()
    {
        isLoading = true;
        statusMessage = "";

        try
        {
            if (Guid.TryParse(BookIdStr, out var guid))
            {
                var bookId = BookId.NewBookId(guid);
                var result = await BookService.GetBookDetailsAsync(bookId, FSharpOption<CancellationToken>.None);

                if (result.IsOk)
                {
                    bookDetails = result.ResultValue;
                }
                else
                {
                    await ShowStatus(string.Format(L["ErrorLoadingBook"], result.ErrorValue), "alert-danger");
                }
            }
            else
            {
                await ShowStatus(L["InvalidBookIdInUrl"], "alert-danger");
            }
        }
        catch (Exception ex)
        {
            await ShowStatus(string.Format(L["ErrorLoadingData"], ex.Message), "alert-danger");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadUserReservation()
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            
            if (user.Identity?.IsAuthenticated == true)
            {
                var userIdStr = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                if (!string.IsNullOrEmpty(userIdStr) && Guid.TryParse(userIdStr, out var userGuid))
                {
                    var sharpinoUserId = UserId.NewUserId(userGuid);
                    var result = await UserService.GetUserDetailsAsync(sharpinoUserId, FSharpOption<System.Threading.CancellationToken>.None);
                    
                    if (result.IsOk)
                    {
                        loggedInUserDetails = result.ResultValue;
                        if (bookDetails != null)
                        {
                            userReservation = loggedInUserDetails.FutureReservations
                                .Select(t => t.Item1)
                                .FirstOrDefault(r => r.BookId.Value == bookDetails.Book.BookId.Value);
                        }
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading user reservation: {ex.Message}");
        }
    }
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        var siteKey = Configuration["Authentication:Recaptcha:SiteKey"];
        if (siteKey is null)
            {
                Logger.LogWarning("Recaptcha SiteKey is not configured");
                return;
            }
        if (firstRender)
        {
            var token = await JSRuntime.InvokeAsync<string>("generateRecaptchaToken", siteKey, "book_view");
            var score = await BotScoreService.GetBotScoreAsync(token);
            if (score < 0.7) 
            {
                Logger.LogInformation($"suspect bot interaction. Score: {score}");
                await BotScoreService.ApplyBotDelayAsync(score);
            }
        }
    }

    private async Task ShowStatus(string message, string cssClass)
    {
        statusMessage = message;
        statusClass = cssClass;

        string type = "info";
        if (cssClass.Contains("success")) type = "success";
        else if (cssClass.Contains("danger")) type = "error";
        else if (cssClass.Contains("warning")) type = "warning";

        await JSRuntime.InvokeVoidAsync("showToast", message, type);
    }

    private string GetAvailabilityLocalName(Availability availability)
    {
        if (availability.IsCirculating) return L["CirculatingRule"];
        if (availability.IsReferenceOnly) return L["ReferenceOnlyRule"];
        return L["UnspecifiedRule"];
    }
}
