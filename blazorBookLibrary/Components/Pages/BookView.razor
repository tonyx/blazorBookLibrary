@page "/book-view/{BookIdStr}"
@using BookLibrary.Shared.Services
@using BookLibrary.Domain
@using BookLibrary.Shared
@using static BookLibrary.Shared.Commons
@using Microsoft.FSharp.Core

@inject IBookService BookService
@inject IUserService UserService
@inject IReservationService ReservationService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IConfiguration Configuration
@inject IJSRuntime JSRuntime
@using Microsoft.Extensions.Localization
@using blazorBookLibrary.Shared.Resources
@inject IStringLocalizer<SharedResources> L
@rendermode InteractiveServer

<PageTitle>Book Details</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-primary mb-0"><i class="bi bi-info-circle me-2"></i>@L["BookDetails"]</h1>
        <button class="btn btn-outline-secondary" @onclick="GoBack">
            <i class="bi bi-arrow-left me-1"></i>@L["Back"]
        </button>
    </div>

    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div class="alert @statusClass alert-dismissible fade show mb-4" role="alert">
            @statusMessage
            <button type="button" class="btn-close" @onclick='() => statusMessage = ""'></button>
        </div>
    }

    @if (isLoading)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (bookDetails != null)
    {
        <div class="row g-4">
            <!-- Book Cover Image Section -->
            <div class="col-md-3">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-header bg-info text-white py-3">
                        <h5 class="card-title mb-0"><i class="bi bi-image me-2"></i>@L["BookCover"]</h5>
                    </div>
                    <div class="card-body d-flex flex-column align-items-center">
                        <div class="book-cover-container shadow-sm border rounded p-2 bg-white d-flex align-items-center justify-content-center w-100" style="min-height: 250px; max-height: 400px; overflow: hidden;">
                            @if (FSharpOption<Uri>.get_IsSome(bookDetails.Book.ImageUrl))
                            {
                                <img src="@bookDetails.Book.ImageUrl.Value.ToString()" 
                                     class="img-fluid rounded shadow-sm" 
                                     alt="Book Cover" 
                                     style="max-height: 100%; max-width: 100%; object-fit: contain;" />
                            }
                            else
                            {
                                <div class="text-center text-muted opacity-50 p-4">
                                    <i class="bi bi-book h1 d-block mb-2"></i>
                                    <span class="small d-block">@L["NoCoverAvailable"]</span>
                                </div>
                            }
                        </div>
                        
                        @if (FSharpOption<Uri>.get_IsSome(bookDetails.Book.ImageUrl))
                        {
                            <div class="mt-3 w-100 text-center">
                                <a href="@bookDetails.Book.ImageUrl.Value.ToString()" target="_blank" class="btn btn-sm btn-outline-info w-100">
                                    <i class="bi bi-box-arrow-up-right me-1"></i> @L["ViewFullImage"]
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Book Details & Status Section -->
            <div class="col-md-9">
                <!-- General Info Card -->
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-header bg-primary text-white py-3">
                        <h5 class="card-title mb-0"><i class="bi bi-book me-2"></i>@L["GeneralInformation"]</h5>
                    </div>
                    <div class="card-body">
                        <dl class="row mb-0">
                            <dt class="col-sm-3 text-muted">@L["Title"]</dt>
                            <dd class="col-sm-9 fw-bold fs-5">@bookDetails.Book.Title.Value</dd>

                            <dt class="col-sm-3 text-muted mt-2">@L["ISBN"]</dt>
                            <dd class="col-sm-9 mt-2">@bookDetails.Book.Isbn.Value</dd>

                            <dt class="col-sm-3 text-muted mt-2">@L["PublicationYear"]</dt>
                            <dd class="col-sm-9 mt-2">@bookDetails.Book.Year.Value</dd>

                            <dt class="col-sm-3 text-muted mt-2">@L["MainCategory"]</dt>
                            <dd class="col-sm-9 mt-2">
                                <span class="badge bg-secondary">@bookDetails.Book.MainCategory.Value()</span>
                            </dd>
                            
                            <dt class="col-sm-3 text-muted mt-2">@L["AdditionalCategories"]</dt>
                            <dd class="col-sm-9 mt-2">
                                <div class="d-flex flex-wrap align-items-center gap-2">
                                    @foreach (var cat in bookDetails.Book.AdditionalCategories)
                                    {
                                        <span class="badge rounded-pill bg-light text-dark border p-2">@cat.Value()</span>
                                    }
                                    @if (!bookDetails.Book.AdditionalCategories.Any())
                                    {
                                        <span class="text-muted fst-italic small">@L["NoAdditionalCategories"]</span>
                                    }
                                </div>
                            </dd>

                            <dt class="col-sm-3 text-muted mt-2">@L["Authors"]</dt>
                            <dd class="col-sm-9 mt-2">
                                @if (bookDetails.Authors.Any())
                                {
                                    <div class="d-flex flex-wrap gap-2">
                                        @foreach (var author in bookDetails.Authors)
                                        {
                                            <span class="badge bg-info text-dark d-flex align-items-center p-2">
                                                <i class="bi bi-person me-1"></i>
                                                <a href="/author-details/@author.AuthorId.Value" class="text-dark text-decoration-none">@author.Name.Value</a>
                                            </span>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted fst-italic">@L["NoAuthorsAssociated"]</span>
                                }
                            </dd>

                            <dt class="col-sm-3 text-muted mt-2">@L["Description"]</dt>
                            <dd class="col-sm-9 mt-2">
                                @if (FSharpOption<string>.get_IsSome(bookDetails.Book.Description))
                                {
                                    <p class="mb-0 text-break" style="white-space: pre-wrap;">@bookDetails.Book.Description.Value</p>
                                }
                                else
                                {
                                    <span class="text-muted fst-italic small">@L["NoDescriptionAvailable"]</span>
                                }
                            </dd>
                        </dl>
                    </div>
                </div>

                <!-- Status & Availability Card -->
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-success text-white py-3">
                        <h5 class="card-title mb-0"><i class="bi bi-calendar-check me-2"></i>@L["StatusAvailability"]</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6 border-end">
                                <h6 class="text-uppercase text-muted fw-bold mb-3 small border-bottom pb-2">@L["CurrentLoan"]</h6>
                                @if (bookDetails.Book.ImmediatelyAvailable)
                                {
                                    <div class="alert alert-success mb-0">
                                        <i class="bi bi-check-circle me-2"></i><strong>@L["AvailableForLoan"]</strong>
                                    </div>
                                } 
                                else
                                {
                                    <div class="alert alert-warning mb-0">
                                        <i class="bi bi-exclamation-triangle me-2"></i><strong>@L["NotAvailable"]</strong>
                                    </div>
                                }
                            </div>

                            <div class="col-md-6 px-4">
                                <h6 class="text-uppercase text-muted fw-bold mb-3 small border-bottom pb-2">@L["Availability"]</h6>
                                <div class="d-flex align-items-center gap-3">
                                    <span class="badge @(bookDetails.Book.Availability.IsCirculating ? "bg-success" : bookDetails.Book.Availability.IsReferenceOnly ? "bg-warning text-dark" : "bg-secondary") fs-6 shadow-sm p-2">
                                        <i class="bi @(bookDetails.Book.Availability.IsCirculating ? "bi-journal-check" : bookDetails.Book.Availability.IsReferenceOnly ? "bi-journals" : "bi-journal-x") me-2"></i>
                                        @GetAvailabilityLocalName(bookDetails.Book.Availability)
                                    </span>
                                    
                                    @if (bookDetails.Book.Availability.IsCirculating)
                                    {
                                        <div class="d-flex flex-column align-items-start gap-2">
                                            @if (userReservation != null)
                                            {
                                                <div class="alert alert-info py-2 px-3 mb-1 shadow-sm border-0 bg-opacity-10 border-start border-4 border-info">
                                                    <i class="bi bi-info-circle-fill me-2 text-info"></i>
                                                    @L["AlreadyReservedMessage", userReservation.ReservedAt.ToLocalTime().ToString("g")]
                                                </div>
                                            }
                                            else if (loggedInUserDetails != null && 
                                                     loggedInUserDetails.FutureReservations.Length >= Configuration.GetValue<int>("BooksLibrary:MaxReservationsPerUser", 3))
                                            {
                                                <div class="alert alert-warning py-2 px-3 mb-1 shadow-sm border-0 bg-opacity-10 border-start border-4 border-warning">
                                                    <i class="bi bi-exclamation-triangle-fill me-2 text-warning"></i>
                                                    @L["MaxReservationsReachedMessage", Configuration.GetValue<int>("BooksLibrary:MaxReservationsPerUser", 3)]
                                                </div>
                                            }
                                            else
                                            {
                                                <button class="btn btn-primary shadow-sm" @onclick="ReserveBook">
                                                    <i class="bi bi-calendar-plus me-1"></i> @L["Reserve"]
                                                </button>
                                            }
                                            
                                            <span class="text-muted small mt-1">
                                                <i class="bi bi-people me-1"></i>
                                                @L["Reservations"]: @bookDetails.ReservationsDetails.Length
                                            </span>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public string BookIdStr { get; set; } = "";

    private bool isLoading = true;
    private Details.BookDetails? bookDetails;
    private Details.UserDetails? loggedInUserDetails;
    private Reservation? userReservation;
    private string statusMessage = "";
    private string statusClass = "alert-info";

    private void GoBack()
    {
        JSRuntime.InvokeVoidAsync("history.back");
    }

    private async Task ReserveBook()
    {
        if (bookDetails == null) return;
        
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        
        if (user.Identity?.IsAuthenticated != true)
        {
            ShowStatus(L["PleaseLoginToReserve"], "alert-warning");
            return;
        }

        var userIdStr = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (string.IsNullOrEmpty(userIdStr) || !Guid.TryParse(userIdStr, out var userGuid))
        {
            ShowStatus(L["UserIdentifierNotFound"], "alert-danger");
            return;
        }

        var sharpinoUserId = UserId.NewUserId(userGuid);
        
        int maxReservations = Configuration.GetValue<int>("BooksLibrary:MaxReservationsPerUser", 3);

        if (userReservation != null)
        {
            ShowStatus(L["AlreadyReservedMessage", userReservation.ReservedAt.ToLocalTime().ToString("g")], "alert-warning");
            return;
        }

        if (loggedInUserDetails != null && loggedInUserDetails.FutureReservations.Length >= maxReservations)
        {
            ShowStatus(L["MaxReservationsReachedMessage", maxReservations], "alert-warning");
            return;
        }

        try 
        {
            isLoading = true;
            StateHasChanged();

            int loanDuration = Configuration.GetValue<int>("BooksLibrary::TimeSlotLoanDurationInDays", 30);
            var now = DateTime.UtcNow;
            var nextSlot = bookDetails.GetNextAvailableTimeSlot(loanDuration, now);
            
            var reservation = Reservation.New(bookDetails.Book.BookId, sharpinoUserId, nextSlot, now);
            
            var result = await ReservationService.AddReservationAsync(reservation, FSharpOption<System.Threading.CancellationToken>.None);
            
            if (result.IsOk)
            {
                ShowStatus(L["ReservationSuccessMessage"], "alert-success");
                await LoadBookDetails();
                await LoadUserReservation();
            }
            else
            {
                ShowStatus(L["ReservationFailedMessage", result.ErrorValue], "alert-danger");
            }
        }
        catch (Exception ex)
        {
            ShowStatus(L["ReservationFailedMessage", ex.Message], "alert-danger");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadBookDetails();
        await LoadUserReservation();
    }

    private async Task LoadBookDetails()
    {
        isLoading = true;
        statusMessage = "";

        try
        {
            if (Guid.TryParse(BookIdStr, out var guid))
            {
                var bookId = BookId.NewBookId(guid);
                var result = await BookService.GetBookDetailsAsync(bookId, FSharpOption<CancellationToken>.None);

                if (result.IsOk)
                {
                    bookDetails = result.ResultValue;
                }
                else
                {
                    ShowStatus($"Failed to load book: {result.ErrorValue}", "alert-danger");
                }
            }
            else
            {
                ShowStatus("Invalid book identifier in URL.", "alert-danger");
            }
        }
        catch (Exception ex)
        {
            ShowStatus($"Error loading data: {ex.Message}", "alert-danger");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadUserReservation()
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            
            if (user.Identity?.IsAuthenticated == true)
            {
                var userIdStr = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                if (!string.IsNullOrEmpty(userIdStr) && Guid.TryParse(userIdStr, out var userGuid))
                {
                    var sharpinoUserId = UserId.NewUserId(userGuid);
                    var result = await UserService.GetUserDetailsAsync(sharpinoUserId, FSharpOption<System.Threading.CancellationToken>.None);
                    
                    if (result.IsOk)
                    {
                        loggedInUserDetails = result.ResultValue;
                        if (bookDetails != null)
                        {
                            userReservation = loggedInUserDetails.FutureReservations.FirstOrDefault(r => r.BookId.Value == bookDetails.Book.BookId.Value);
                        }
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading user reservation: {ex.Message}");
        }
    }

    private void ShowStatus(string message, string cssClass)
    {
        statusMessage = message;
        statusClass = cssClass;
    }

    private string GetAvailabilityLocalName(Availability availability)
    {
        if (availability.IsCirculating) return L["CirculatingRule"];
        if (availability.IsReferenceOnly) return L["ReferenceOnlyRule"];
        return L["UnspecifiedRule"];
    }
}
