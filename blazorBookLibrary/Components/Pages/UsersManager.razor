@page "/users-manager"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using blazorBookLibrary.Data
@attribute [Authorize(Roles = "Admin")]
@inject UserManager<ApplicationUser> UserManager
@inject RoleManager<IdentityRole> RoleManager
@inject IStringLocalizer<SharedResources> L
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<PageTitle>@L["UsersManager"] — @L["TheModernArchivist"]</PageTitle>

<div class="sanctuary-container py-5">
    <div class="mb-5">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-muted">@L["Home"]</a></li>
                <li class="breadcrumb-item active text-serif" aria-current="page">@L["EditorialAccountLedger"]</li>
            </ol>
        </nav>
        <h1 class="display-4 text-serif mb-2">@L["EditorialAccountLedger"]</h1>
        <p class="text-muted lead">@L["ManageSystemAccountRolesAndPermissions"]</p>
    </div>

    <div class="row g-4">
        @* Search & Patron Directory Section *@
        <div class="col-lg-8">
            <div class="card-sanctuary p-4 mb-4">
                <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
                    <h2 class="h4 text-serif mb-0">@L["PatronDirectory"]</h2>
                    <div class="input-group" style="max-width: 350px;">
                        <span class="input-group-text bg-transparent border-end-0 text-muted">
                            <i class="bi bi-search"></i>
                        </span>
                        <input type="text" class="form-control border-start-0 ps-0" 
                               placeholder="@L["SearchByEmailOrNamePlaceholder"]" 
                               @bind="searchQuery" @bind:event="oninput" 
                               @onkeyup="HandleKeyUp" />
                    </div>
                </div>

                @if (searchResults != null)
                {
                    <div class="editorial-ledger-container">
                        @if (searchResults.Any())
                        {
                            <table class="editorial-ledger w-100">
                                <thead>
                                    <tr>
                                        <th class="ps-3">@L["ArchivalPatron"]</th>
                                        <th>@L["CurrentArchivalRoles"]</th>
                                        <th class="text-end pe-3">@L["Actions"]</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var user in searchResults)
                                    {
                                        <tr>
                                            <td class="ps-3 py-3">
                                                <div class="fw-bold">@user.Nome @user.Cognome</div>
                                                <div class="text-muted small">@user.Email</div>
                                            </td>
                                            <td class="py-3">
                                                <div class="d-flex flex-wrap gap-1">
                                                    @foreach (var role in GetUserRoles(user.Id))
                                                    {
                                                        <span class="badge-sanctuary">@role</span>
                                                    }
                                                </div>
                                            </td>
                                            <td class="text-end pe-3 py-3">
                                                @if (IsManager(user.Id))
                                                {
                                                    <button class="btn btn-outline-danger btn-sm rounded-pill px-3" @onclick="() => ToggleManagerRole(user, false)">
                                                        <i class="bi bi-person-dash me-1"></i> @L["RevokeRole"]
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button class="btn btn-outline-primary btn-sm rounded-pill px-3" @onclick="() => ToggleManagerRole(user, true)">
                                                        <i class="bi bi-person-plus me-1"></i> @L["AssignManager"]
                                                    </button>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <div class="text-center py-5 bg-surface-low rounded-3">
                                <i class="bi bi-person-x display-4 text-muted mb-3 d-block"></i>
                                <p class="text-muted mb-0">@L["NoPatronsFound"]</p>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-5 bg-surface-low rounded-3 border-dashed">
                        <i class="bi bi-search text-muted mb-2 d-block h3"></i>
                        <p class="text-muted mb-0">@L["EnterSearchQueryToBegin"]</p>
                    </div>
                }
            </div>
        </div>

        @* Existing Managers Section *@
        <div class="col-lg-4">
            <div class="card-sanctuary p-4 sticky-top" style="top: 2rem;">
                <h2 class="h5 text-serif mb-4 border-bottom pb-2">@L["SystemAccountManagers"]</h2>
                
                @if (managers == null)
                {
                    <div class="d-flex align-items-center justify-content-center py-4">
                        <div class="spinner-border spinner-border-sm text-primary me-2" role="status"></div>
                        <span class="text-muted">@L["Loading"]...</span>
                    </div>
                }
                else if (!managers.Any())
                {
                    <div class="bg-surface-low p-4 rounded-3 text-center">
                        <p class="text-muted mb-0 small">@L["NoArchivalManagersFound"]</p>
                    </div>
                }
                else
                {
                    <div class="list-group list-group-flush">
                        @foreach (var manager in managers)
                        {
                            <div class="list-group-item bg-transparent border-0 px-0 py-3 d-flex justify-content-between align-items-center border-bottom-dashed">
                                <div class="overflow-hidden">
                                    <div class="fw-bold text-truncate">@manager.Nome @manager.Cognome</div>
                                    <div class="text-muted small text-truncate">@manager.Email</div>
                                </div>
                                <button class="btn btn-link text-danger p-0 ms-2" 
                                        title="@L["RevokeRole"]"
                                        @onclick="() => ToggleManagerRole(manager, false)">
                                    <i class="bi bi-person-x-fill h5 mb-0"></i>
                                </button>
                            </div>
                        }
                    </div>
                }

                <div class="mt-4 p-3 bg-surface-low rounded-3">
                    <h6 class="small fw-bold mb-2 text-uppercase letter-spacing-1">@L["AdministrativeNote"]</h6>
                    <p class="small text-muted mb-0">
                        @L["ManagerRoleGrantsAccessToAdministrativeTools"]
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string searchQuery = "";
    private List<ApplicationUser>? searchResults;
    private List<ApplicationUser>? managers;
    private string statusMessage = "";
    private Dictionary<string, IList<string>> userRolesCache = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadManagers();
    }

    private async Task LoadManagers()
    {
        var users = await UserManager.GetUsersInRoleAsync("Manager");
        managers = users.ToList();
        
        // Update roles cache for these users
        foreach (var user in managers)
        {
            if (user.Id != null)
            {
                userRolesCache[user.Id] = await UserManager.GetRolesAsync(user);
            }
        }
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SearchUsers();
        }
        else if (searchQuery.Length > 2)
        {
            // Optional: Debounced search could go here
            await SearchUsers();
        }
    }

    private async Task SearchUsers()
    {
        if (string.IsNullOrWhiteSpace(searchQuery))
        {
            searchResults = null;
            return;
        }

        // Simplistic search across several fields
        var allUsers = UserManager.Users.ToList(); // In production, filter on the database side
        searchResults = allUsers
            .Where(u => (u.Email?.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ?? false) ||
                        (u.UserName?.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ?? false) ||
                        (u.Nome?.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ?? false) ||
                        (u.Cognome?.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ?? false))
            .Take(10)
            .ToList();

        // Update roles cache for results
        foreach (var user in searchResults)
        {
            if (user.Id != null)
            {
                userRolesCache[user.Id] = await UserManager.GetRolesAsync(user);
            }
        }
    }

    private IEnumerable<string> GetUserRoles(string userId)
    {
        return userRolesCache.TryGetValue(userId, out var roles) ? roles : Enumerable.Empty<string>();
    }

    private bool IsManager(string userId)
    {
        return GetUserRoles(userId).Any(r => r == "Manager");
    }

    private async Task ToggleManagerRole(ApplicationUser user, bool assign)
    {
        IdentityResult result;
        if (assign)
        {
            result = await UserManager.AddToRoleAsync(user, "Manager");
            var message = result.Succeeded ? L["AssignedManagerRoleTo", user.Email].Value : $"{L["Error"]}: {string.Join(", ", result.Errors.Select(e => e.Description))}";
            await ShowStatus(message, result.Succeeded ? "success" : "error");
        }
        else
        {
            result = await UserManager.RemoveFromRoleAsync(user, "Manager");
            var message = result.Succeeded ? L["RevokedManagerRoleFrom", user.Email].Value : $"{L["Error"]}: {string.Join(", ", result.Errors.Select(e => e.Description))}";
            await ShowStatus(message, result.Succeeded ? "success" : "error");
        }

        if (result.Succeeded)
        {
            // Refresh local state
            if (user.Id != null)
            {
                userRolesCache[user.Id] = await UserManager.GetRolesAsync(user);
            }
            await LoadManagers();
            await SearchUsers(); // Refresh search view too
        }
    }

    private async Task ShowStatus(string message, string type)
    {
        statusMessage = message;
        await JSRuntime.InvokeVoidAsync("showToast", message, type);
    }
}

<style>
    .border-dashed {
        border: 2px dashed #dee2e6;
    }
    .border-bottom-dashed {
        border-bottom: 1px dashed #dee2e6 !important;
    }
    .letter-spacing-1 {
        letter-spacing: 1px;
    }
    
    /* Ensuring responsiveness for the ledger on mobile */
    @@media (max-width: 768px) {
        .editorial-ledger thead {
            display: none;
        }
        .editorial-ledger td {
            display: block;
            width: 100%;
            text-align: left !important;
            padding: 0.5rem 1rem !important;
        }
        .editorial-ledger td:first-child {
            padding-top: 1.5rem !important;
            font-size: 1.1rem;
        }
        .editorial-ledger td:last-child {
            padding-bottom: 1.5rem !important;
            border-bottom: 1px solid #eee;
        }
    }
</style>
