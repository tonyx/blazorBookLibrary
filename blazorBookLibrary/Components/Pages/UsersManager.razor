@page "/users-manager"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using blazorBookLibrary.Data
@attribute [Authorize(Roles = "Admin")]
@inject UserManager<ApplicationUser> UserManager
@inject RoleManager<IdentityRole> RoleManager
@inject IStringLocalizer<SharedResources> L
@rendermode InteractiveServer

<PageTitle>@L["UsersManager"]</PageTitle>

<h3>@L["UsersManager"]</h3>

<div class="mb-4">
    <h4>@L["Search"]</h4>
    <div class="input-group mb-3" style="max-width: 500px;">
        <input type="text" class="form-control" placeholder="@L["SearchByEmailOrNamePlaceholder"]" @bind="searchQuery" @bind:event="oninput" />
        <button class="btn btn-primary" type="button" @onclick="SearchUsers">@L["Search"]</button>
    </div>

    @if (searchResults != null)
    {
        @if (searchResults.Any())
        {
            <table class="table table-hover mt-3">
                <thead class="table-light">
                    <tr>
                        <th>@L["Email"]</th>
                        <th>@L["Name"]</th>
                        <th>@L["CurrentRoles"]</th>
                        <th>@L["Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in searchResults)
                    {
                        <tr>
                            <td>@user.Email</td>
                            <td>@user.Nome @user.Cognome</td>
                            <td>
                                @foreach (var role in GetUserRoles(user.Id))
                                {
                                    <span class="badge bg-secondary me-1">@role</span>
                                }
                            </td>
                            <td>
                                @if (IsManager(user.Id))
                                {
                                    <button class="btn btn-warning btn-sm" @onclick="() => ToggleManagerRole(user, false)">@L["RevokeManager"]</button>
                                }
                                else
                                {
                                    <button class="btn btn-success btn-sm" @onclick="() => ToggleManagerRole(user, true)">@L["AssignManager"]</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-muted">@L["NoUsersFound"]</p>
        }
    }
</div>

<hr />

<div class="mt-4">
    <h4>@L["ExistingManagers"]</h4>
    @if (managers == null)
    {
        <p><em>@L["Loading"]...</em></p>
    }
    else if (!managers.Any())
    {
        <p>@L["NoManagersFound"]</p>
    }
    else
    {
        <table class="table table-striped mt-3">
            <thead class="table-dark">
                <tr>
                    <th>@L["Email"]</th>
                    <th>@L["Name"]</th>
                    <th>@L["Actions"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var manager in managers)
                {
                    <tr>
                        <td>@manager.Email</td>
                        <td>@manager.Nome @manager.Cognome</td>
                        <td>
                            <button class="btn btn-danger btn-sm" @onclick="() => ToggleManagerRole(manager, false)">@L["RevokeRole"]</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@if (!string.IsNullOrEmpty(statusMessage))
{
    <div class="alert alert-info mt-3 alert-dismissible fade show" role="alert">
        @statusMessage
        <button type="button" class="btn-close" @onclick='() => statusMessage = ""'></button>
    </div>
}

@code {
    private string searchQuery = "";
    private List<ApplicationUser>? searchResults;
    private List<ApplicationUser>? managers;
    private string statusMessage = "";
    private Dictionary<string, IList<string>> userRolesCache = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadManagers();
    }

    private async Task LoadManagers()
    {
        var users = await UserManager.GetUsersInRoleAsync("Manager");
        managers = users.ToList();
        
        // Update roles cache for these users
        foreach (var user in managers)
        {
            if (user.Id != null)
            {
                userRolesCache[user.Id] = await UserManager.GetRolesAsync(user);
            }
        }
    }

    private async Task SearchUsers()
    {
        if (string.IsNullOrWhiteSpace(searchQuery))
        {
            searchResults = null;
            return;
        }

        // Simplistic search across several fields
        var allUsers = UserManager.Users.ToList(); // In production, filter on the database side
        searchResults = allUsers
            .Where(u => (u.Email?.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ?? false) ||
                        (u.UserName?.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ?? false) ||
                        (u.Nome?.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ?? false) ||
                        (u.Cognome?.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ?? false))
            .Take(10)
            .ToList();

        // Update roles cache for results
        foreach (var user in searchResults)
        {
            if (user.Id != null)
            {
                userRolesCache[user.Id] = await UserManager.GetRolesAsync(user);
            }
        }
    }

    private IEnumerable<string> GetUserRoles(string userId)
    {
        return userRolesCache.TryGetValue(userId, out var roles) ? roles : Enumerable.Empty<string>();
    }

    private bool IsManager(string userId)
    {
        return GetUserRoles(userId).Any(r => r == "Manager");
    }

    private async Task ToggleManagerRole(ApplicationUser user, bool assign)
    {
        IdentityResult result;
        if (assign)
        {
            result = await UserManager.AddToRoleAsync(user, "Manager");
            statusMessage = result.Succeeded ? L["AssignedManagerRoleTo", user.Email].Value : $"{L["Error"]}: {string.Join(", ", result.Errors.Select(e => e.Description))}";
        }
        else
        {
            result = await UserManager.RemoveFromRoleAsync(user, "Manager");
            statusMessage = result.Succeeded ? L["RevokedManagerRoleFrom", user.Email].Value : $"{L["Error"]}: {string.Join(", ", result.Errors.Select(e => e.Description))}";
        }

        if (result.Succeeded)
        {
            // Refresh local state
            if (user.Id != null)
            {
                userRolesCache[user.Id] = await UserManager.GetRolesAsync(user);
            }
            await LoadManagers();
        }
    }
}
