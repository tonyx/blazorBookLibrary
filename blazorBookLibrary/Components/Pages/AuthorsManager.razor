@page "/authors-manager"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.QuickGrid
@using BookLibrary.Shared.Services
@using blazorBookLibrary.Shared.Resources
@using BookLibrary.Domain
@using static BookLibrary.Shared.Commons
@using Microsoft.FSharp.Core
@using Microsoft.FSharp.Collections
@using System.Threading

@attribute [Authorize(Roles = "Admin, Manager")]
@inject IAuthorService AuthorService
@inject IAuthorsSearchService AuthorsSearchService
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<SharedResources> L
@rendermode InteractiveServer

<PageTitle>@L["AuthorsManager"] — @L["TheModernArchivist"]</PageTitle>

<div class="sanctuary-container py-5">
    @* Page Header *@
    <div class="mb-5">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-muted">@L["Home"]</a></li>
                <li class="breadcrumb-item active text-serif" aria-current="page">@L["AuthorsManager"]</li>
            </ol>
        </nav>
        <div class="d-flex justify-content-between align-items-end">
            <div>
                <h1 class="display-4 text-serif mb-2">@L["AuthorRegistry"]</h1>
                <p class="text-muted lead mb-0">@L["ManageCatalogedAuthors"]</p>
            </div>
            
            <button class="btn btn-sanctuary @(showAddSection ? "active" : "")" @onclick="() => showAddSection = !showAddSection">
                <i class="bi @(showAddSection ? "bi-dash-lg" : "bi-plus-lg") me-2"></i>
                @(showAddSection ? L["CloseEntryForm"] : L["NewAuthorRegistration"])
            </button>
        </div>
    </div>

    @* Search Filters *@
    <div class="card-sanctuary mb-5 p-4 border-0 shadow-none bg-surface-low">
        <EditForm Model="@this" OnValidSubmit="HandleSearch" FormName="SearchAuthorForm">
            <div class="row g-4 align-items-end">
                <div class="col-md-5">
                    <label class="form-label small text-muted text-uppercase fw-bold mb-2">@L["AuthorName"]</label>
                    <InputText class="form-control bg-white border-0 shadow-sm py-2" @bind-Value="searchName" placeholder="@L["SearchByName"]" />
                </div>
                <div class="col-md-5">
                    <label class="form-label small text-muted text-uppercase fw-bold mb-2">@L["IsniIdentifier"]</label>
                    <InputText class="form-control bg-white border-0 shadow-sm py-2" @bind-Value="searchIsni" placeholder="@L["SearchByIsni"]" />
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100 py-2 rounded-pill">
                        <i class="bi bi-search me-2"></i> @L["Search"]
                    </button>
                </div>
            </div>
        </EditForm>
    </div>

    @* Add New Author Section *@
    @if (showAddSection)
    {
        <div class="mb-5 animate-slide-up">
            <div class="card-sanctuary p-5">
                <div class="border-bottom pb-4 mb-4">
                    <h2 class="display-6 text-serif mb-2">@L["NewAuthorDiscovery"]</h2>
                    <p class="text-muted">@L["RegisterNewScholarlyAuthorRecord"]</p>
                </div>

                <EditForm Model="@this" OnValidSubmit="HandleAddAuthor" FormName="AddAuthorForm">
                    <div class="row g-4">
                        <div class="col-md-5">
                            <label class="form-label small text-muted text-uppercase fw-bold mb-2">@L["FullName"]</label>
                            <InputText class="form-control bg-surface-low border-0 py-2 shadow-sm serif fw-bold" @bind-Value="newAuthorName" placeholder="e.g. Stephen King" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small text-muted text-uppercase fw-bold mb-2">@L["IsniIdentifier"] (@L["Optional"])</label>
                            <InputText class="form-control bg-surface-low border-0 py-2 shadow-sm font-monospace" @bind-Value="newAuthorIsni" placeholder="0000 0001..." />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small text-muted text-uppercase fw-bold mb-2">@L["ProfileImage"] (@L["Optional"])</label>
                            <div class="input-group shadow-sm rounded-3 overflow-hidden">
                                <InputText class="form-control bg-surface-low border-0 py-2" @bind-Value="newAuthorImageUrl" placeholder="https://..." />
                                <button type="button" class="btn btn-white border-start" @onclick="LookupAuthorImage" disabled="@(string.IsNullOrWhiteSpace(newAuthorName) || isSearchingImage)" title="@L["WikipediaImageLookup"]">
                                    @if (isSearchingImage) { <span class="spinner-border spinner-border-sm"></span> }
                                    else { <i class="bi bi-wikipedia me-2"></i> @L["Lookup"] }
                                </button>
                            </div>
                        </div>
                        
                        @if (!string.IsNullOrWhiteSpace(newAuthorImageUrl))
                        {
                            <div class="col-12 mt-3 animate-fade-in">
                                <div class="p-3 bg-surface-low rounded-3 border d-flex align-items-center gap-4">
                                    <div class="position-relative" style="width: 100px; height: 100px; overflow: hidden; border-radius: 50%; border: 4px solid white; box-shadow: var(--shadow-sm);">
                                        <img src="@newAuthorImageUrl" class="w-100 h-100" style="object-fit: cover;" alt="Preview" @onerror='() => newAuthorImageUrl = ""' />
                                    </div>
                                    <div>
                                        <h6 class="text-serif mb-1">@L["VisualIdentityPreview"]</h6>
                                        <p class="small text-muted mb-0 italic">@L["VerifyAuthorImageBeforeRegistration"]</p>
                                    </div>
                                </div>
                            </div>
                        }

                        <div class="col-12 mt-5">
                            <div class="d-flex gap-3">
                                <button type="submit" class="btn btn-sanctuary btn-lg flex-grow-1 py-3 shadow-sm shadow-hover">
                                    <i class="bi bi-person-check me-2"></i> @L["FinalizeAuthorRegistration"]
                                </button>
                                <button type="button" class="btn btn-outline-secondary btn-lg px-4" @onclick="() => showAddSection = false">
                                    @L["Discard"]
                                </button>
                            </div>
                        </div>
                    </div>
                </EditForm>
            </div>
        </div>
    }

    @* Authors Ledger *@
    @if (searchPerformed)
    {
        <div class="animate-fade-in">
            <div class="card-sanctuary p-0 overflow-hidden">
                <div class="px-5 py-4 bg-surface-container d-flex justify-content-between align-items-center border-bottom">
                    <div class="d-flex align-items-center gap-3">
                        <h2 class="h4 text-serif mb-0">@L["AuthorLedger"]</h2>
                        <span class="badge-sanctuary badge-neutral">@authors.Count @L["TotalRegistered"]</span>
                    </div>
                </div>

                <div class="table-responsive">
                    <QuickGrid Items="@FilteredAuthors" Pagination="@pagination" Class="editorial-ledger w-100 align-middle">
                        <TemplateColumn Title="@L["AuthorName"]" SortBy="@sortName" Class="col-title text-serif fw-bold h5">
                            <ColumnOptions>
                                <div class="p-3 bg-surface-low rounded-3 border shadow-sm" style="min-width: 300px;">
                                    <div class="input-group input-group-sm">
                                        <span class="input-group-text bg-transparent border-end-0 text-muted"><i class="bi bi-filter"></i></span>
                                        <input type="search" autofocus @bind="nameFilter" @bind:event="oninput" 
                                               placeholder="@L["FilterRecords"]" 
                                               class="form-control border-start-0 ps-0" />
                                    </div>
                                </div>
                            </ColumnOptions>
                            <ChildContent>
                                <a href="/author-details/@context.Id" class="text-decoration-none text-reset transition-hover py-2 d-block">
                                    @context.Name.Value
                                </a>
                            </ChildContent>
                        </TemplateColumn>

                        <TemplateColumn Title="@L["Identity"]" Align="Align.Center">
                            @if (context.ImageUri != null && FSharpOption<Uri>.get_IsSome(context.ImageUri))
                            {
                                <span class="text-success"><i class="bi bi-person-badge-fill"></i></span>
                            }
                            else
                            {
                                <span class="text-muted opacity-25"><i class="bi bi-person-badge"></i></span>
                            }
                        </TemplateColumn>

                        <TemplateColumn Title="@L["IsniIdentifier"]" Sortable="true" Class="font-monospace small">
                            @if (string.IsNullOrEmpty(context.Isni.Value))
                            {
                                <span class="text-muted opacity-25 italic">@L["NoneNotSet"]</span>
                            }
                            else
                            {
                                @context.Isni.Value
                            }
                        </TemplateColumn>

                        <TemplateColumn Title="@L["LinkedTitles"]" Align="Align.Center">
                            <span class="badge-sanctuary badge-neutral">@context.Books.Length</span>
                        </TemplateColumn>

                        <TemplateColumn Title="@L["Status"]" Align="Align.End" Class="pe-5">
                            @if (context.Sealed.Sealed)
                            {
                                <span class="text-muted small fw-bold"><i class="bi bi-lock-fill me-2" style="font-size: 0.5rem;"></i>@L["Sealed"]</span>
                            }
                            else
                            {
                                <span class="text-success small fw-bold"><i class="bi bi-unlock-fill me-2" style="font-size: 0.5rem;"></i>@L["Active"]</span>
                            }
                        </TemplateColumn>
                    </QuickGrid>
                </div>
                
                <div class="px-5 py-3 bg-surface-container border-top d-flex justify-content-center">
                    <Paginator State="@pagination" />
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool showAddSection = false;
    private List<Author> authors = new();
    private PaginationState pagination = new() { ItemsPerPage = 12 };
    private GridSort<Author> sortName = GridSort<Author>.ByAscending(a => a.Name.Value);
    
    private string nameFilter = "";
    private string isniFilter = "";
    
    private string newAuthorName = "";
    private string newAuthorIsni = "";
    private string newAuthorImageUrl = "";
    private bool isSearchingImage = false;

    private string statusMessage = "";

    private string searchName = "";
    private string searchIsni = "";
    private bool searchPerformed = false;

    private async Task HandleSearch()
    {
        searchPerformed = true;
        await LoadAuthors();
    }

    private async Task LoadAuthors()
    {
        FSharpResult<FSharpList<Author>, string> result;

        bool hasName = !string.IsNullOrWhiteSpace(searchName);
        bool hasIsni = !string.IsNullOrWhiteSpace(searchIsni);

        if (hasName && hasIsni)
        {
            var name = Name.New(searchName);
            var isni = Isni.NewInvalid(searchIsni);
            result = await AuthorService.SearchByIsniAndNameAsync(isni, name);
        }
        else if (hasName)
        {
            var name = Name.New(searchName);
            result = await AuthorService.SearchByNameAsync(name);
        }
        else if (hasIsni)
        {
            var isni = Isni.NewInvalid(searchIsni);
            result = await AuthorService.SearchByIsniAsync(isni); 
        }
        else
        {
            result = await AuthorService.GetAllAsync();
        }

        if (result.IsOk)
        {
            authors = result.ResultValue.ToList();
        }
        else
        {
            await ShowStatus(string.Format(L["ErrorLoadingAuthors"], result.ErrorValue), "error");
        }
    }

    private IQueryable<Author> FilteredAuthors => 
        authors.AsQueryable()
            .Where(a => a.Name.Value.Contains(nameFilter, StringComparison.OrdinalIgnoreCase))
            .Where(a => a.Isni.Value.Contains(isniFilter, StringComparison.OrdinalIgnoreCase));

    private async Task HandleAddAuthor()
    {
        if (string.IsNullOrWhiteSpace(newAuthorName))
        {
            await ShowStatus(L["AuthorNameRequired"], "warning");
            return;
        }

        FSharpOption<Isni> isniOpt = FSharpOption<Isni>.None;
        if (!string.IsNullOrWhiteSpace(newAuthorIsni))
        {
            var isniResult = Isni.New(newAuthorIsni);
            if (isniResult.IsError)
            {
                await ShowStatus(string.Format(L["InvalidIsniValue"], isniResult.ErrorValue), "error");
                return;
            }
            isniOpt = FSharpOption<Isni>.Some(isniResult.ResultValue);
        }

        FSharpOption<Uri> imageUrlOpt = FSharpOption<Uri>.None;
        if (!string.IsNullOrWhiteSpace(newAuthorImageUrl))
        {
            if (Uri.TryCreate(newAuthorImageUrl, UriKind.Absolute, out var uri))
            {
                imageUrlOpt = FSharpOption<Uri>.Some(uri);
            }
            else
            {
                await ShowStatus(L["InvalidImageUrl"], "warning");
                return;
            }
        }

        var name = Name.New(newAuthorName);
        var author = Author.NewWithOptionalIsniAndImageUrl(name, isniOpt, imageUrlOpt);

        var result = await AuthorService.AddAuthorAsync(author);

        if (result.IsOk)
        {
            await ShowStatus(string.Format(L["AuthorAddedSuccessfully"], newAuthorName), "success");
            newAuthorName = "";
            newAuthorIsni = "";
            newAuthorImageUrl = "";
            await LoadAuthors();
        }
        else
        {
            await ShowStatus(string.Format(L["ErrorCreatingAuthor"], result.ErrorValue), "error");
        }
    }

    private async Task LookupAuthorImage()
    {
        if (string.IsNullOrWhiteSpace(newAuthorName)) return;

        isSearchingImage = true;
        try
        {
            var result = await AuthorsSearchService.LookupImageUrlByNameAndThumbSizeAsync(newAuthorName, FSharpOption<int>.Some(200));
            if (result.IsOk)
            {
                newAuthorImageUrl = result.ResultValue;
                await ShowStatus(L["ImageFoundWikipedia"], "success");
            }
            else
            {
                await ShowStatus(string.Format(L["WikipediaLookupError"], result.ErrorValue), "warning");
            }
        }
        catch (Exception ex)
        {
            await ShowStatus(string.Format(L["ErrorSearchingImage"], ex.Message), "error");
        }
        finally
        {
            isSearchingImage = false;
        }
    }

    private async Task ShowStatus(string message, string type)
    {
        statusMessage = message;
        await JSRuntime.InvokeVoidAsync("showToast", message, type);
    }
}
