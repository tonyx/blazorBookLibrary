@page "/authors-manager"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.QuickGrid
@using BookLibrary.Shared.Services
@using blazorBookLibrary.Shared.Resources
@using BookLibrary.Domain
@using static BookLibrary.Shared.Commons
@using Microsoft.FSharp.Core
@using Microsoft.FSharp.Collections
@using System.Threading

@attribute [Authorize(Roles = "Admin, Manager")]
@inject IAuthorService AuthorService
@inject IAuthorsSearchService AuthorsSearchService
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<SharedResources> L
@rendermode InteractiveServer

<PageTitle>@L["AuthorsManager"]</PageTitle>

<div class="container-fluid py-4">
    <h1 class="mb-4 text-primary">@L["AuthorsManager"]</h1>

    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-secondary text-white">
                    <h5 class="card-title mb-0"><i class="bi bi-search me-2"></i>@L["SearchAuthors"]</h5>
                </div>
                <div class="card-body bg-light">
                    <EditForm Model="@this" OnValidSubmit="HandleSearch" FormName="SearchAuthorForm">
                        <div class="row g-3">
                            <div class="col-md-5">
                                <label class="form-label fw-bold">@L["Name"]</label>
                                <InputText class="form-control" @bind-Value="searchName" placeholder="@L["SearchByName"]" />
                            </div>
                            <div class="col-md-5">
                                <label class="form-label fw-bold">@L["IsniNumber"]</label>
                                <InputText class="form-control" @bind-Value="searchIsni" placeholder="@L["SearchByIsni"]" />
                            </div>
                            <div class="col-md-2 d-flex align-items-end">
                                <button type="submit" class="btn btn-primary w-100">
                                    <i class="bi bi-search me-1"></i> @L["Search"]
                                </button>
                            </div>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>


    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <h5 class="card-title mb-0"><i class="bi bi-person-plus-fill me-2"></i>@L["AddNewAuthor"]</h5>
                </div>
                <div class="card-body bg-light">
                    <EditForm Model="@this" OnValidSubmit="HandleAddAuthor" FormName="AddAuthorForm">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label fw-bold">@L["Name"]</label>
                                <InputText class="form-control" @bind-Value="newAuthorName" placeholder="e.g. Stephen King" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label fw-bold">@L["IsniOptional"]</label>
                                <InputText class="form-control" @bind-Value="newAuthorIsni" placeholder="e.g. 0000 0001 2140 1961" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label fw-bold">@L["ImageUrlOptional"]</label>
                                <div class="input-group">
                                    <InputText class="form-control" @bind-Value="newAuthorImageUrl" placeholder="https://..." />
                                    <button type="button" class="btn btn-outline-secondary" @onclick="LookupAuthorImage" disabled="@(string.IsNullOrWhiteSpace(newAuthorName) || isSearchingImage)" title="@L["LookupFromWikipedia"]">
                                        @if (isSearchingImage)
                                        {
                                            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                        }
                                        else
                                        {
                                            <i class="bi bi-image"></i>
                                        }
                                    </button>
                                </div>
                            </div>
                            <div class="col-md-2 d-flex align-items-end">
                                <button type="submit" class="btn btn-success w-100">
                                    <i class="bi bi-plus-circle me-1"></i> @L["AddAuthor"]
                                </button>
                            </div>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(newAuthorImageUrl))
                        {
                            <div class="mt-3">
                                <label class="form-label fw-bold d-block text-muted small uppercase mb-1">@L["ImagePreview"]</label>
                                <div class="preview-container d-inline-block p-1 bg-white border rounded shadow-sm">
                                    <img src="@newAuthorImageUrl" class="img-fluid rounded" style="max-height: 120px; min-width: 80px; object-fit: contain;" alt="Author Preview" @onerror='async () => { await ShowStatus(L["PreviewImageLoadError"], "alert-danger"); newAuthorImageUrl = ""; }' />
                                </div>
                            </div>
                        }
                    </EditForm>
                </div>
            </div>
        </div>
    </div>


    @if (searchPerformed)
    {
        <div class="card shadow-sm border-0">
            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0"><i class="bi bi-table me-2"></i>@L["RegisteredAuthors"]</h5>
                <span class="badge bg-light text-dark">@L["Total"]: @authors.Count</span>
            </div>
            <div class="card-body">
                <div class="row mb-4 g-2">
                    <div class="col-md-6">
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0"><i class="bi bi-search"></i></span>
                            <input type="search" autofocus @bind="nameFilter" @bind:event="oninput" class="form-control border-start-0" placeholder="@L["FilterByName"]" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0"><i class="bi bi-upc-scan"></i></span>
                            <input type="search" @bind="isniFilter" @bind:event="oninput" class="form-control border-start-0" placeholder="@L["FilterByIsni"]" />
                        </div>
                    </div>
                </div>

                <div class="table-responsive">
                    <QuickGrid Items="@FilteredAuthors" Pagination="@pagination" Class="table table-hover align-middle">
                        <TemplateColumn Title="@L["AuthorName"]" SortBy="@sortName" Class="fw-bold">
                            <a href="/author-details/@context.Id" class="text-decoration-none text-primary" title="View details for '@context.Name.Value'">
                                <i class="bi bi-person-circle me-2 opacity-75"></i>@context.Name.Value
                            </a>
                        </TemplateColumn>
                        <TemplateColumn Title="@L["Image"]" Align="Align.Center" SortBy="@sortImage">
                            @if (context.ImageUri != null && FSharpOption<Uri>.get_IsSome(context.ImageUri))
                            {
                                <span class="text-success" title="@context.ImageUri.Value.ToString()"><i class="bi bi-check-circle-fill"></i></span>
                            }
                            else
                            {
                                <span class="text-muted opacity-25"><i class="bi bi-x-circle"></i></span>
                            }
                        </TemplateColumn>
                        <PropertyColumn Property="@(a => a.Isni.Value)" Sortable="true" Title="@L["IsniNumber"]" />
                        <TemplateColumn Title="@L["WorksCount"]" Align="Align.Center">
                            <span class="badge rounded-pill bg-info text-dark">@context.Books.Length</span>
                        </TemplateColumn>

                        <TemplateColumn Title="@L["Status"]" Align="Align.Center">
                            @if (context.Sealed.Sealed)
                            {
                                <span class="badge bg-secondary"><i class="bi bi-lock-fill me-1"></i>@L["Sealed"]</span>
                            }
                            else
                            {
                                <span class="badge bg-success"><i class="bi bi-unlock-fill me-1"></i>@L["Active"]</span>
                            }
                        </TemplateColumn>
                    </QuickGrid>
                </div>
                
                <div class="mt-3 d-flex justify-content-center">
                    <Paginator State="@pagination" />
                </div>
            </div>
        </div>
    }

</div>

<style>
    .quickgrid {
        --grid-selected-color: #f8f9fa;
    }
    .quickgrid th {
        background-color: #fcfcfc;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 0.025em;
    }
</style>

@code {
    private List<Author> authors = new();
    private PaginationState pagination = new() { ItemsPerPage = 10 };
    private GridSort<Author> sortName = GridSort<Author>.ByAscending(a => a.Name.Value);
    private GridSort<Author> sortImage = GridSort<Author>.ByDescending(a => a.ImageUri != null && FSharpOption<Uri>.get_IsSome(a.ImageUri));
    
    private string nameFilter = "";
    private string isniFilter = "";
    
    private string newAuthorName = "";
    private string newAuthorIsni = "";
    private string newAuthorImageUrl = "";
    private bool isSearchingImage = false;

    private string statusMessage = "";

    private string searchName = "";
    private string searchIsni = "";
    private bool searchPerformed = false;

    protected override void OnInitialized()
    {
        // No auto-load
    }

    private async Task HandleSearch()
    {
        searchPerformed = true;
        await LoadAuthors();
    }

    private async Task LoadAuthors()
    {
        FSharpResult<FSharpList<Author>, string> result;

        bool hasName = !string.IsNullOrWhiteSpace(searchName);
        bool hasIsni = !string.IsNullOrWhiteSpace(searchIsni);

        if (hasName && hasIsni)
        {
            var name = Name.New(searchName);
            var isni = Isni.NewInvalid(searchIsni);
            result = await AuthorService.SearchByIsniAndNameAsync(isni, name);

        }

        else if (hasName)
        {
            var name = Name.New(searchName);
            result = await AuthorService.SearchByNameAsync(name);


        }
        else if (hasIsni)
        {
            var isni = Isni.NewInvalid(searchIsni);
            result = await AuthorService.SearchByIsniAsync(isni); 

        }

        else
        {
            result = await AuthorService.GetAllAsync();
        }

        if (result.IsOk)
        {
            authors = result.ResultValue.ToList();
        }
        else
        {
            await ShowStatus(string.Format(L["ErrorLoadingAuthors"], result.ErrorValue), "alert-danger");
        }
    }


    private IQueryable<Author> FilteredAuthors => 
        authors.AsQueryable()
            .Where(a => a.Name.Value.Contains(nameFilter, StringComparison.OrdinalIgnoreCase))
            .Where(a => a.Isni.Value.Contains(isniFilter, StringComparison.OrdinalIgnoreCase));

    private async Task HandleAddAuthor()
    {
        if (string.IsNullOrWhiteSpace(newAuthorName))
        {
            await ShowStatus(L["AuthorNameRequired"], "alert-warning");
            return;
        }

        FSharpOption<Isni> isniOpt = FSharpOption<Isni>.None;
        if (!string.IsNullOrWhiteSpace(newAuthorIsni))
        {
            var isniResult = Isni.New(newAuthorIsni);
            if (isniResult.IsError)
            {
                await ShowStatus(string.Format(L["InvalidIsniValue"], isniResult.ErrorValue), "alert-danger");
                return;
            }
            isniOpt = FSharpOption<Isni>.Some(isniResult.ResultValue);
        }

        FSharpOption<Uri> imageUrlOpt = FSharpOption<Uri>.None;
        if (!string.IsNullOrWhiteSpace(newAuthorImageUrl))
        {
            if (Uri.TryCreate(newAuthorImageUrl, UriKind.Absolute, out var uri))
            {
                imageUrlOpt = FSharpOption<Uri>.Some(uri);
            }
            else
            {
                await ShowStatus(L["InvalidImageUrl"], "alert-warning");
                return;
            }
        }

        var name = Name.New(newAuthorName);
        var author = Author.NewWithOptionalIsniAndImageUrl(name, isniOpt, imageUrlOpt);

        var result = await AuthorService.AddAuthorAsync(author);

        if (result.IsOk)
        {
            await ShowStatus(string.Format(L["AuthorAddedSuccessfully"], newAuthorName), "alert-success");
            newAuthorName = "";
            newAuthorIsni = "";
            newAuthorImageUrl = "";
            await LoadAuthors();
        }
        else
        {
            await ShowStatus(string.Format(L["ErrorCreatingAuthor"], result.ErrorValue), "alert-danger");
        }
    }

    private async Task LookupAuthorImage()
    {
        if (string.IsNullOrWhiteSpace(newAuthorName)) return;

        isSearchingImage = true;
        try
        {
            var result = await AuthorsSearchService.LookupImageUrlByNameAndThumbSizeAsync(newAuthorName, FSharpOption<int>.Some(200));
            if (result.IsOk)
            {
                newAuthorImageUrl = result.ResultValue;
                await ShowStatus(L["ImageFoundWikipedia"], "alert-success");
            }
            else
            {
                await ShowStatus(string.Format(L["WikipediaLookupError"], result.ErrorValue), "alert-warning");
            }
        }
        catch (Exception ex)
        {
            await ShowStatus(string.Format(L["ErrorSearchingImage"], ex.Message), "alert-danger");
        }
        finally
        {
            isSearchingImage = false;
        }
    }

    private async Task ShowStatus(string message, string cssClass)
    {
        statusMessage = message;

        string type = "info";
        if (cssClass.Contains("success")) type = "success";
        else if (cssClass.Contains("danger")) type = "error";
        else if (cssClass.Contains("warning")) type = "warning";

        await JSRuntime.InvokeVoidAsync("showToast", message, type);
    }
}
