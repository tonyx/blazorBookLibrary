@page "/authors-manager"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.QuickGrid
@using BookLibrary.Shared.Services
@using BookLibrary.Domain
@using static BookLibrary.Shared.Commons
@using Microsoft.FSharp.Core
@using Microsoft.FSharp.Collections
@using System.Threading

@attribute [Authorize(Roles = "Admin, Manager")]
@inject IAuthorService AuthorService
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<PageTitle>Authors Manager</PageTitle>

<div class="container-fluid py-4">
    <h1 class="mb-4 text-primary">Authors Manager</h1>

    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-secondary text-white">
                    <h5 class="card-title mb-0"><i class="bi bi-search me-2"></i>Search Authors</h5>
                </div>
                <div class="card-body bg-light">
                    <EditForm Model="@this" OnValidSubmit="HandleSearch" FormName="SearchAuthorForm">
                        <div class="row g-3">
                            <div class="col-md-5">
                                <label class="form-label fw-bold">Name</label>
                                <InputText class="form-control" @bind-Value="searchName" placeholder="Search by name..." />
                            </div>
                            <div class="col-md-5">
                                <label class="form-label fw-bold">ISNI</label>
                                <InputText class="form-control" @bind-Value="searchIsni" placeholder="Search by ISNI..." />
                            </div>
                            <div class="col-md-2 d-flex align-items-end">
                                <button type="submit" class="btn btn-primary w-100">
                                    <i class="bi bi-search me-1"></i> Search
                                </button>
                            </div>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>


    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div class="alert alert-info alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-info-circle-fill me-2"></i>@statusMessage
            <button type="button" class="btn-close" @onclick='() => statusMessage = ""'></button>
        </div>
    }

    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <h5 class="card-title mb-0"><i class="bi bi-person-plus-fill me-2"></i>Add New Author</h5>
                </div>
                <div class="card-body bg-light">
                    <EditForm Model="@this" OnValidSubmit="HandleAddAuthor" FormName="AddAuthorForm">
                        <div class="row g-3">
                            <div class="col-md-5">
                                <label class="form-label fw-bold">Name</label>
                                <InputText class="form-control" @bind-Value="newAuthorName" placeholder="e.g. Stephen King" />
                            </div>
                            <div class="col-md-5">
                                <label class="form-label fw-bold">ISNI (Optional)</label>
                                <InputText class="form-control" @bind-Value="newAuthorIsni" placeholder="e.g. 0000 0001 2140 1961" />
                            </div>
                            <div class="col-md-2 d-flex align-items-end">
                                <button type="submit" class="btn btn-success w-100">
                                    <i class="bi bi-plus-circle me-1"></i> Add Author
                                </button>
                            </div>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>


    @if (searchPerformed)
    {
        <div class="card shadow-sm border-0">
            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0"><i class="bi bi-table me-2"></i>Registered Authors</h5>
                <span class="badge bg-light text-dark">Total: @authors.Count</span>
            </div>
            <div class="card-body">
                <div class="row mb-4 g-2">
                    <div class="col-md-6">
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0"><i class="bi bi-search"></i></span>
                            <input type="search" autofocus @bind="nameFilter" @bind:event="oninput" class="form-control border-start-0" placeholder="Filter result by name..." />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0"><i class="bi bi-upc-scan"></i></span>
                            <input type="search" @bind="isniFilter" @bind:event="oninput" class="form-control border-start-0" placeholder="Filter result by ISNI..." />
                        </div>
                    </div>
                </div>

                <div class="table-responsive">
                    <QuickGrid Items="@FilteredAuthors" Pagination="@pagination" Class="table table-hover align-middle">
                        <PropertyColumn Property="@(a => a.Name.Value)" Sortable="true" Title="Author Name" Class="fw-bold" />
                        <PropertyColumn Property="@(a => a.Isni.Value)" Sortable="true" Title="ISNI Number" />
                        <TemplateColumn Title="Books Count" Align="Align.Center">
                            <span class="badge rounded-pill bg-info text-dark">@context.Books.Length</span>
                        </TemplateColumn>

                        <TemplateColumn Title="Status" Align="Align.Center">
                            @if (context.Sealed.Sealed)
                            {
                                <span class="badge bg-secondary"><i class="bi bi-lock-fill me-1"></i>Sealed</span>
                            }
                            else
                            {
                                <span class="badge bg-success"><i class="bi bi-unlock-fill me-1"></i>Active</span>
                            }
                        </TemplateColumn>

                        <TemplateColumn Title="Actions" Align="Align.Center">
                            <button class="btn btn-sm btn-outline-danger border-0" 
                                    title="Delete Author" 
                                    disabled="@(context.Books.Length > 0)" 
                                    @onclick="() => HandleDeleteAuthor(context)">
                                <i class="bi bi-trash3-fill fs-5"></i>
                            </button>
                        </TemplateColumn>
                    </QuickGrid>
                </div>
                
                <div class="mt-3 d-flex justify-content-center">
                    <Paginator State="@pagination" />
                </div>
            </div>
        </div>
    }

</div>

<style>
    .quickgrid {
        --grid-selected-color: #f8f9fa;
    }
    .quickgrid th {
        background-color: #fcfcfc;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 0.025em;
    }
</style>

@code {
    private List<Author> authors = new();
    private PaginationState pagination = new() { ItemsPerPage = 10 };
    
    private string nameFilter = "";
    private string isniFilter = "";
    
    private string newAuthorName = "";
    private string newAuthorIsni = "";

    private string statusMessage = "";

    private string searchName = "";
    private string searchIsni = "";
    private bool searchPerformed = false;

    protected override void OnInitialized()
    {
        // No auto-load
    }

    private async Task HandleSearch()
    {
        searchPerformed = true;
        await LoadAuthors();
    }

    private async Task LoadAuthors()
    {
        FSharpResult<FSharpList<Author>, string> result;

        bool hasName = !string.IsNullOrWhiteSpace(searchName);
        bool hasIsni = !string.IsNullOrWhiteSpace(searchIsni);

        if (hasName && hasIsni)
        {
            var name = Name.New(searchName);
            var isni = Isni.NewInvalid(searchIsni);
            result = await AuthorService.SearchByIsniAndNameAsync(isni, name, FSharpOption<CancellationToken>.None);

        }

        else if (hasName)
        {
            var name = Name.New(searchName);
            result = await AuthorService.SearchByNameAsync(name, FSharpOption<CancellationToken>.None);


        }
        else if (hasIsni)
        {
            var isni = Isni.NewInvalid(searchIsni);
            result = await AuthorService.SearchByIsniAsync(isni, FSharpOption<CancellationToken>.None);

        }

        else
        {
            result = await AuthorService.GetAllAsync(FSharpOption<CancellationToken>.None);
        }

        if (result.IsOk)
        {
            authors = result.ResultValue.ToList();
        }
        else
        {
            statusMessage = $"Error loading authors: {result.ErrorValue}";
        }
    }


    private IQueryable<Author> FilteredAuthors => 
        authors.AsQueryable()
            .Where(a => a.Name.Value.Contains(nameFilter, StringComparison.OrdinalIgnoreCase))
            .Where(a => a.Isni.Value.Contains(isniFilter, StringComparison.OrdinalIgnoreCase));

    private async Task HandleAddAuthor()
    {
        if (string.IsNullOrWhiteSpace(newAuthorName))
        {
            statusMessage = "Author name is required.";
            return;
        }

        Isni isni;
        if (string.IsNullOrWhiteSpace(newAuthorIsni))
        {
            isni = Isni.EmptyIsni;
        }
        else
        {
            var isniResult = Isni.New(newAuthorIsni);
            if (isniResult.IsError)
            {
                statusMessage = $"Invalid ISNI: {isniResult.ErrorValue}";
                return;
            }
            isni = isniResult.ResultValue;
        }

        var name = Name.New(newAuthorName);
        var author = Author.New(name, isni);

        var result = await AuthorService.AddAuthorAsync(author, FSharpOption<CancellationToken>.None);


        if (result.IsOk)
        {
            statusMessage = $"Author '{newAuthorName}' has been added.";
            newAuthorName = "";
            newAuthorIsni = "";
            await LoadAuthors();
        }
        else
        {
            statusMessage = $"Error adding author: {result.ErrorValue}";
        }
    }

    private async Task HandleDeleteAuthor(Author author)
    {
        bool confirmed = await JSRuntime.InvokeAsync<bool>("confirm", $"Are you sure you want to delete author '{author.Name.Value}'?");
        if (confirmed)
        {
            var result = await AuthorService.RemoveAsync(author.AuthorId, FSharpOption<CancellationToken>.None);
            if (result.IsOk)
            {
                statusMessage = $"Author '{author.Name.Value}' has been deleted.";
                await LoadAuthors();
            }
            else
            {
                statusMessage = $"Error deleting author: {result.ErrorValue}";
            }
        }
    }
}
