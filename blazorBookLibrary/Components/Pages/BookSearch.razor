@page "/"
@page "/book-search"
@page "/books-browser"
@using Microsoft.AspNetCore.Components.QuickGrid
@using BookLibrary.Shared.Services
@using Microsoft.Extensions.Configuration
@using BookLibrary.Shared
@using blazorBookLibrary.Security
@using BookLibrary.Domain
@using static BookLibrary.Shared.Commons
@using Microsoft.FSharp.Core
@using Microsoft.FSharp.Collections
@using static  BookLibrary.Shared.SearchCriteria
@using System.Threading
@using static BookLibrary.Shared.Details
@inject BotScoreService BotScoreService
@inject IBookService BookService
@inject ITextEmbeddingService TextEmbeddingService
@inject IAuthorService AuthorService
@inject IConfiguration Configuration
@inject ILogger<BookSearch> Logger
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<SharedResources> L
@rendermode InteractiveServer

<PageTitle>@L["BookSearch"] — @L["TheModernArchivist"]</PageTitle>

<div class="sanctuary-container py-5">

    @* Page Header *@
    <div class="mb-5 text-center">
        <h1 class="display-3 text-serif mb-3">@L["CuratedCatalog"]</h1>
        <p class="text-muted lead mx-auto" style="max-width: 800px;">@L["ArchivalDiscoveryDescription"]</p>
    </div>

    @* Search Toolbar *@
    <div class="card-sanctuary mb-5 p-4 border-0 shadow-none bg-surface-low rounded-pill-sm">
        <BookSearchToolbar @ref="searchToolbar" OnSearchResultsFound="HandleSearchResultsFound" OnError="ShowSearchError" OnSearchStarted="HandleSearchStarted" />
    </div>

    @if (searchBooksPerformed)
    {
        <div class="animate-fade-in">
            <div class="card-sanctuary p-0 overflow-hidden">
                <div class="px-5 py-4 bg-surface-container d-flex justify-content-between align-items-center border-bottom">
                    <div class="d-flex align-items-center gap-4">
                        <h2 class="h4 text-serif mb-0">@L["CatalogDiscovery"]</h2>
                        <div class="form-check form-switch p-0 m-0 d-flex align-items-center gap-2">
                             <input class="form-check-input ms-0" type="checkbox" id="imagePreviewSwitch" @bind="showImagePreview" style="cursor: pointer;">
                             <label class="form-check-label small fw-bold text-muted" for="imagePreviewSwitch">@L["VisualIdentity"]</label>
                        </div>
                    </div>
                    <span class="badge-sanctuary badge-neutral">@foundBooks.Count @L["TitlesFound"]</span>
                </div>

                <div class="table-responsive">
                    <QuickGrid Items="@FilteredBooks" Pagination="@bookPagination" Class="editorial-ledger w-100 align-middle">
                        @if (showImagePreview)
                        {
                            <TemplateColumn Title="@L["VisualRef"]" Class="col-preview ps-5">
                                <a href="/book-view/@context.Book.Id" class="d-inline-block text-decoration-none transition-hover shadow-sm rounded overflow-hidden" 
                                   title="@L["BookDetails"]: @context.Book.Title.Value">
                                    <div class="bg-surface-low rounded p-1" style="width: 48px; height: 68px; display: flex; align-items: center; justify-content: center;">
                                        @if (context.Book.ImageUrl != null && FSharpOption<Uri>.get_IsSome(context.Book.ImageUrl))
                                        {
                                            <img src="@context.Book.ImageUrl.Value.ToString()" style="max-width: 100%; max-height: 100%; object-fit: contain;" alt="@context.Book.Title.Value" />
                                        }
                                        else
                                        {
                                            <i class="bi bi-journal-text opacity-25" style="font-size: 1.2rem;"></i>
                                        }
                                    </div>
                                </a>
                            </TemplateColumn>
                        }

                        <TemplateColumn Title="@L["Title"]" SortBy="@sortTitle" Class="col-title text-serif fw-bold h5">
                            <ColumnOptions>
                                <div class="p-3 bg-surface-low rounded-3 border shadow-sm" style="min-width: 300px;">
                                    <div class="input-group input-group-sm">
                                        <span class="input-group-text bg-transparent border-end-0 text-muted"><i class="bi bi-filter"></i></span>
                                        <input type="search" autofocus @bind="titleRefinementFilter" @bind:event="oninput" 
                                               placeholder="@L["RefineResultsByTitlePlaceholder"]" 
                                               class="form-control border-start-0 ps-0" />
                                    </div>
                                </div>
                            </ColumnOptions>
                             <ChildContent>
                                <a href="/book-view/@context.Book.Id" class="text-decoration-none text-reset transition-hover py-2 d-block">
                                    <div class="fw-bold mb-1">@context.Book.Title.Value</div>
                                    @if (FSharpOption<string>.get_IsSome(context.Explanation))
                                    {
                                        <div class="small text-primary italic mt-1 fw-normal animate-fade-in" style="font-size: 0.75rem;">
                                            <i class="bi bi-stars me-1"></i> @context.Explanation.Value
                                        </div>
                                    }
                                    else if (loadingExplanations.Contains(context.Book.BookId))
                                    {
                                        <div class="spinner-border spinner-border-sm text-primary mt-1" role="status" style="width: 10px; height: 10px;">
                                            <span class="visually-hidden">@L["Loading"]...</span>
                                        </div>
                                    }
                                </a>
                             </ChildContent>
                        </TemplateColumn>

                        @if (foundBooks.Any(b => FSharpOption<double>.get_IsSome(b.Score)))
                        {
                            <TemplateColumn Title="@L["Match"]" SortBy="@sortScore" Class="col-score text-center">
                                @{
                                    var isTop = topBookId != null && context.Book.BookId.Equals(topBookId);
                                    var color = isTop ? topMatchColor : "bg-secondary opacity-50";
                                }
                                <div class="d-flex justify-content-center align-items-center h-100">
                                    <span class="d-inline-block rounded-circle @color shadow-sm" 
                                          style="width: 12px; height: 12px;" 
                                          title="@(isTop && color == "bg-success" ? L["ExcellentMatch"] : isTop && color == "bg-warning" ? L["GoodMatch"] : L["PotentialMatch"])">
                                    </span>
                                </div>
                            </TemplateColumn>
                        }

                        <PropertyColumn Property="@(b => b.Book.Year.Value)" Title="@L["Year"]" Sortable="true" Class="col-year text-muted small px-3" />
                        
                        <TemplateColumn Title="@L["Taxonomy"]" sortBy="@sortTaxonomy" Class="col-category small">
                            <span class="badge-sanctuary badge-neutral">@context.Book.MainCategory.Value()</span>
                        </TemplateColumn>

                        <TemplateColumn Title="@L["ArchivalStatus"]" SortBy=@sortAvailability Align="Align.End" Class="col-available pe-5">
                            @if (context.Book.AvailabilityStatus == BookLibrary.Shared.Commons.AvailabilityStatus.Available)
                            {
                                <span class="text-success small fw-bold"><i class="bi bi-check-circle-fill me-2" style="font-size: 0.5rem;"></i>@L["Available"]</span>
                            }
                            else if (context.Book.AvailabilityStatus == BookLibrary.Shared.Commons.AvailabilityStatus.Reserved)
                            {
                                <span class="text-warning small fw-bold"><i class="bi bi-circle-fill me-2" style="font-size: 0.5rem;"></i>@L["Reserved"]</span>
                            }
                            else if (context.Book.AvailabilityStatus == BookLibrary.Shared.Commons.AvailabilityStatus.NotAvailable)
                            {
                                <span class="text-danger small fw-bold"><i class="bi bi-circle-fill me-2" style="font-size: 0.5rem;"></i>@L["NotAvailable"]</span>
                            }
                            else if (context.Book.AvailabilityStatus == BookLibrary.Shared.Commons.AvailabilityStatus.Consultable)
                            {
                                <span class="text-info small fw-bold"><i class="bi bi-circle-fill me-2" style="font-size: 0.5rem;"></i>@L["Consultable"]</span>
                            }
                            else 
                            {
                                <span class="text-muted small fw-bold"><i class="bi bi-circle-fill me-2" style="font-size: 0.5rem;"></i>@L["Unspecified"]</span>
                            }
                        </TemplateColumn>

                    </QuickGrid>
                </div>
                
                <div class="px-5 py-3 bg-surface-container border-top d-flex justify-content-between align-items-center">
                    <div class="small text-muted serif italic">@L["Showing"] @FilteredBooks.Count() @L["Records"]</div>
                    <Paginator State="@bookPagination" />
                </div>
            </div>
            
            <div class="mt-5 p-4 bg-surface-low rounded-4 border border-dashed text-center">
                <p class="small text-muted mb-0 italic">
                    <i class="bi bi-info-circle me-2"></i>
                    @L["ArchivalReferenceNote"]
                </p>
            </div>
        </div>
    }
</div>

@code {
    private bool _isLoading = false;
    private List<BookSearchResult> foundBooks = new();
    private string titleRefinementFilter = "";
    private IQueryable<BookSearchResult> FilteredBooks => 
        foundBooks.AsQueryable()
            .Where(b => string.IsNullOrEmpty(titleRefinementFilter) || 
                        b.Book.Title.Value.Contains(titleRefinementFilter, StringComparison.OrdinalIgnoreCase));

    private bool showImagePreview = true;
    private bool searchBooksPerformed = false;
    private PaginationState bookPagination = new() { ItemsPerPage = 12 };
    private GridSort<BookSearchResult> sortTitle = GridSort<BookSearchResult>.ByAscending(b => b.Book.Title.Value);
    private GridSort<BookSearchResult> sortAvailability = GridSort<BookSearchResult>.ByAscending(b => b.Book.ImmediatelyAvailable);    
    private GridSort<BookSearchResult> sortTaxonomy = GridSort<BookSearchResult>.ByAscending(b => b.Book.MainCategory.Value());
    private GridSort<BookSearchResult> sortScore = GridSort<BookSearchResult>.ByDescending(b => FSharpOption<double>.get_IsSome(b.Score) ? b.Score.Value : 0f);
    private bool enableAIExplanations = false;

    private string statusMessage = "";
    private string topMatchColor = "bg-secondary";
    private BookId? topBookId;
    private BookSearchToolbar searchToolbar;
    private HashSet<BookId> loadingExplanations = new();
    private static readonly SemaphoreSlim explanationSemaphore = new(1, 1);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        var siteKey = Configuration["Authentication:Recaptcha:SiteKey"];
        if (firstRender)
        {
            enableAIExplanations = Configuration.GetValue<bool>("BooksLibrary:EnableAIExtendedExplanations");
            try 
            {
                var token = await JSRuntime.InvokeAsync<string>("generateRecaptchaToken", siteKey, "book_browser");
                var score = await BotScoreService.GetBotScoreAsync(token);
                await BotScoreService.ApplyBotDelayAsync(score);

                if (score < 0.3) 
                {
                    Logger.LogWarning($"Suspicious bot activity {score}");
                    await ShowStatus(L["overActivity"], "error");
                }
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Error during reCAPTCHA verification");
            }
        }
    }

    private async Task HandleSearchStarted(bool started)
    {
        searchBooksPerformed = true;
        statusMessage = "";
    }

    private void HandleSearchResultsFound(List<BookSearchResult> results)
    {
        foundBooks = results;
        topBookId = null;
        topMatchColor = "bg-secondary";

        if (results.Count > 0 && FSharpOption<double>.get_IsSome(results[0].Score))
        {
            var first = results[0];
            var firstScore = first.Score.Value;
            var secondScore = (results.Count > 1 && FSharpOption<double>.get_IsSome(results[1].Score)) ? results[1].Score.Value : 0.0;
            
            topBookId = first.Book.BookId;
            
            if (firstScore > 0.65 && (firstScore - secondScore) > 0.07)
            {
                topMatchColor = "bg-success";
            }
            else if (firstScore > 0.60 && (firstScore - secondScore) > 0.04)
            {
                topMatchColor = "bg-warning";
            }
        }
    }

    private async Task ShowSearchError(string error)
    {
        await ShowStatus(error, "error");
    }

    private async Task ShowStatus(string message, string type)
    {
        statusMessage = message;
        await JSRuntime.InvokeVoidAsync("showToast", message, type);
    }

    private async Task FetchExplanation(BookSearchResult res)
    {
        if (FSharpOption<string>.get_IsSome(res.Explanation) || loadingExplanations.Contains(res.Book.BookId)) return;
        
        var query = searchToolbar.CurrentSemanticQuery;
        if (string.IsNullOrWhiteSpace(query)) return;

        await explanationSemaphore.WaitAsync();
        try 
        {
            if (FSharpOption<string>.get_IsSome(res.Explanation)) return;

            loadingExplanations.Add(res.Book.BookId);
            StateHasChanged();
            
            var desc = FSharpOption<string>.get_IsSome(res.Book.Description) ? res.Book.Description.Value : "";
            var bookText = $"{res.Book.Title.Value}. {desc}";
            var explanationResult = await TextEmbeddingService.GetMatchExplanationAsync(query, bookText);
            if (explanationResult.IsOk)
            {
                var newRes = new BookSearchResult(res.Book, res.Score, FSharpOption<string>.Some(explanationResult.ResultValue));
                var index = foundBooks.IndexOf(res);
                if (index != -1)
                {
                    foundBooks[index] = newRes;
                }
            }
            else 
            {
                await ShowStatus($"{L["ExplanationFailed"]}: {explanationResult.ErrorValue}", "warning");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error fetching match explanation");
        }
        finally 
        {
            loadingExplanations.Remove(res.Book.BookId);
            explanationSemaphore.Release();
            StateHasChanged();
        }
    }
}
