@page "/book-edit/{BookIdStr}"
@using Microsoft.AspNetCore.Authorization
@using BookLibrary.Shared.Services
@using BookLibrary.Domain
@using BookLibrary.Shared
@using BookLibrary.Shared.Services
@using BookLibrary.Domain
@using blazorBookLibrary.Shared.Resources
@using static BookLibrary.Shared.Commons
@using Microsoft.FSharp.Core
@using System.Linq
@using System.Globalization

@attribute [Authorize(Roles = "Admin, Manager")]
@inject IBookService BookService
@inject IDetailsService DetailsService
@inject IAuthorService AuthorService
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager
@inject IGoogleBooksService GoogleBooksService
@inject ITextEmbeddingService TextEmbeddingService
@inject IVectorDbService VectorDbService
@inject IStringLocalizer<SharedResources> L
@inject ILoanService LoanService
@inject IConfiguration Configuration
@rendermode InteractiveServer

<PageTitle>@L["BookDetails"]</PageTitle>

<style>
    .editable-title {
        cursor: pointer;
        padding: 4px 8px;
        border-radius: 4px;
        transition: all 0.2s ease;
        display: inline-block;
        border: 1px solid transparent;
    }
    .editable-title:hover {
        background-color: #f8f9fa;
        border-color: #dee2e6;
        color: #0d6efd;
    }
    .editable-category:hover {
        opacity: 0.8;
        transform: scale(1.05);
    }
    .image-edit-badge {
        bottom: 15px;
        right: 15px;
        background: var(--primary);
        color: white;
        width: 42px;
        height: 42px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        z-index: 10;
        border: 4px solid var(--surface-container-lowest);
    }
    .image-edit-badge:hover {
        transform: scale(1.1);
        background: var(--secondary);
        box-shadow: 0 6px 20px rgba(0,0,0,0.3);
    }
    .image-edit-badge i {
        font-size: 1.2rem;
    }
    .book-cover-wrap:hover .image-edit-badge {
        animation: pulse-sanctuary 2s infinite;
    }
    @@keyframes pulse-sanctuary {
        0% { transform: scale(1); }
        50% { transform: scale(1.05); }
        100% { transform: scale(1); }
    }
</style>

<div class="sanctuary-container">
    <!-- Header Area -->
    <div class="d-flex justify-content-between align-items-end mb-5 border-bottom pb-4" style="border-color: var(--outline-variant) !important;">
        <div>
            <nav aria-label="breadcrumb" class="mb-2">
                <ol class="breadcrumb mb-0" style="font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--secondary);">
                    <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-reset">@L["Home"]</a></li>
                    <li class="breadcrumb-item"><a href="/books-manager" class="text-decoration-none text-reset">@L["Catalog"]</a></li>
                    <li class="breadcrumb-item active" aria-current="page">@L["BookDetails"]</li>
                </ol>
            </nav>
            <h1 class="serif display-5 mb-0" style="font-weight: 800; color: var(--primary);">@L["BookDetails"]</h1>
        </div>
        <div class="d-flex gap-3">
            <a href="/books-manager" class="btn-sanctuary-outline text-decoration-none">
                <i class="bi bi-arrow-left me-2"></i>@L["BackToBooks"]
            </a>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="d-flex justify-content-center align-items-center" style="min-height: 400px;">
            <div class="spinner-grow text-primary" role="status">
                <span class="visually-hidden">@L["WaitLoading"]</span>
            </div>
        </div>
    }
    else if (bookDetails != null)
    {
        <div class="row g-5">
            <!-- Left Column: Visual & Archival Controls -->
            <div class="col-lg-4">
                <div class="card-sanctuary floating text-center mb-4">
                    <div class="book-cover-wrap mb-4 bg-surface-low shadow-sm" style="height: 450px; border-radius: 4px; overflow: hidden; display: flex; align-items: center; justify-content: center; position: relative;">
                        @if (FSharpOption<Uri>.get_IsSome(bookDetails.Book.ImageUrl))
                        {
                            <img src="@bookDetails.Book.ImageUrl.Value.ToString()" 
                                 alt="@bookDetails.Book.Title.Value Cover" 
                                 class="w-100 h-100" 
                                 style="object-fit: cover;" />
                        }
                        else
                        {
                            <div class="text-center text-muted opacity-25 p-4 d-flex flex-column align-items-center">
                                <i class="bi bi-journal-text" style="font-size: 5rem;"></i>
                                <span class="d-block mt-3 serif">@L["NoCoverAvailable"]</span>
                                @if (bookDetails.Book.Editable)
                                {
                                    <button class="btn btn-link btn-sm text-decoration-none mt-2 text-serif" @onclick:stopPropagation @onclick="StartEditingImageUrl">
                                        + @L["AddCoverImage"]
                                    </button>
                                }
                            </div>
                        }

                        @if (bookDetails.Book.Editable)
                        {
                            <div class="image-edit-badge position-absolute" @onclick="StartEditingImageUrl" @onclick:stopPropagation title="@L["ChangeImage"]">
                                <i class="bi bi-camera-fill"></i>
                            </div>
                        }
                    </div>

                    @if (bookDetails.Book.Editable && isEditingImageUrl)
                    {
                        <div class="mt-4 p-4 bg-surface-low rounded-xl text-start animate-fade-in shadow-sm border border-dashed border-primary-subtle">
                            <label class="form-label small text-muted text-uppercase fw-bold mb-3 d-flex justify-content-between align-items-center">
                                <span>@L["ModifyArchivalCover"]</span>
                                @if (isLookingUpCover) { <span class="spinner-border spinner-border-sm text-primary"></span> }
                            </label>
                            
                            <div class="input-group shadow-sm rounded-3 overflow-hidden mb-4 border">
                                <input type="text" class="form-control border-0 py-2 serif" 
                                       placeholder="@L["PasteImageUrl"]" 
                                       @bind="editedImageUrl" />
                                <button class="btn btn-white border-start d-flex align-items-center gap-2" type="button" @onclick="LookupCover" disabled="@isLookingUpCover">
                                    <select class="form-select form-select-sm border-0 bg-transparent py-0" @bind="coverSizeLookup" style="width: auto;" @onclick:stopPropagation>
                                        <option value="Small">S</option>
                                        <option value="Medium" selected>M</option>
                                        <option value="Large">L</option>
                                    </select>
                                    <i class="bi bi-magic text-primary"></i>@L["DiscoverCover"]
                                </button>
                            </div>

                            @if (coverPreviewUrl != null)
                            {
                                <div class="mb-4 text-center animate-fade-in bg-white p-3 rounded-lg border shadow-sm">
                                    <p class="small text-muted mb-2 italic">@L["DiscoveredCoverPreview"]</p>
                                    <div class="preview-rect bg-surface-container mx-auto overflow-hidden shadow-sm border border-4 border-white" style="width: 100px; height: 140px;">
                                        <img src="@coverPreviewUrl" class="w-100 h-100" style="object-fit: contain;" />
                                    </div>
                                    <div class="d-flex gap-2 justify-content-center mt-3">
                                        <button type="button" class="btn btn-primary btn-sm px-3" @onclick="AcceptLookup">@L["UseThisCover"]</button>
                                        <button type="button" class="btn btn-outline-secondary btn-sm px-3" @onclick="DiscardLookup">@L["Discard"]</button>
                                    </div>
                                </div>
                            }

                            <div class="d-flex gap-2 mt-2">
                                <button class="btn btn-primary flex-grow-1" @onclick="UpdateImageUrl" disabled="@(string.IsNullOrWhiteSpace(editedImageUrl))">
                                    <i class="bi bi-check2-circle me-2"></i>@L["FinalizeCoverUpdate"]
                                </button>
                                <button class="btn btn-outline-secondary" @onclick="() => isEditingImageUrl = false">@L["Cancel"]</button>
                                @if (FSharpOption<Uri>.get_IsSome(bookDetails.Book.ImageUrl))
                                {
                                    <button class="btn btn-outline-danger" @onclick="RemoveImageUrl" title="@L["DiscardCover"]">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                }
                            </div>
                        </div>
                    }

                    <div class="mt-5 text-start p-4 bg-surface-low rounded-xl">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="serif mb-0">@L["ArchivalStatus"]</h6>
                            <div class="badge-sanctuary @(isBookSealed ? "badge-borrowed" : "badge-available") d-flex align-items-center">
                                <i class="bi @(isBookSealed ? "bi-lock-fill" : "bi-unlock-fill") me-2"></i>
                                <div class="form-check form-switch p-0 m-0 d-flex align-items-center">
                                    <input class="form-check-input ms-0 me-2" type="checkbox" id="sealSwitch" 
                                           checked="@(!isBookSealed)" 
                                           @onchange="ToggleSeal"
                                           style="cursor: pointer; width: 2em; height: 1em;" />
                                    <label class="form-check-label small fw-bold" for="sealSwitch">
                                        @(isBookSealed ? L["LockedSealed"] : L["EditableUnsealed"])
                                    </label>
                                </div>
                            </div>
                        </div>
                        <p class="small text-muted mb-0 serif italic">@L["SealDescription"]</p>
                    </div>
                </div>
            </div>

            <!-- Right Column: Administrative Details -->
            <div class="col-lg-8">
                <div class="card-sanctuary mb-5">
                    <h5 class="serif mb-4 pb-2 border-bottom" style="border-color: var(--outline-variant) !important;">@L["PrimaryArchivalMetadata"]</h5>
                    
                    <div class="row g-4">
                        <!-- Title -->
                        <div class="col-12 border-bottom pb-4" style="border-color: var(--surface-container-low) !important;">
                            <label class="form-label small text-muted text-uppercase fw-bold mb-2">@L["Title"]</label>
                             @if (isEditingTitle)
                            {
                                <div class="input-group shadow-sm rounded overflow-hidden">
                                    <input type="text" class="form-control border-0 py-3 serif h4 mb-0 fw-bold bg-surface-low" @bind="editedTitle" @onkeyup="HandleKeyUp" autofocus />
                                    <button class="btn btn-primary px-4" @onclick="UpdateTitle">@L["Confirm"]</button>
                                    <button class="btn btn-white border-start" @onclick="CancelEdit"><i class="bi bi-x-lg"></i></button>
                                </div>
                            }
                            else
                            {
                                <div class="d-flex align-items-center gap-3">
                                    <h2 class="serif mb-0" style="color: var(--primary); font-weight: 800;">@bookDetails.Book.Title.Value</h2>
                                    @if (bookDetails.Book.Editable)
                                    {
                                        <button class="btn btn-link p-0 text-muted" @onclick="StartEdit"><i class="bi bi-pencil-square"></i></button>
                                    }
                                </div>
                            }
                        </div>

                        <!-- ISBN & Availability Grid -->
                        <div class="col-md-6 border-end" style="border-color: var(--surface-container-low) !important;">
                            <label class="form-label small text-muted text-uppercase fw-bold mb-2">Identifier (ISBN-13)</label>
                            @if (isEditingIsbn)
                            {
                                <div class="p-3 bg-surface-low rounded border">
                                    <div class="input-group mb-2">
                                        <input type="text" class="form-control small py-2" @bind="editedIsbn" placeholder="ISBN..." />
                                        <button class="btn btn-primary btn-sm" @onclick="UpdateIsbn"><i class="bi bi-check-lg"></i></button>
                                        <button class="btn btn-white border-start" @onclick="CancelEditIsbn"><i class="bi bi-x-lg"></i></button>
                                    </div>
                                    <div class="form-check form-switch small">
                                        <input class="form-check-input" type="checkbox" id="invalidIsbnSwitch" @bind="acceptInvalidIsbn" />
                                        <label class="form-check-label x-small text-muted" for="invalidIsbnSwitch">@L["AcceptInvalidIsbn"]</label>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="d-flex align-items-center gap-3">
                                    <span class="badge-sanctuary badge-neutral font-monospace p-2">@bookDetails.Book.Isbn.Value</span>
                                    @if (bookDetails.Book.Editable)
                                    {
                                        <button class="btn btn-link p-0 text-muted" @onclick="StartEditIsbn"><i class="bi bi-pencil-square"></i></button>
                                    }
                                </div>
                            }
                        </div>

                        <div class="col-md-6">
                            <label class="form-label small text-muted text-uppercase fw-bold mb-2">@L["ArchivalAvailability"]</label>
                             @if (isEditingAvailability)
                            {
                                <div class="input-group input-group-sm">
                                    <select class="form-select border-primary" @bind="editedAvailability">
                                        @foreach (var avail in Availability.AllCases())
                                        {
                                            <option value="@avail.ToString()" selected="@(avail.ToString() == bookDetails.Book.Availability.ToString())">
                                                @GetAvailabilityLocalName(avail)
                                            </option>
                                        }
                                    </select>
                                    <button class="btn btn-primary" @onclick="UpdateAvailability"><i class="bi bi-check-lg"></i></button>
                                    <button class="btn btn-white border-start" @onclick="() => isEditingAvailability = false"><i class="bi bi-x-lg"></i></button>
                                </div>
                            }
                            else
                            {
                                <div class="d-flex align-items-center gap-3">
                                    <span class="badge-sanctuary @(bookDetails.Book.Availability.IsCirculating ? "badge-available" : "badge-neutral") p-2">
                                        <i class="bi @(bookDetails.Book.Availability.IsCirculating ? "bi-journal-check" : "bi-journal-lock") me-2"></i>
                                        @GetAvailabilityLocalName(bookDetails.Book.Availability)
                                    </span>
                                    @if (bookDetails.Book.Editable)
                                    {
                                        <button class="btn btn-link p-0 text-muted" @onclick="StartEditAvailability"><i class="bi bi-pencil-square"></i></button>
                                    }
                                </div>
                            }
                        </div>

                        <!-- Authors & Taxonomy -->
                        <div class="col-md-6 border-end" style="border-color: var(--surface-container-low) !important;">
                            <label class="form-label small text-muted text-uppercase fw-bold mb-3">@L["CatalogedAuthors"]</label>
                            <div class="d-flex flex-wrap gap-2 mb-3">
                                @foreach (var author in bookDetails.Authors)
                                {
                                    <span class="badge-sanctuary badge-neutral p-2 d-flex align-items-center">
                                        <i class="bi bi-journal-richtext me-2 opacity-50"></i>
                                        <a href="/author-details/@author.AuthorId.Value" class="text-reset text-decoration-none fw-bold">@author.Name.Value</a>
                                        @if (bookDetails.Book.Editable)
                                        {
                                            <span class="ms-2 ps-2 border-start" style="cursor: pointer;" @onclick="() => RemoveAuthorFromBook(author)"><i class="bi bi-x text-danger"></i></span>
                                        }
                                    </span>
                                }
                            </div>
                            
                            @if (bookDetails.Book.Editable)
                            {
                                <div class="position-relative">
                                    <div class="input-group input-group-sm rounded bg-surface-low border p-1 shadow-sm">
                                        <span class="input-group-text bg-transparent border-0"><i class="bi bi-person-plus"></i></span>
                                        <input type="text" 
                                               class="form-control border-0 bg-transparent py-2" 
                                               placeholder="@L["AddAuthorToRecord"]" 
                                               value="@authorSearchInput" 
                                               @oninput="HandleAuthorSearchInput"
                                               @onfocus="() => { if(authorSearchResults.Any()) showAuthorSearchResults = true; }" />
                                    </div>
                                    
                                    @if (showAuthorSearchResults)
                                    {
                                        <div class="list-group position-absolute w-100 shadow mt-1 border" style="z-index: 1100; max-height: 200px; overflow-y: auto; border-radius: 8px;">
                                            @foreach (var author in authorSearchResults)
                                            {
                                                <button type="button" class="list-group-item list-group-item-action text-start p-3 small border-0" @onclick="() => SelectAuthorForAdd(author)">
                                                    <div class="fw-bold">@author.Name.Value</div>
                                                </button>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>

                        <div class="col-md-6">
                            <label class="form-label small text-muted text-uppercase fw-bold mb-3">@L["EditorialTaxonomy"]</label>
                            <div class="d-flex flex-wrap gap-2 mb-3">
                                <!-- Main -->
                                <span class="badge-sanctuary badge-neutral p-2 d-flex align-items-center @((bookDetails?.Book.Editable ?? false) ? "clickable" : "")" @onclick="StartEditCategory">
                                    <i class="bi bi-bookmark-fill me-2 opacity-50"></i>
                                    @bookDetails!.Book.MainCategory.Value()
                                    @if (bookDetails.Book.Editable) { <i class="bi bi-pencil-fill ms-2 ps-2 border-start x-small"></i> }
                                </span>
                                <!-- Additions -->
                                @foreach (var cat in bookDetails.Book.AdditionalCategories)
                                {
                                    <span class="badge-sanctuary badge-neutral p-2 d-flex align-items-center">
                                        @cat.Value()
                                        @if (bookDetails.Book.Editable)
                                        {
                                            <span class="ms-2 ps-2 border-start" style="cursor: pointer;" @onclick="() => RemoveAdditionalCategory(cat)"><i class="bi bi-dash text-danger"></i></span>
                                        }
                                    </span>
                                }
                            </div>
                            
                            @if (bookDetails.Book.Editable)
                            {
                                <button class="btn btn-sm btn-white border rounded-pill px-3" @onclick="() => showAddDropdown = !showAddDropdown">
                                    <i class="bi bi-plus-lg me-1"></i> @L["AddArchivalTag"]
                                </button>
                                @if (showAddDropdown)
                                {
                                    <div class="position-absolute shadow-lg border rounded-lg bg-white p-3 mt-1" style="z-index: 1000; min-width: 250px; left: 15px;">
                                        <div class="small fw-bold mb-3 border-bottom pb-2">@L["SelectCategory"]</div>
                                        <div class="row g-1">
                                            @foreach (var cat in Category.AllCases())
                                            {
                                                if (cat != bookDetails.Book.MainCategory && !bookDetails.Book.AdditionalCategories.Contains(cat))
                                                {
                                                    <div class="col-6">
                                                        <div class="dropdown-item py-1 px-2 small rounded text-truncate border mb-1" style="cursor: pointer;" @onclick="() => AddAdditionalCategoryWrapper(cat)">
                                                            @cat.Value()
                                                        </div>
                                                    </div>
                                                }
                                            }
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>

                <!-- Narrative Ledger (Description) -->
                <div class="card-sanctuary p-5">
                    <div class="d-flex justify-content-between align-items-baseline mb-4 border-bottom pb-3" style="border-color: var(--outline-variant) !important;">
                        <h5 class="serif mb-0">@L["NarrativeAbstract"]</h5>
                        @if (bookDetails.Book.Editable && !isEditingDescription)
                        {
                            <button class="btn btn-sm btn-white border" @onclick="StartEditDescription"><i class="bi bi-pencil-square me-1"></i> @L["EditNarrative"]</button>
                        }
                    </div>

                    @if (isEditingDescription)
                    {
                        <div class="p-4 bg-surface-low rounded-xl">
                            <textarea class="form-control border-0 serif bg-transparent mb-3" @bind="editedDescription" rows="10" placeholder="@L["WriteDescription"]"></textarea>
                            <div class="d-flex gap-3">
                                <button class="btn btn-primary px-4" @onclick="UpdateDescription">@L["Save"]</button>
                                <button class="btn btn-white border px-4" @onclick="CancelEditDescription">@L["Cancel"]</button>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="serif italic text-muted lh-lg" style="font-size: 1.1rem; white-space: pre-wrap;">
                            @(FSharpOption<string>.get_IsSome(bookDetails.Book.Description) ? bookDetails.Book.Description.Value : L["NoDescriptionProvided"])
                        </div>

                        @if (FSharpOption<string>.get_IsSome(bookDetails.Book.Description) && FSharpOption<EmbeddingDataId>.get_IsNone(bookDetails.Book.OptionalEmbedding) && bookDetails.Book.Editable)
                        {
                            <div class="mt-4 p-3 bg-surface-low rounded-xl border border-warning-subtle animate-fade-in shadow-sm d-flex align-items-center gap-3">
                                <div class="p-2 bg-warning-subtle rounded-circle text-warning">
                                    <i class="bi bi-cpu fs-5"></i>
                                </div>
                                <div class="flex-grow-1">
                                    <h6 class="serif mb-1 small fw-bold text-warning-emphasis">@L["AIVectorDataMissing"]</h6>
                                    <p class="small text-muted mb-0 serif italic">@L["NoVectorDataNote"]</p>
                                </div>
                                <button class="btn btn-sm btn-primary px-3 rounded-pill" @onclick="GenerateEmbedding" disabled="@isGeneratingEmbedding">
                                    @if (isGeneratingEmbedding)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2"></span>
                                        <span>@L["Wait"]...</span>
                                    }
                                    else
                                    {
                                        <i class="bi bi-magic me-1"></i>
                                        <span>@L["GenerateEmbedding"]</span>
                                    }
                                </button>
                            </div>
                        }

                        @if (FSharpOption<EmbeddingDataId>.get_IsSome(bookDetails.Book.OptionalEmbedding))
                        {
                            <div class="mt-4 p-4 bg-surface-low rounded-xl border border-primary-subtle shadow-sm animate-fade-in">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="p-2 bg-primary-subtle rounded-circle text-primary">
                                            <i class="bi bi-shield-check fs-5"></i>
                                        </div>
                                        <h6 class="serif mb-0 fw-bold">@L["SemanticSanityCheck"]</h6>
                                    </div>
                                    <div class="d-flex gap-2">
                                        <button class="btn btn-sm btn-outline-danger px-3" @onclick="RemoveEmbedding" disabled="@isRemovingEmbedding">
                                            @if (isRemovingEmbedding) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                            else { <i class="bi bi-trash me-1"></i> }
                                            @L["RemoveEmbedding"]
                                        </button>
                                        <button class="btn btn-sm btn-outline-primary px-3" @onclick="() => showSanityCheckForm = !showSanityCheckForm">
                                            <i class="bi @(showSanityCheckForm ? "bi-chevron-up" : "bi-chevron-down") me-1"></i>
                                            @(showSanityCheckForm ? L["Hide"] : L["PerformSanityCheck"])
                                        </button>
                                    </div>
                                </div>

                                @if (showSanityCheckForm)
                                {
                                    <div class="sanity-check-form animate-fade-in mt-3">
                                        <p class="small text-muted mb-3 italic">@L["VerifyAIUnderstandingNote"]</p>
                                        
                                        <div class="mb-3">
                                            <label class="form-label x-small text-uppercase fw-bold text-muted">@L["TestQueryDescription"]</label>
                                            <textarea class="form-control serif bg-white border shadow-sm" @bind="sanityCheckQuery" rows="3" placeholder="@L["SemanticSearchPlaceholder"]"></textarea>
                                        </div>

                                        <div class="d-flex align-items-end gap-3 mb-4">
                                            <div style="width: 100px;">
                                                <label class="form-label x-small text-uppercase fw-bold text-muted">@L["MaxResults"]</label>
                                                <input type="number" class="form-control" @bind="sanityCheckLimit" min="1" max="10" />
                                            </div>
                                            <button class="btn btn-primary px-4 shadow-sm" @onclick="PerformSanityCheck" disabled="@(string.IsNullOrWhiteSpace(sanityCheckQuery) || isPerformingSanityCheck)">
                                                @if (isPerformingSanityCheck) { <span class="spinner-border spinner-border-sm me-2"></span> }
                                                <i class="bi bi-search me-1"></i> @L["CheckSemanticAccuracy"]
                                            </button>
                                        </div>

                                        @if (sanityCheckResults != null)
                                        {
                                            <div class="results-area p-3 bg-white rounded border animate-fade-in shadow-sm">
                                                <h6 class="serif border-bottom pb-2 mb-3">Semantic Results</h6>
                                                
                                                <div class="d-flex align-items-center gap-3 mb-4">
                                                    @{
                                                        var matchesPrimary = sanityCheckResults.Any() && sanityCheckResults.First().Id.Value == bookDetails.Book.BookId.Value;
                                                        var inResults = sanityCheckResults.Any(r => r.Id.Value == bookDetails.Book.BookId.Value);
                                                    }
                                                    <div class="badge-sanctuary @(matchesPrimary ? "badge-available" : (inResults ? "badge-neutral" : "badge-borrowed")) p-3 d-flex align-items-center gap-3 flex-grow-1 border">
                                                        <i class="bi @(matchesPrimary ? "bi-check-circle-fill" : (inResults ? "bi-info-circle-fill" : "bi-exclamation-triangle-fill")) fs-4"></i>
                                                        <div>
                                                            <div class="fw-bold">@(matchesPrimary ? L["PrimaryMatchFound"] : (inResults ? L["SecondaryMatchFound"] : L["NoMatchFound"]))</div>
                                                            <div class="small opacity-75">@(matchesPrimary ? L["TopSemanticResult"] : (inResults ? L["FoundInTopResults"] : L["NotInTopResults"]))</div>
                                                        </div>
                                                    </div>
                                                </div>

                                                <div class="list-group list-group-flush border-top">
                                                    @foreach (var res in sanityCheckResults)
                                                    {
                                                        <a href="/book-edit/@res.Id.Value" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-3 rounded">
                                                            <div class="serif @(res.Id.Value == bookDetails.Book.BookId.Value ? "fw-bold text-primary" : "")">
                                                                @res.Title
                                                                @if (res.Id.Value == bookDetails.Book.BookId.Value) { <span class="ms-2 badge bg-primary-subtle text-primary small">@L["CurrentBook"]</span> }
                                                            </div>
                                                            <i class="bi bi-chevron-right text-muted"></i>
                                                        </a>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    }
                </div>

            </div> <!-- End lg-8 -->
        </div> <!-- End row g-5 -->

        <!-- Status & Future Engagements -->
        <div class="row g-5 mt-4">
            <div class="col-lg-12">
                <div class="card-sanctuary">
                    <h5 class="serif mb-4 pb-2 border-bottom" style="border-color: var(--outline-variant) !important;">@L["ArchivalLifecycle"]</h5>
                    
                    <div class="row g-4">
                        <div class="col-md-6 border-end" style="border-color: var(--surface-container-low) !important;">
                            <label class="form-label small text-muted text-uppercase fw-bold mb-3">@L["CurrentLoanStatus"]</label>
                            @if (FSharpOption<BookLibrary.Shared.Details.LoanDetails>.get_IsSome(bookDetails.CurrentLoan))
                            {
                                var loan = bookDetails.CurrentLoan.Value;
                                <div class="p-4 bg-surface-low rounded-xl border border-warning-subtle">
                                    <div class="d-flex align-items-center gap-3 mb-3">
                                        <i class="bi bi-journal-minus fs-3 text-warning"></i>
                                        <div>
                                            <h6 class="serif mb-1">@L["ItemCurrentlyWithBorrower"]</h6>
                                            <p class="small text-muted mb-0">UID: @loan.UserDetails.AppUser.UserName</p>
                                        </div>
                                    </div>
                                    <div class="d-flex justify-content-between small border-top pt-2">
                                        <span>@L["CheckoutDate"]: <strong class="serif">@loan.Loan.TimeSlot.Start.ToShortDateString()</strong></span>
                                        <span>@L["ExpectedReturn"]: <strong class="serif">@loan.Loan.TimeSlot.End.ToShortDateString()</strong></span>
                                    </div>
                                </div>
                            }
                            else if (bookDetails.Book.Available)
                            {
                                <div class="p-4 bg-surface-low rounded-xl border border-success-subtle d-flex align-items-center gap-3">
                                    <i class="bi bi-journal-check fs-3 text-success"></i>
                                    <div>
                                        <h6 class="serif mb-1">@L["AvailableInStacks"]</h6>
                                        <p class="small text-muted mb-0">@L["ReadyForDissemination"]</p>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="p-4 bg-surface-low rounded-xl border d-flex align-items-center gap-3">
                                    <i class="bi bi-journal-x fs-3 text-muted"></i>
                                    <div>
                                        <h6 class="serif mb-1">@L["ProvisionallyUnavailable"]</h6>
                                        <p class="small text-muted mb-0">@L["ContactRepositoryManager"]</p>
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="col-md-6">
                            <label class="form-label small text-muted text-uppercase fw-bold mb-3">@L["ScheduledReservations"]</label>
                            @if (bookDetails.ReservationsDetails.Any())
                            {
                                <div class="editorial-ledger">
                                    <table class="table table-borderless mb-0">
                                        <thead>
                                            <tr>
                                                <th class="ps-0">@L["Patron"]</th>
                                                <th>@L["TimeSlot"]</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @{
                                                var pendingRes = bookDetails.PendingReservationsDetails.ToList();
                                            }
                                            @for (int i = 0; i < pendingRes.Count; i++)
                                            {
                                                var res = pendingRes[i];
                                                <tr>
                                                    <td class="ps-0 py-3">
                                                        <div class="fw-bold serif">@res.UserDetails.AppUser.UserName</div>
                                                        <div class="x-small text-muted">@res.UserDetails.AppUser.CodiceFiscale</div>
                                                    </td>
                                                    <td class="py-3">
                                                        <div class="small font-monospace">@res.Reservation.TimeSlot.Start.ToShortDateString() — @res.Reservation.TimeSlot.End.ToShortDateString()</div>
                                                        @if (i == 0)
                                                        {
                                                            <div class="mt-3 p-3 bg-light rounded border border-primary-subtle shadow-sm animate-fade-in">
                                                                <div class="input-group input-group-sm">
                                                                    <input type="text" 
                                                                           class="form-control" 
                                                                           placeholder="Reservation Code" 
                                                                           @bind="reservationCodeInput" />
                                                                    <button class="btn btn-primary" @onclick="() => ConvertToLoan(res)">
                                                                        <i class="bi bi-arrow-repeat me-1"></i>
                                                                        Convert to Loan
                                                                    </button>
                                                                </div>
                                                            </div>
                                                        }
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <div class="p-4 bg-surface-low rounded-xl text-center border dashed">
                                    <p class="text-muted fst-italic small mb-0 serif">@L["NoFutureProvisions"]</p>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @if (bookDetails.Book.Editable)
        {
            <!-- Archival Removal -->
            <div class="mt-5 pt-5 border-top" style="border-color: var(--outline-variant) !important; border-style: dashed !important;">
                <div class="card-sanctuary bg-surface-low border-0">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="serif text-danger mb-1">@L["DeaccessionItem"]</h5>
                            <p class="text-muted small mb-0 serif">@L["PermanentlyRemoveFromArchivalRecord"]</p>
                        </div>
                        <button class="btn btn-outline-danger px-4 py-2 serif" @onclick="DeleteBook" disabled="@(!bookDetails.Book.Editable)">
                            <i class="bi bi-trash me-2"></i>@L["PurgeRecord"]
                        </button>
                    </div>
                </div>
            </div>
        }
    }
</div>


@code {
    [Parameter]
    public string BookIdStr { get; set; } = "";

    private bool isLoading = true;
    private Details.BookDetails? bookDetails;
    private string statusMessage = "";
    private string statusClass = "alert-info";
    private string reservationCodeInput = "";

    private string authorSearchInput = "";
    private List<Author> authorSearchResults = new();
    private bool showAuthorSearchResults = false;
    private Author? selectedAuthorForAdd = null;
    private bool isLoadingAuthors = false;
    private bool isGeneratingEmbedding = false;
    private bool isRemovingEmbedding = false;

    private bool showSanityCheckForm = false;
    private string sanityCheckQuery = "";
    private int sanityCheckLimit = 3;
    private bool isPerformingSanityCheck = false;
    private List<SanityCheckResult>? sanityCheckResults = null;

    public class SanityCheckResult
    {
        public BookId Id { get; set; } = null!;
        public string Title { get; set; } = "";
    }

    private bool isEditingImageUrl = false;
    private string editedImageUrl = "";
    private string? coverPreviewUrl = null;
    private bool isLookingUpCover = false;
    private string coverSizeLookup = "Medium";

    private bool isEditingIsbn = false;
    private string editedIsbn = "";
    private bool acceptInvalidIsbn = false;

    private bool isBookIsbnEmpty()
    {
        return bookDetails?.Book.Isbn.IsNoneIsbn ?? true;
    }

    private bool isBookIsbnValid()
    {
        return bookDetails?.Book.Isbn.IsValidIsbn ?? false;
    }

    private void StartEditingImageUrl()
    {
        isEditingImageUrl = true;
        coverPreviewUrl = null;
        if (bookDetails == null) return;
        editedImageUrl = FSharpOption<Uri>.get_IsSome(bookDetails.Book.ImageUrl) 
            ? bookDetails.Book.ImageUrl.Value.ToString() 
            : "";
    }

    private async Task HandleAuthorSearchInput(ChangeEventArgs e)
    {
        authorSearchInput = e.Value?.ToString() ?? "";
        if (authorSearchInput.Length >= 2)
        {
            isLoadingAuthors = true;
            try
            {
                var result = await AuthorService.SearchByNameAsync(Name.New(authorSearchInput), FSharpOption<CancellationToken>.None);
                if (result.IsOk)
                {
                    authorSearchResults = result.ResultValue.ToList();
                    showAuthorSearchResults = authorSearchResults.Any();
                }
                else
                {
                    authorSearchResults.Clear();
                    showAuthorSearchResults = false;
                }
            }
            finally
            {
                isLoadingAuthors = false;
            }
        }
        else
        {
            authorSearchResults.Clear();
            showAuthorSearchResults = false;
            selectedAuthorForAdd = null;
        }
    }

    private async Task SelectAuthorForAdd(Author author)
    {
        selectedAuthorForAdd = author;
        authorSearchInput = author.Name.Value;
        showAuthorSearchResults = false;
        await AddAuthorToBook();
    }

    private async Task AddAuthorToBook()
    {
        if (selectedAuthorForAdd == null || bookDetails == null) return;
        
        try
        {
            var result = await BookService.AddAuthorToBookAsync(selectedAuthorForAdd.AuthorId, bookDetails.Book.BookId, FSharpOption<CancellationToken>.None);
            if (result.IsOk)
            {
                var addedName = selectedAuthorForAdd.Name.Value;
                await LoadBookDetails();
                authorSearchInput = "";
                selectedAuthorForAdd = null;
                await ShowStatus($"{L["Author"]} '{addedName}' {L["HasBeenAdded"]}.", "alert-success");
            }
            else
            {
                await ShowStatus(string.Format(L["ErrorAddingAuthor"], result.ErrorValue), "alert-danger");
            }
        }
        catch (Exception ex)
        {
            await ShowStatus(string.Format(L["ErrorAddingAuthorGeneric"], ex.Message), "alert-danger");
        }
    }

    private async Task RemoveAuthorFromBook(Author author)
    {
        if (bookDetails == null) return;

        bool confirmed = await JSRuntime.InvokeAsync<bool>("confirm", $"{L["ConfirmRemoveAuthor"]} '{author.Name.Value}'?");
        if (!confirmed) return;

        try
        {
            var result = await BookService.RemoveAuthorFromBookAsync(author.AuthorId, bookDetails.Book.BookId, FSharpOption<CancellationToken>.None);
            if (result.IsOk)
            {
                await LoadBookDetails();
                await ShowStatus($"{L["Author"]} '{author.Name.Value}' {L["Removed"]}.", "alert-success");
            }
            else
            {
                await ShowStatus(string.Format(L["ErrorRemovingAuthor"], result.ErrorValue), "alert-danger");
            }
        }
        catch (Exception ex)
        {
            await ShowStatus(string.Format(L["ErrorRemovingAuthorGeneric"], ex.Message), "alert-danger");
        }
    }

    private bool showAddDropdown = false;
    private bool isEditingTitle = false;
    private string editedTitle = "";
    private bool isEditingCategory = false;
    private string editedCategory = "";
    private bool isEditingDescription = false;
    private string editedDescription = "";
    private bool isEditingAvailability = false;
    private string editedAvailability = "";
    private bool isBookSealed => bookDetails != null && bookDetails.Book.Sealed.IsSealed(DateTime.UtcNow);

    private async Task AddAdditionalCategoryWrapper(Category category)
    {
        showAddDropdown = false;
        await AddAdditionalCategory(category);
    }

    private async Task AddAdditionalCategory(Category category)
    {
        if (bookDetails == null) return;
        
        try 
        {
            var result = await BookService.AddAdditionalCategoryAsync(category, bookDetails.Book.BookId, FSharpOption<CancellationToken>.None);
            if (result.IsOk)
            {
                await LoadBookDetails();
                await ShowStatus($"{L["Category"]} '{category.Value()}' {L["HasBeenAdded"]}", "alert-success");
            }
            else
            {
                await ShowStatus(string.Format(L["ErrorAddingCategory"], result.ErrorValue), "alert-danger");
            }
        }
        catch (Exception ex)
        {
            await ShowStatus(string.Format(L["ErrorAddingCategoryGeneric"], ex.Message), "alert-danger");
        }
    }

    private async Task RemoveAdditionalCategory(Category category)
    {
        if (bookDetails == null) return;
        
        try 
        {
            var result = await BookService.RemoveAdditionalCategoryAsync(category, bookDetails.Book.BookId, FSharpOption<CancellationToken>.None);
            if (result.IsOk)
            {
                await LoadBookDetails();
                await ShowStatus($"{L["Category"]} '{category.Value()}' {L["Removed"]}", "alert-success");
            }
            else
            {
                await ShowStatus(string.Format(L["ErrorRemovingCategory"], result.ErrorValue), "alert-danger");
            }
        }
        catch (Exception ex)
        {
            await ShowStatus(string.Format(L["ErrorRemovingCategoryGeneric"], ex.Message), "alert-danger");
        }
    }

    private async Task StartEdit()
    {
        if (bookDetails?.Book.Editable ?? false)
        {
            isEditingTitle = true;
            editedTitle = bookDetails!.Book.Title.Value;
        }
        else if (isBookSealed)
        {
            await ShowStatus(L["BookSealedCannotEdit"], "alert-warning");
        }
    }

    private async Task ToggleSeal()
    {
        if (bookDetails == null) return;
        
        if (isBookSealed)
        {
            var hasLoans = FSharpOption<BookLibrary.Shared.Details.LoanDetails>.get_IsSome(bookDetails.CurrentLoan);
            var hasReservations = bookDetails.ReservationsDetails.Any();
            
            if (hasLoans || hasReservations)
            {
                await ShowStatus(L["CannotUnsealWithLoansOrReservations"], "alert-warning");
                return;
            }
        }

        var result = isBookSealed 
            ? await BookService.UnsealAsync(bookDetails.Book.BookId, FSharpOption<CancellationToken>.None)
            : await BookService.SealAsync(bookDetails.Book.BookId, FSharpOption<CancellationToken>.None);
            
        if (result.IsOk)
        {
            await LoadBookDetails();
            isEditingTitle = false;
        }
        else
        {
            await ShowStatus(string.Format(L["ErrorChangingSealState"], result.ErrorValue), "alert-danger");
        }
    }

    private void CancelEdit()
    {
        isEditingTitle = false;
    }

    private async Task StartEditCategory()
    {
        if (bookDetails?.Book.Editable ?? false)
        {
            isEditingCategory = true;
            editedCategory = bookDetails!.Book.MainCategory.Value();
        }
        else if (isBookSealed)
        {
            await ShowStatus(L["BookSealedCannotChangeCategory"], "alert-warning");
        }
    }

    private async Task UpdateCategory()
    {
        if (bookDetails == null || string.IsNullOrWhiteSpace(editedCategory) || editedCategory == bookDetails.Book.MainCategory.Value())
        {
            isEditingCategory = false;
            return;
        }

        try
        {
            var category = Category.FromString(editedCategory);
            var result = await BookService.ChangeMainCategoryAsync(category, bookDetails.Book.BookId, FSharpOption<CancellationToken>.None);
            if (result.IsOk)
            {
                await LoadBookDetails();
                isEditingCategory = false;
                await ShowStatus($"{L["Category"]} {L["HasBeenUpdated"]}.", "alert-success");
            }
            else
            {
                await ShowStatus(string.Format(L["ErrorUpdatingCategory"], result.ErrorValue), "alert-danger");
            }
        }
        catch (Exception ex)
        {
            await ShowStatus(string.Format(L["ErrorUpdatingCategoryGeneric"], ex.Message), "alert-danger");
        }
    }

    private async Task StartEditAvailability()
    {
        if (bookDetails?.Book.Editable ?? false)
        {
            isEditingAvailability = true;
            editedAvailability = bookDetails!.Book.Availability.ToString();
        }
        else if (isBookSealed)
        {
            await ShowStatus(L["BookSealedCannotChangeAvailability"], "alert-warning");
        }
    }

    private async Task UpdateAvailability()
    {
        if (bookDetails == null || string.IsNullOrWhiteSpace(editedAvailability) || editedAvailability == bookDetails.Book.Availability.ToString())
        {
            isEditingAvailability = false;
            return;
        }

        try
        {
            var availability = Availability.FromString(editedAvailability);
            var result = await BookService.SetAvailabilityAsync(availability, bookDetails.Book.BookId, FSharpOption<CancellationToken>.None);
            if (result.IsOk)
            {
                await LoadBookDetails();
                isEditingAvailability = false;
                await ShowStatus($"{L["Availability"]} {L["HasBeenUpdated"]}.", "alert-success");
            }
            else
            {
                await ShowStatus(string.Format(L["ErrorUpdatingAvailability"], result.ErrorValue), "alert-danger");
            }
        }
        catch (Exception ex)
        {
            await ShowStatus(string.Format(L["ErrorUpdatingAvailabilityGeneric"], ex.Message), "alert-danger");
        }
    }

    private string GetAvailabilityLocalName(Availability availability)
    {
        if (availability.IsCirculating) return L["CirculatingRule"];
        if (availability.IsReferenceOnly) return L["ReferenceOnlyRule"];
        return L["UnspecifiedRule"];
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await UpdateTitle();
        }
        else if (e.Key == "Escape")
        {
            CancelEdit();
        }
    }

    private async Task DeleteBook()
    {
        if (bookDetails == null) return;
        
        bool confirmed = await JSRuntime.InvokeAsync<bool>("confirm", $"{L["ConfirmPermanentlyDeleteBook"]} '{bookDetails.Book.Title.Value}'?");
        if (!confirmed) return;
        
        try 
        {
            // The service now handles the 3-phase removal (Vector DB cleanup, association removal, and book deletion)
            var result = await BookService.RemoveBookAsync(bookDetails.Book.BookId, FSharpOption<CancellationToken>.None);
            if (result.IsOk)
            {
                NavigationManager.NavigateTo("/books-manager");
            }
            else
            {
                await ShowStatus(string.Format(L["ErrorDeletingBook"], result.ErrorValue), "alert-danger");
            }
        }
        catch (Exception ex)
        {
            await ShowStatus(string.Format(L["ErrorDuringDeletion"], ex.Message), "alert-danger");
        }
    }

    private async Task UpdateTitle()
    {
        if (bookDetails == null || string.IsNullOrWhiteSpace(editedTitle) || editedTitle == bookDetails.Book.Title.Value)
        {
            isEditingTitle = false;
            return;
        }
        
        try 
        {
            var title = Title.New(editedTitle);
            var result = await BookService.UpdateTitleAsync(title, bookDetails.Book.BookId, FSharpOption<CancellationToken>.None);
            
            if (result.IsOk)
            {
                await LoadBookDetails();
                isEditingTitle = false;
                await ShowStatus(L["TitleUpdated"], "alert-success");
            }
            else
            {
                await ShowStatus(string.Format(L["ErrorUpdatingTitle"], result.ErrorValue), "alert-danger");
            }
        }
        catch (Exception ex)
        {
            await ShowStatus(string.Format(L["ErrorUpdatingTitleGeneric"], ex.Message), "alert-danger");
        }
    }

    private async Task UpdateImageUrl()
    {
        if (bookDetails == null) return;
        
        try 
        {
            if (string.IsNullOrWhiteSpace(editedImageUrl))
            {
                await RemoveImageUrl();
                return;
            }

            if (Uri.TryCreate(editedImageUrl, UriKind.Absolute, out var uri))
            {
                var result = await BookService.SetImageUrlAsync(bookDetails.Book.BookId, uri);
                if (result.IsOk)
                {
                    await ShowStatus(L["ImageUrlUpdated"], "alert-success");
                    isEditingImageUrl = false;
                    await LoadBookDetails();
                }
                else
                {
                    await ShowStatus(string.Format(L["ErrorUpdatingImage"], result.ErrorValue), "alert-danger");
                }
            }
            else
            {
                await ShowStatus(L["InvalidUrlFormat"], "alert-warning");
            }
        }
        catch (Exception ex)
        {
            await ShowStatus(string.Format(L["ErrorUpdatingImageGeneric"], ex.Message), "alert-danger");
        }
    }

    private async Task RemoveImageUrl()
    {
        if (bookDetails == null) return;
        
        bool confirm = await JSRuntime.InvokeAsync<bool>("confirm", L["ConfirmRemoveBookImage"]);
        if (!confirm) return;

        try
        {
            var result = await BookService.RemoveImageUrlAsync(bookDetails.Book.BookId);
            if (result.IsOk)
            {
                await ShowStatus(L["ImageCoverRemoved"], "alert-info");
                isEditingImageUrl = false;
                await LoadBookDetails();
            }
            else
            {
                await ShowStatus(string.Format(L["ErrorRemovingImage"], result.ErrorValue), "alert-danger");
            }
        }
        catch (Exception ex)
        {
            await ShowStatus(string.Format(L["ErrorRemovingImageGeneric"], ex.Message), "alert-danger");
        }
    }

    private async Task LookupCover()
    {
        if (bookDetails == null) return;

        isLookingUpCover = true;
        StateHasChanged();

        try
        {
            FSharpResult<FSharpOption<string>, string> result;
            string searchMode = "";

            if (isBookIsbnValid())
            {
                searchMode = "ISBN";
                var size = ThumbRoughSize.Medium;
                if (coverSizeLookup == "Small") size = ThumbRoughSize.Small;
                else if (coverSizeLookup == "Large") size = ThumbRoughSize.Large;

                result = await GoogleBooksService.LookupCoverImageByIsbnWithOpenApiAndThenGoogleAsync(bookDetails.Book.Isbn, FSharpOption<ThumbRoughSize>.Some(size));
            }
            else
            {
                searchMode = "Title/Author";
                var title = bookDetails.Book.Title.Value;
                var firstAuthor = bookDetails.Authors.FirstOrDefault();
                var authorName = firstAuthor != null ? FSharpOption<string>.Some(firstAuthor.Name.Value) : FSharpOption<string>.None;
                
                result = await GoogleBooksService.LookupGoogleApiCoverImageByTitleAndOptionalAuthorAsync(title, authorName);
            }

            if (result.IsOk && FSharpOption<string>.get_IsSome(result.ResultValue))
            {
                coverPreviewUrl = result.ResultValue.Value;
                await ShowStatus(string.Format(L["CoverImageFoundVia"], searchMode), "alert-success");
            }
            else if (result.IsOk)
            {
                await ShowStatus(string.Format(L["NoCoverFoundUsing"], searchMode), "alert-warning");
            }
            else
            {
                await ShowStatus(string.Format(L["LookupError"], result.ErrorValue), "alert-danger");
            }
        }
        catch (Exception ex)
        {
            await ShowStatus(string.Format(L["LookupErrorGeneric"], ex.Message), "alert-danger");
        }
        finally
        {
            isLookingUpCover = false;
        }
    }

    private async Task StartEditDescription()
    {
        if (bookDetails?.Book.Editable ?? false)
        {
            isEditingDescription = true;
            editedDescription = FSharpOption<string>.get_IsSome(bookDetails.Book.Description) 
                ? bookDetails.Book.Description.Value 
                : "";
        }
        else if (isBookSealed)
        {
            await ShowStatus(L["BookSealedCannotEditDescription"], "alert-warning");
        }
    }

    private void CancelEditDescription()
    {
        isEditingDescription = false;
    }

    private async Task UpdateDescription()
    {
        if (bookDetails == null) return;
        
        try 
        {
            FSharpResult<Microsoft.FSharp.Core.Unit, string> result;
            
            if (string.IsNullOrWhiteSpace(editedDescription))
            {
                result = await BookService.RemoveDescriptionAsync(bookDetails.Book.BookId, FSharpOption<System.Threading.CancellationToken>.None);
                if (result.IsOk) await ShowStatus(L["DescriptionRemoved"], "alert-success");
            }
            else
            {
                result = await BookService.UpdateDescriptionAsync(editedDescription, bookDetails.Book.BookId, FSharpOption<System.Threading.CancellationToken>.None);
                if (result.IsOk) 
                {
                    await ShowStatus(L["DescriptionUpdated"], "alert-success");
                    if (FSharpOption<EmbeddingDataId>.get_IsSome(bookDetails.Book.OptionalEmbedding))
                    {
                        await ShowStatus(L["UpdateEmbeddingAdvice"], "alert-warning");
                    }
                }
            }
            
            if (result.IsOk)
            {
                await LoadBookDetails();
                isEditingDescription = false;
            }
            else
            {
                await ShowStatus(string.Format(L["ErrorUpdatingDescription"], result.ErrorValue), "alert-danger");
            }
        }
        catch (Exception ex)
        {
            await ShowStatus(string.Format(L["ErrorUpdatingDescriptionGeneric"], ex.Message), "alert-danger");
        }
    }

    private async Task GenerateEmbedding()
    {
        if (bookDetails == null || FSharpOption<string>.get_IsNone(bookDetails.Book.Description)) return;
        
        isGeneratingEmbedding = true;
        try
        {
            var text = bookDetails.Book.Description.Value;
            var embeddingResult = await TextEmbeddingService.GetEmbeddingAsync(text); //, FSharpOption<System.Threading.CancellationToken>.None);
            
            if (!embeddingResult.IsOk)
            {
                await ShowStatus($"Embedding generation failed: {embeddingResult.ErrorValue}", "alert-danger");
                return;
            }

            var embeddingId = EmbeddingDataId.New();
            var storeResult = await VectorDbService.StoreEmbeddingAsync(embeddingId, bookDetails.Book.BookId, embeddingResult.ResultValue, FSharpOption<System.Threading.CancellationToken>.None);
            
            if (!storeResult.IsOk)
            {
                await ShowStatus($"Vector storage failed: {storeResult.ErrorValue}", "alert-danger");
                return;
            }

            var embedResult = await BookService.EmbedDescriptionAsync(bookDetails.Book.BookId, embeddingId, FSharpOption<System.Threading.CancellationToken>.None);
            
            if (embedResult.IsOk)
            {
                await ShowStatus("AI embedding generated and associated successfully.", "alert-success");
                await LoadBookDetails();
            }
            else
            {
                await ShowStatus($"Failed to link embedding to book: {embedResult.ErrorValue}", "alert-danger");
            }
        }
        catch (Exception ex)
        {
            await ShowStatus($"An unexpected error occurred: {ex.Message}", "alert-danger");
        }
        finally
        {
            isGeneratingEmbedding = false;
        }
    }

    private async Task PerformSanityCheck()
    {
        if (string.IsNullOrWhiteSpace(sanityCheckQuery) || bookDetails == null) return;
        
        isPerformingSanityCheck = true;
        sanityCheckResults = null;
        try
        {
            var embeddingResult = await TextEmbeddingService.GetEmbeddingAsync(sanityCheckQuery);
            if (!embeddingResult.IsOk)
            {
                await ShowStatus($"Query embedding failed: {embeddingResult.ErrorValue}", "alert-danger");
                return;
            }

            var searchResult = await VectorDbService.SearchSimilarEmbeddingsAsync(embeddingResult.ResultValue, sanityCheckLimit);
            if (!searchResult.IsOk)
            {
                await ShowStatus($"Semantic search failed: {searchResult.ErrorValue}", "alert-danger");
                return;
            }

            var results = new List<SanityCheckResult>();
            foreach (var item in searchResult.ResultValue)
            {
                var bookId = item.Item2;
                // Fetch title for each book
                var details = await DetailsService.GetBookDetailsAsync(bookId, FSharpOption<CancellationToken>.None);
                if (details.IsOk)
                {
                    results.Add(new SanityCheckResult { Id = bookId, Title = details.ResultValue.Book.Title.Value });
                }
                else
                {
                    results.Add(new SanityCheckResult { Id = bookId, Title = "Unknown Title" });
                }
            }
            sanityCheckResults = results;
        }
        catch (Exception ex)
        {
            await ShowStatus($"Sanity check error: {ex.Message}", "alert-danger");
        }
        finally
        {
            isPerformingSanityCheck = false;
        }
    }

    private async Task AcceptLookup()
    {
        if (coverPreviewUrl != null)
        {
            editedImageUrl = coverPreviewUrl;
            coverPreviewUrl = null;
            await ShowStatus(L["ImageUrlAppliedConfirm"], "alert-info");
        }
    }

    private async Task DiscardLookup()
    {
        coverPreviewUrl = null;
        await ShowStatus(L["CoverLookupDiscarded"], "alert-info");
    }

    private async Task StartEditIsbn()
    {
        if (bookDetails?.Book.Editable ?? false)
        {
            isEditingIsbn = true;
            editedIsbn = bookDetails.Book.Isbn.Value;
            acceptInvalidIsbn = false;
        }
        else if (isBookSealed)
        {
            await ShowStatus(L["BookSealedCannotEditIsbn"], "alert-warning");
        }
    }

    private void CancelEditIsbn()
    {
        isEditingIsbn = false;
    }

    private async Task UpdateIsbn()
    {
        if (bookDetails == null) return;
        if (string.IsNullOrWhiteSpace(editedIsbn))
        {
            await ShowStatus(L["IsbnCannotBeEmpty"], "alert-warning");
            return;
        }

        try
        {
            Isbn isbn;
            var validResult = Isbn.New(editedIsbn);
            
            if (validResult.IsOk)
            {
                isbn = validResult.ResultValue;
            }
            else if (acceptInvalidIsbn)
            {
                isbn = Isbn.NewInvalid(editedIsbn);
            }
            else
            {
                await ShowStatus(L["InvalidIsbnFormatSwitch"], "alert-warning");
                return;
            }

            var result = await BookService.UpdateIsbnAsync(isbn, bookDetails.Book.BookId, FSharpOption<CancellationToken>.None);
            if (result.IsOk)
            {
                await LoadBookDetails();
                isEditingIsbn = false;
                await ShowStatus(L["IsbnUpdated"], "alert-success");
            }
            else
            {
                await ShowStatus(string.Format(L["ErrorUpdatingIsbn"], result.ErrorValue), "alert-danger");
            }
        }
        catch (Exception ex)
        {
            await ShowStatus(string.Format(L["ErrorUpdatingIsbnGeneric"], ex.Message), "alert-danger");
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadBookDetails();
    }

    private async Task LoadBookDetails()
    {
        isLoading = true;
        statusMessage = "";

        try
        {
            if (Guid.TryParse(BookIdStr, out var guid))
            {
                var bookId = BookId.NewBookId(guid);
                var result = await DetailsService.GetBookDetailsAsync(bookId, FSharpOption<CancellationToken>.None);

                if (result.IsOk)
                {
                    bookDetails = result.ResultValue;
                    if (bookDetails.PendingReservationsDetails.Any())
                    {
                        var firstRes = bookDetails.PendingReservationsDetails.First();
                        var preFill = Configuration.GetValue<bool>("BooksLibrary:PreFillReservationCode");
                        if (preFill)
                        {
                            reservationCodeInput = firstRes.Reservation.ReservationCode.Value;
                        }
                    }
                }
                else
                {
                    await ShowStatus(string.Format(L["ErrorLoadingBook"], result.ErrorValue), "alert-danger");
                }
            }
            else
            {
                await ShowStatus(L["InvalidBookIdInUrl"], "alert-danger");
            }
        }
        catch (Exception ex)
        {
            await ShowStatus(string.Format(L["ErrorLoadingData"], ex.Message), "alert-danger");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ConvertToLoan(Details.ReservationDetails resDetails)
    {
        if (string.IsNullOrWhiteSpace(reservationCodeInput))
        {
            await ShowStatus("Please enter a reservation code.", "alert-warning");
            return;
        }

        try
        {
            @* var resCode = ReservationCode.ReservationCode(reservationCodeInput); *@
            var resCode = ReservationCode.ReservationCode.NewReservationCode(reservationCodeInput);
            var result = await LoanService.TransformReservationIntoLoanAsync(
                resDetails.Reservation.ReservationId, 
                resCode, 
                ShortLang.New(CultureInfo.CurrentCulture.Name),
                DateTime.UtcNow, 
                FSharpOption<CancellationToken>.None);

            if (result.IsOk)
            {
                await ShowStatus("Reservation successfully converted to loan.", "alert-success");
                await LoadBookDetails();
                reservationCodeInput = "";
            }
            else
            {
                await ShowStatus($"Error: {result.ErrorValue}", "alert-danger");
            }
        }
        catch (Exception ex)
        {
            await ShowStatus($"An error occurred: {ex.Message}", "alert-danger");
        }
    }

    private async Task ShowStatus(string message, string cssClass)
    {
        statusMessage = message;
        statusClass = cssClass;

        string type = "info";
        if (cssClass.Contains("success")) type = "success";
        else if (cssClass.Contains("danger")) type = "error";
        else if (cssClass.Contains("warning")) type = "warning";

        await JSRuntime.InvokeVoidAsync("showToast", message, type);
    }

    private async Task RemoveEmbedding()
    {
        if (bookDetails == null || FSharpOption<EmbeddingDataId>.get_IsNone(bookDetails.Book.OptionalEmbedding)) return;

        bool confirm = await JSRuntime.InvokeAsync<bool>("confirm", L["ConfirmRemoveEmbedding"]);
        if (!confirm) return;

        isRemovingEmbedding = true;
        var embeddingId = bookDetails.Book.OptionalEmbedding.Value;

        try
        {
            // 1. Remove from Book object via BookService
            var bookResult = await BookService.RemoveEmbeddingAsync(bookDetails.Book.BookId);
            if (!bookResult.IsOk)
            {
                await ShowStatus(string.Format(L["ErrorRemovingEmbedding"], bookResult.ErrorValue), "alert-danger");
                return;
            }

            // 2. Remove from Vector DB
            var vectorResult = await VectorDbService.RemoveEmbeddingAsync(embeddingId);
            if (!vectorResult.IsOk)
            {
                // Inform user and restore the reference in the Book object for consistency
                await ShowStatus(L["VectorDbRemovalFailed"], "alert-warning");
                var restoreResult = await BookService.EmbedDescriptionAsync(bookDetails.Book.BookId, embeddingId);
                if (!restoreResult.IsOk)
                {
                    await ShowStatus(string.Format(L["ErrorRestoringEmbedding"], restoreResult.ErrorValue), "alert-danger");
                }
            }
            else
            {
                await ShowStatus(L["EmbeddingRemoved"], "alert-success");
            }

            await LoadBookDetails();
        }
        catch (Exception ex)
        {
            await ShowStatus(string.Format(L["ErrorRemovingEmbedding"], ex.Message), "alert-danger");
        }
        finally
        {
            isRemovingEmbedding = false;
        }
    }
}
