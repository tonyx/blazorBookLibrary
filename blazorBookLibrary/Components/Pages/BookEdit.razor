@page "/book-edit/{BookIdStr}"
@using Microsoft.AspNetCore.Authorization
@using BookLibrary.Shared.Services
@using BookLibrary.Domain
@using BookLibrary.Shared
@using BookLibrary.Shared.Services
@using BookLibrary.Domain
@using blazorBookLibrary.Shared.Resources
@using static BookLibrary.Shared.Commons
@using Microsoft.FSharp.Core

@attribute [Authorize(Roles = "Admin, Manager")]
@inject IBookService BookService
@inject IAuthorService AuthorService
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager
@inject IGoogleBooksService GoogleBooksService
@inject IStringLocalizer<SharedResources> L
@rendermode InteractiveServer

<PageTitle>@L["BookDetails"]</PageTitle>

<style>
    .editable-title {
        cursor: pointer;
        padding: 4px 8px;
        border-radius: 4px;
        transition: all 0.2s ease;
        display: inline-block;
        border: 1px solid transparent;
    }
    .editable-title:hover {
        background-color: #f8f9fa;
        border-color: #dee2e6;
        color: #0d6efd;
    }
    .editable-category {
        transition: all 0.2s ease;
    }
    .editable-category:hover {
        opacity: 0.8;
        transform: scale(1.05);
    }
</style>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-primary mb-0"><i class="bi bi-info-circle me-2"></i>@L["BookDetails"]</h1>
        <a href="/books-manager" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>@L["BackToBooks"]
        </a>
    </div>

    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div class="alert @statusClass alert-dismissible fade show mb-4" role="alert">
            @statusMessage
            <button type="button" class="btn-close" @onclick='() => statusMessage = ""'></button>
        </div>
    }

    @if (isLoading)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">@L["WaitLoading"]</span>
            </div>
        </div>
    }
    else if (bookDetails != null)
    {
        <div class="row g-4">
            <!-- Book Info Section -->
            <div class="col-lg-7">
                <div class="card shadow-sm border-0 h-100" style="z-index: 10;">
                    <div class="card-header bg-primary text-white py-3 d-flex justify-content-between align-items-center">
                        <h5 class="card-title mb-0"><i class="bi bi-book me-2"></i>@L["GeneralInformation"]</h5>
                        <div class="form-check form-switch mb-0">
                            <input class="form-check-input" type="checkbox" id="sealSwitch" 
                                   checked="@(!isBookSealed)" 
                                   @onchange="ToggleSeal"
                                   style="cursor: pointer" />
                            <label class="form-check-label text-white ms-2" for="sealSwitch">
                                @(isBookSealed ? L["LockedSealed"] : L["EditableUnsealed"])
                            </label>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <!-- Image Column -->
                            <div class="col-md-4 mb-4 mb-md-0">
                                <div class="book-cover-container shadow-sm border rounded p-2 bg-white d-flex align-items-center justify-content-center" style="min-height: 200px; max-height: 350px; overflow: hidden;">
                                    @if (FSharpOption<Uri>.get_IsSome(bookDetails.Book.ImageUrl))
                                    {
                                        <img src="@bookDetails.Book.ImageUrl.Value.ToString()" 
                                             class="img-fluid rounded shadow-sm" 
                                             alt="Book Cover" 
                                             style="max-height: 100%; max-width: 100%; object-fit: contain;" />
                                    }
                                    else
                                    {
                                        <div class="text-center text-muted opacity-50 p-4">
                                            <i class="bi bi-book h1 d-block mb-2"></i>
                                            <span class="small d-block">@L["NoCoverAvailable"]</span>
                                        </div>
                                    }
                                </div>

                                @if (bookDetails.Book.Editable)
                                {
                                    <div class="mt-3">
                                        @if (isEditingImageUrl)
                                        {
                                            <div class="p-3 border rounded bg-light shadow-sm animate-fade-in">
                                                <label class="form-label small fw-bold text-muted text-uppercase mb-2">@L["UpdateProfileImageUrl"]</label>
                                                <div class="input-group input-group-sm mb-3">
                                                    <span class="input-group-text bg-white border-primary"><i class="bi bi-link-45deg"></i></span>
                                                    <input type="text" class="form-control border-primary" @bind="editedImageUrl" placeholder="@L["PasteImageUrl"]" />
                                                    <button class="btn btn-primary d-flex align-items-center" @onclick="UpdateImageUrl" title="@L["ConfirmChanges"]">
                                                        <i class="bi bi-check-lg me-1"></i><span>@L["Save"]</span>
                                                    </button>
                                                    <button class="btn btn-outline-secondary" @onclick="() => isEditingImageUrl = false">
                                                        <i class="bi bi-x-lg"></i><span>@L["Cancel"]</span>
                                                    </button>
                                                </div>

                                                <label class="form-label small fw-bold text-muted text-uppercase mb-2">@L["LookupCover"]</label>
                                                <div class="d-flex gap-2">
                                                    <select class="form-select form-select-sm border-info" @bind="coverSizeLookup">
                                                        <option value="Small">@L["Small"]</option>
                                                        <option value="Medium">@L["Medium"]</option>
                                                        <option value="Large">@L["Large"]</option>
                                                    </select>
                                                    <button class="btn btn-info btn-sm text-white flex-grow-1" @onclick="LookupCover" disabled="@isLookingUpCover">
                                                        @if (isLookingUpCover) { <span class="spinner-border spinner-border-sm me-1" role="status"></span> }
                                                        <i class="bi bi-search me-1"></i> @L["Lookup"]
                                                    </button>
                                                </div>
                                                <div class="form-text x-small mt-1 px-1 text-muted">
                                                    <i class="bi bi-info-circle me-1"></i>
                                                    @(isBookIsbnValid() ? "Searching by ISBN" : "Searching by title & author")
                                                </div>

                                                @if (coverPreviewUrl != null)
                                                {
                                                    <div class="mt-3 p-3 bg-white border border-info rounded shadow-sm animate-fade-in">
                                                        <div class="d-flex align-items-center gap-3">
                                                            <div class="flex-shrink-0" style="width: 80px; height: 110px; overflow: hidden; border: 1px solid #dee2e6; border-radius: 4px;">
                                                                <img src="@coverPreviewUrl" alt="Cover Preview" style="width: 100%; height: 100%; object-fit: contain;" />
                                                            </div>
                                                            <div class="flex-grow-1">
                                                                <h6 class="text-info fw-bold mb-1 small">@L["NewCoverFound"]</h6>
                                                                <p class="x-small text-muted mb-2">@L["UseThisImage"]</p>
                                                                <div class="d-flex gap-2">
                                                                    <button type="button" class="btn btn-info text-white btn-sm px-3 py-1" @onclick="AcceptLookup">
                                                                        <i class="bi bi-check2 me-1"></i>@L["Accept"]
                                                                    </button>
                                                                    <button type="button" class="btn btn-outline-secondary btn-sm px-3 py-1" @onclick="DiscardLookup">
                                                                        @L["Discard"]
                                                                    </button>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="d-grid gap-2">
                                                <button class="btn btn-sm btn-outline-primary" @onclick="StartEditingImageUrl">
                                                    @if (FSharpOption<Uri>.get_IsSome(bookDetails.Book.ImageUrl))
                                                    {
                                                        <i class="bi bi-pencil-square me-1"></i><span>@L["ChangeImage"]</span>
                                                    }
                                                    else
                                                    {
                                                        <i class="bi bi-plus-lg me-1"></i><span>@L["AddImage"]</span>
                                                    }
                                                </button>
                                                @if (FSharpOption<Uri>.get_IsSome(bookDetails.Book.ImageUrl))
                                                {
                                                    <button class="btn btn-sm btn-outline-danger" @onclick="RemoveImageUrl">
                                                        <i class="bi bi-image-fill me-1"></i> @L["RemoveImage"]
                                                    </button>
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                            </div>

                            <!-- Details Column -->
                            <div class="col-md-8">
                                <dl class="row mb-0">
                                    <dt class="col-sm-4 text-muted" @onclick="CancelEdit" style="cursor: pointer" title="@L["CancelEdit"]">@L["Title"]</dt>
                                    <dd class="col-sm-8 fw-bold fs-5">
                                        @if (isEditingTitle)
                                        {
                                            <div class="input-group">
                                                <input type="text" class="form-control fw-bold" @bind="editedTitle" @onkeyup="HandleKeyUp" autofocus />
                                                <button class="btn btn-primary" @onclick="UpdateTitle" title="@L["ConfirmChanges"]">
                                                    <i class="bi bi-check-lg"></i> @L["Confirm"]
                                                </button>
                                                <button class="btn btn-outline-secondary" @onclick="CancelEdit" title="@L["Cancel"]">
                                                    <i class="bi bi-x-lg"></i>
                                                </button>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="@((bookDetails?.Book.Editable ?? false) ? "editable-title" : "")" @onclick="StartEdit">
                                                @bookDetails.Book.Title.Value
                                                @if (bookDetails.Book.Editable)
                                                {
                                                    <i class="bi bi-pencil-square text-muted ms-2 small"></i>
                                                }
                                            </div>
                                        }
                                    </dd>

                                    <dt class="col-sm-4 text-muted mt-2">ISBN</dt>
                                    <dd class="col-sm-8 mt-2">
                                        @if (isEditingIsbn)
                                        {
                                            <div class="p-2 border rounded bg-light shadow-sm">
                                                <div class="input-group input-group-sm mb-2">
                                                    <input type="text" class="form-control" @bind="editedIsbn" placeholder="ISBN..." autofocus />
                                                    <button class="btn btn-primary" @onclick="UpdateIsbn">
                                                        <i class="bi bi-check-lg"></i> @L["Confirm"]
                                                    </button>
                                                    <button class="btn btn-outline-secondary" @onclick="CancelEditIsbn">
                                                        <i class="bi bi-x-lg"></i>
                                                    </button>
                                                </div>
                                                <div class="form-check form-switch">
                                                    <input class="form-check-input" type="checkbox" id="invalidIsbnSwitch" @bind="acceptInvalidIsbn" />
                                                    <label class="form-check-label x-small text-muted" for="invalidIsbnSwitch">@L["AcceptInvalidIsbn"]</label>
                                                </div>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="@((bookDetails?.Book.Editable ?? false) ? "editable-title" : "")" @onclick="StartEditIsbn">
                                                @bookDetails.Book.Isbn.Value
                                                @if (bookDetails.Book.Editable)
                                                {
                                                    <i class="bi bi-pencil-square text-muted ms-2 small"></i>
                                                }
                                            </div>
                                        }
                                    </dd>

                                    <dt class="col-sm-4 text-muted mt-2">@L["PublicationYear"]</dt>
                                    <dd class="col-sm-8 mt-2">@bookDetails.Book.Year.Value</dd>

                            <dt class="col-sm-4 text-muted">@L["MainCategory"]</dt>
                            <dd class="col-sm-8">
                                @if (isEditingCategory)
                                {
                                    <div class="input-group input-group-sm" style="max-width: 300px;">
                                        <select class="form-select" @bind="editedCategory">
                                            @foreach (var cat in Category.AllCases())
                                            {
                                                <option value="@cat.Value()" selected="@(cat.Value() == bookDetails.Book.MainCategory.Value())">@cat.Value()</option>
                                            }
                                        </select>
                                        <button class="btn btn-primary" @onclick="UpdateCategory">
                                            <i class="bi bi-check-lg"></i>
                                        </button>
                                        <button class="btn btn-outline-secondary" @onclick="() => isEditingCategory = false">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    </div>
                                }
                                else
                                {
                                    <span class="badge bg-secondary @((bookDetails?.Book.Editable ?? false) ? "editable-category" : "")" 
                                          @onclick="StartEditCategory" 
                                          style="@((bookDetails?.Book.Editable ?? false) ? "cursor: pointer;" : "")" 
                                          title="@((bookDetails?.Book.Editable ?? false) ? L["ChangeCategory"] : "")">
                                        @bookDetails.Book.MainCategory.Value()
                                        @if (bookDetails.Book.Editable)
                                        {
                                            <i class="bi bi-pencil-fill ms-2 small"></i>
                                        }
                                    </span>
                                }
                            </dd>

                            <dt class="col-sm-4 text-muted mt-2">@L["Availability"]</dt>
                            <dd class="col-sm-8 mt-2">
                                @if (isEditingAvailability)
                                {
                                    <div class="input-group input-group-sm" style="max-width: 300px;">
                                        <select class="form-select" @bind="editedAvailability">
                                            @foreach (var avail in Availability.AllCases())
                                            {
                                                <option value="@avail.ToString()" selected="@(avail.ToString() == bookDetails.Book.Availability.ToString())">
                                                    @GetAvailabilityLocalName(avail)
                                                </option>
                                            }
                                        </select>
                                        <button class="btn btn-primary" @onclick="UpdateAvailability">
                                            <i class="bi bi-check-lg"></i>
                                        </button>
                                        <button class="btn btn-outline-secondary" @onclick="() => isEditingAvailability = false">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    </div>
                                }
                                else
                                {
                                    <div class="@((bookDetails?.Book.Editable ?? false) ? "editable-title" : "")" 
                                          @onclick="StartEditAvailability" 
                                          style="@((bookDetails?.Book.Editable ?? false) ? "cursor: pointer;" : "")" 
                                          title="@((bookDetails?.Book.Editable ?? false) ? L["ChangeAvailability"] : "")">
                                        <span class="badge @(bookDetails.Book.Availability.IsCirculating ? "bg-success" : bookDetails.Book.Availability.IsReferenceOnly ? "bg-warning text-dark" : "bg-secondary")">
                                            @GetAvailabilityLocalName(bookDetails.Book.Availability)
                                        </span>
                                        @if (bookDetails.Book.Editable)
                                        {
                                            <i class="bi bi-pencil-square text-muted ms-2 small"></i>
                                        }
                                    </div>
                                }
                            </dd>
                            
                            <dt class="col-sm-4 text-muted">@L["AdditionalCategories"]</dt>
                            <dd class="col-sm-8">
                                <div class="d-flex flex-wrap align-items-center gap-2">
                                    @foreach (var cat in bookDetails.Book.AdditionalCategories)
                                    {
                                        <span class="badge rounded-pill bg-light text-dark border d-flex align-items-center">
                                            @cat.Value()
                                            @if (bookDetails.Book.Editable)
                                            {
                                                <span class="badge rounded-circle bg-danger ms-2 p-1 d-flex align-items-center justify-content-center hover-shadow" 
                                                      style="cursor: pointer; width: 18px; height: 18px;"
                                                      @onclick="() => RemoveAdditionalCategory(cat)"
                                                      title="@L["RemoveCategory"]">
                                                    <i class="bi bi-x text-white" style="font-size: 0.75rem;"></i>
                                                </span>
                                            }
                                        </span>
                                    }
                                    
                                    @if (bookDetails.Book.Editable)
                                    {
                                        <div class="position-relative d-inline-block">
                                            <button class="btn btn-sm btn-outline-primary rounded-pill" type="button" @onclick="() => showAddDropdown = !showAddDropdown">
                                                <i class="bi bi-plus-lg me-1"></i> @L["Add"]
                                            </button>
                                            
                                            @if (showAddDropdown)
                                            {
                                                <div class="position-absolute shadow border rounded bg-white p-2" style="z-index: 1000; min-width: 200px; max-height: 300px; overflow-y: auto; top: 100%; left: 0;">
                                                    <div class="d-flex justify-content-between align-items-center mb-2 px-2 border-bottom pb-1">
                                                        <span class="small fw-bold">@L["SelectCategory"]</span>
                                                        <button class="btn btn-sm p-0 border-0" @onclick="() => showAddDropdown = false"><i class="bi bi-x"></i></button>
                                                    </div>
                                                    @foreach (var cat in Category.AllCases())
                                                    {
                                                        var mainCat = bookDetails.Book.MainCategory;
                                                        if (cat != mainCat && !bookDetails.Book.AdditionalCategories.Contains(cat))
                                                        {
                                                            <div class="dropdown-item py-1 px-2 small rounded" style="cursor: pointer;" @onclick="() => AddAdditionalCategoryWrapper(cat)">
                                                                @cat.Value()
                                                            </div>
                                                        }
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                    else if (!bookDetails.Book.AdditionalCategories.Any())
                                    {
                                        <span class="text-muted fst-italic small">@L["NoAdditionalCategories"]</span>
                                    }
                                </div>
                            </dd>

                            <dt class="col-sm-4 text-muted">@L["Authors"]</dt>
                            <dd class="col-sm-8">
                                @if (bookDetails.Authors.Any())
                                {
                                    <div class="d-flex flex-wrap gap-2 mb-2">
                                        @foreach (var author in bookDetails.Authors)
                                        {
                                            <span class="badge bg-info text-dark d-flex align-items-center p-2 mb-1">
                                                <i class="bi bi-person me-1"></i>
                                                <a href="/author-details/@author.AuthorId.Value" class="text-dark text-decoration-none">@author.Name.Value</a>
                                                @if (bookDetails.Book.Editable)
                                                {
                                                    <span class="badge rounded-circle bg-danger ms-2 p-1 d-flex align-items-center justify-content-center hover-shadow" 
                                                          style="cursor: pointer; width: 18px; height: 18px;"
                                                          @onclick="() => RemoveAuthorFromBook(author)"
                                                          title="@L["RemoveAuthor"]">
                                                        <i class="bi bi-x text-white" style="font-size: 0.75rem;"></i>
                                                    </span>
                                                }
                                            </span>
                                        }
                                    </div>
                                }
                                
                                @if (bookDetails.Book.Editable)
                                {
                                    <div class="mt-3 position-relative" style="max-width: 450px;">
                                        <label class="form-label small fw-bold text-muted text-uppercase mb-1">@L["AssociateNewAuthor"]</label>
                                        <div class="input-group shadow-sm">
                                            <span class="input-group-text bg-white border-end-0"><i class="bi bi-person-plus text-primary"></i></span>
                                            <input type="text" 
                                                   class="form-control border-start-0" 
                                                   placeholder="@L["SearchAuthorToAdd"]" 
                                                   value="@authorSearchInput" 
                                                   @oninput="HandleAuthorSearchInput"
                                                   @onfocus="() => { if(authorSearchResults.Any()) showAuthorSearchResults = true; }" />
                                            <button class="btn btn-primary px-3" 
                                                    type="button" 
                                                    @onclick="AddAuthorToBook" 
                                                    disabled="@(selectedAuthorForAdd == null)">
                                                <i class="bi bi-plus-lg me-1"></i>@L["Add"]
                                            </button>
                                        </div>
                                        
                                        @if (showAuthorSearchResults)
                                        {
                                            <div class="list-group position-absolute w-100 shadow mt-1 border-primary-subtle" style="z-index: 1100; max-height: 250px; overflow-y: auto;">
                                                @foreach (var author in authorSearchResults)
                                                {
                                                    <button type="button" 
                                                            class="list-group-item list-group-item-action text-start py-2 animate-fade-in" 
                                                            @onclick="() => SelectAuthorForAdd(author)">
                                                        <div class="d-flex justify-content-between align-items-center">
                                                            <div class="fw-bold text-primary">@author.Name.Value</div>
                                                            @if (!string.IsNullOrEmpty(author.Isni.Value))
                                                            {
                                                                <span class="badge bg-light text-muted border small font-monospace">@author.Isni.Value</span>
                                                            }
                                                        </div>
                                                    </button>
                                                }
                                            </div>
                                        }
                                        @if (!string.IsNullOrEmpty(authorSearchInput) && authorSearchInput.Length >= 2 && !authorSearchResults.Any() && !isLoadingAuthors)
                                        {
                                            <div class="alert alert-light border small mt-1 py-1 px-2 text-muted shadow-sm">
                                                <i class="bi bi-info-circle me-1"></i>@L["NoAuthorsFoundMatching"] "@authorSearchInput"
                                            </div>
                                        }
                                    </div>
                                }
                                else if (!bookDetails.Authors.Any())
                                {
                                    <span class="text-muted fst-italic">@L["NoAuthorsAssociated"]</span>
                                }
                            </dd>

                            <dt class="col-sm-4 text-muted mt-2">@L["Description"]</dt>
                            <dd class="col-sm-8 mt-2">
                                @if (isEditingDescription)
                                {
                                    <div class="input-group">
                                        <textarea class="form-control" @bind="editedDescription" rows="5" autofocus></textarea>
                                    </div>
                                    <div class="mt-2 d-flex gap-2">
                                        <button class="btn btn-sm btn-primary" @onclick="UpdateDescription">
                                            <i class="bi bi-check-lg me-1"></i> @L["Confirm"]
                                        </button>
                                        <button class="btn btn-sm btn-outline-secondary" @onclick="CancelEditDescription">
                                            <i class="bi bi-x-lg me-1"></i> @L["Cancel"]
                                        </button>
                                    </div>
                                }
                                else
                                {
                                    <div class="@((bookDetails?.Book.Editable ?? false) ? "editable-title" : "")" @onclick="StartEditDescription">
                                        @if (FSharpOption<string>.get_IsSome(bookDetails?.Book.Description))
                                        {
                                            <p class="mb-0 text-break" style="white-space: pre-wrap;">@bookDetails.Book.Description.Value</p>
                                        }
                                        else
                                        {
                                            <span class="text-muted fst-italic">@L["NoDescriptionAvailable"]</span>
                                        }
                                        @if (bookDetails?.Book.Editable ?? false)
                                        {
                                            <i class="bi bi-pencil-square text-muted ms-2 small"></i>
                                        }
                                    </div>
                                }
                            </dd>

                                </dl>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Status & Availability Section -->
            <div class="col-lg-5">
                <div class="card shadow-sm border-0 mb-4 h-100">
                    <div class="card-header bg-success text-white py-3">
                        <h5 class="card-title mb-0"><i class="bi bi-calendar-check me-2"></i>@L["StatusAvailability"]</h5>
                    </div>
                    <div class="card-body">
                        <h6 class="text-uppercase text-muted fw-bold mb-3 small border-bottom pb-2">@L["CurrentLoan"]</h6>
                        @if (FSharpOption<BookLibrary.Domain.Loan>.get_IsSome(bookDetails.CurrentLoan))
                        {
                            var loan = bookDetails.CurrentLoan.Value;
                            <div class="alert alert-warning mb-4">
                                <p class="mb-1"><i class="bi bi-exclamation-triangle me-2"></i><strong>@L["CurrentlyLoanedOut"]</strong></p>
                                <ul class="list-unstyled mb-0 small mt-2">
                                    <li><strong>@L["Start"]:</strong> @loan.TimeSlot.Start.ToShortDateString()</li>
                                    <li><strong>@L["ExpectedReturn"]:</strong> @loan.TimeSlot.End.ToShortDateString()</li>
                                    <li><strong>@L["BorrowerUserId"]:</strong> @loan.UserId</li>
                                </ul>
                            </div>
                        }
                        else if (bookDetails.Book.ImmediatelyAvailable)
                        {
                            <div class="alert alert-success mb-4">
                                <i class="bi bi-check-circle me-2"></i><strong>@L["AvailableForLoan"]</strong>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-warning mb-4">
                                <i class="bi bi-exclamation-triangle me-2"></i><strong>@L["NotAvailable"]</strong>
                            </div>
                        }

                        <h6 class="text-uppercase text-muted fw-bold mb-3 small border-bottom pb-2">@L["FutureReservations"]</h6>
                        @if (bookDetails.FutureReservations.Any())
                        {
                            <ul class="list-group list-group-flush mb-0">
                                @foreach (var res in bookDetails.FutureReservations)
                                {
                                    <li class="list-group-item px-0 py-2 border-0 border-bottom">
                                        <div class="d-flex align-items-center">
                                            <i class="bi bi-calendar-event me-2 text-primary"></i>
                                            <div>
                                                <div class="small fw-bold">@res.TimeSlot.Start.ToShortDateString() - @res.TimeSlot.End.ToShortDateString()</div>
                                                <div class="small text-muted">User: @res.UserId</div>
                                            </div>
                                        </div>
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <p class="text-muted fst-italic small mb-0">@L["NoFutureReservations"]</p>
                        }
                    </div>
                </div>
            </div>
        </div>

        @if (bookDetails.Book.Editable)
        {
            <!-- Danger Zone Section -->
            <div class="row g-4 mt-4 mb-5">
                <div class="col-12">
                    <div class="card border-danger shadow-sm border-2">
                        <div class="card-header bg-danger text-white py-3">
                            <h5 class="card-title mb-0"><i class="bi bi-exclamation-octagon me-2"></i>@L["DangerZone"]</h5>
                        </div>
                        <div class="card-body d-flex justify-content-between align-items-center">
                            <div class="me-4">
                                <h6 class="fw-bold mb-1 text-danger">@L["PermanentlyRemoveBook"]</h6>
                                <p class="text-muted small mb-0">@L["DeleteBookDescription"]</p>
                            </div>
                            <button class="btn btn-danger btn-lg px-4 flex-shrink-0" @onclick="DeleteBook" disabled="@(!bookDetails.Book.Editable)">
                                <i class="bi bi-trash me-2"></i>@L["DeleteBook"]
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    [Parameter]
    public string BookIdStr { get; set; } = "";

    private bool isLoading = true;
    private Details.BookDetails? bookDetails;
    private string statusMessage = "";
    private string statusClass = "alert-info";

    private string authorSearchInput = "";
    private List<Author> authorSearchResults = new();
    private bool showAuthorSearchResults = false;
    private Author? selectedAuthorForAdd = null;
    private bool isLoadingAuthors = false;

    private bool isEditingImageUrl = false;
    private string editedImageUrl = "";
    private string? coverPreviewUrl = null;
    private bool isLookingUpCover = false;
    private string coverSizeLookup = "Medium";

    private bool isEditingIsbn = false;
    private string editedIsbn = "";
    private bool acceptInvalidIsbn = false;

    private bool isBookIsbnEmpty()
    {
        return bookDetails?.Book.Isbn.IsNoneIsbn ?? true;
    }

    private bool isBookIsbnValid()
    {
        return bookDetails?.Book.Isbn.IsValidIsbn ?? false;
    }

    private void StartEditingImageUrl()
    {
        isEditingImageUrl = true;
        coverPreviewUrl = null;
        if (bookDetails == null) return;
        editedImageUrl = FSharpOption<Uri>.get_IsSome(bookDetails.Book.ImageUrl) 
            ? bookDetails.Book.ImageUrl.Value.ToString() 
            : "";
    }

    private async Task HandleAuthorSearchInput(ChangeEventArgs e)
    {
        authorSearchInput = e.Value?.ToString() ?? "";
        if (authorSearchInput.Length >= 2)
        {
            isLoadingAuthors = true;
            try
            {
                var result = await AuthorService.SearchByNameAsync(Name.New(authorSearchInput), FSharpOption<CancellationToken>.None);
                if (result.IsOk)
                {
                    authorSearchResults = result.ResultValue.ToList();
                    showAuthorSearchResults = authorSearchResults.Any();
                }
                else
                {
                    authorSearchResults.Clear();
                    showAuthorSearchResults = false;
                }
            }
            finally
            {
                isLoadingAuthors = false;
            }
        }
        else
        {
            authorSearchResults.Clear();
            showAuthorSearchResults = false;
            selectedAuthorForAdd = null;
        }
    }

    private void SelectAuthorForAdd(Author author)
    {
        selectedAuthorForAdd = author;
        authorSearchInput = author.Name.Value;
        showAuthorSearchResults = false;
    }

    private async Task AddAuthorToBook()
    {
        if (selectedAuthorForAdd == null || bookDetails == null) return;
        
        try
        {
            var result = await BookService.AddAuthorToBookAsync(selectedAuthorForAdd.AuthorId, bookDetails.Book.BookId, FSharpOption<CancellationToken>.None);
            if (result.IsOk)
            {
                var addedName = selectedAuthorForAdd.Name.Value;
                await LoadBookDetails();
                authorSearchInput = "";
                selectedAuthorForAdd = null;
                ShowStatus($"{L["Author"]} '{addedName}' {L["HasBeenAdded"]}.", "alert-success");
            }
            else
            {
                ShowStatus($"Failed to add author: {result.ErrorValue}", "alert-danger");
            }
        }
        catch (Exception ex)
        {
            ShowStatus($"Error adding author: {ex.Message}", "alert-danger");
        }
    }

    private async Task RemoveAuthorFromBook(Author author)
    {
        if (bookDetails == null) return;

        bool confirmed = await JSRuntime.InvokeAsync<bool>("confirm", $"{L["ConfirmRemoveAuthor"]} '{author.Name.Value}'?");
        if (!confirmed) return;

        try
        {
            var result = await BookService.RemoveAuthorFromBookAsync(author.AuthorId, bookDetails.Book.BookId, FSharpOption<CancellationToken>.None);
            if (result.IsOk)
            {
                await LoadBookDetails();
                ShowStatus($"{L["Author"]} '{author.Name.Value}' {L["Removed"]}.", "alert-success");
            }
            else
            {
                ShowStatus($"Failed to remove author: {result.ErrorValue}", "alert-danger");
            }
        }
        catch (Exception ex)
        {
            ShowStatus($"Error removing author: {ex.Message}", "alert-danger");
        }
    }

    private bool showAddDropdown = false;
    private bool isEditingTitle = false;
    private string editedTitle = "";
    private bool isEditingCategory = false;
    private string editedCategory = "";
    private bool isEditingDescription = false;
    private string editedDescription = "";
    private bool isEditingAvailability = false;
    private string editedAvailability = "";
    private bool isBookSealed => bookDetails != null && bookDetails.Book.Sealed.IsSealed(DateTime.UtcNow);

    private async Task AddAdditionalCategoryWrapper(Category category)
    {
        showAddDropdown = false;
        await AddAdditionalCategory(category);
    }

    private async Task AddAdditionalCategory(Category category)
    {
        if (bookDetails == null) return;
        
        try 
        {
            var result = await BookService.AddAdditionalCategoryAsync(category, bookDetails.Book.BookId, FSharpOption<CancellationToken>.None);
            if (result.IsOk)
            {
                await LoadBookDetails();
                ShowStatus($"{L["Category"]} '{category.Value()}' {L["HasBeenAdded"]}", "alert-success");
            }
            else
            {
                ShowStatus($"Failed to add category: {result.ErrorValue}", "alert-danger");
            }
        }
        catch (Exception ex)
        {
            ShowStatus($"Error adding category: {ex.Message}", "alert-danger");
        }
    }

    private async Task RemoveAdditionalCategory(Category category)
    {
        if (bookDetails == null) return;
        
        try 
        {
            var result = await BookService.RemoveAdditionalCategoryAsync(category, bookDetails.Book.BookId, FSharpOption<CancellationToken>.None);
            if (result.IsOk)
            {
                await LoadBookDetails();
                ShowStatus($"{L["Category"]} '{category.Value()}' {L["Removed"]}", "alert-success");
            }
            else
            {
                ShowStatus($"Failed to remove category: {result.ErrorValue}", "alert-danger");
            }
        }
        catch (Exception ex)
        {
            ShowStatus($"Error removing category: {ex.Message}", "alert-danger");
        }
    }

    private void StartEdit()
    {
        if (bookDetails?.Book.Editable ?? false)
        {
            isEditingTitle = true;
            editedTitle = bookDetails!.Book.Title.Value;
        }
        else if (isBookSealed)
        {
            ShowStatus("This book is currently sealed (locked). Please unseal it to edit.", "alert-warning");
        }
    }

    private async Task ToggleSeal()
    {
        if (bookDetails == null) return;
        
        var result = isBookSealed 
            ? await BookService.UnsealAsync(bookDetails.Book.BookId, FSharpOption<CancellationToken>.None)
            : await BookService.SealAsync(bookDetails.Book.BookId, FSharpOption<CancellationToken>.None);
            
        if (result.IsOk)
        {
            await LoadBookDetails();
            isEditingTitle = false;
        }
        else
        {
            ShowStatus($"Failed to change seal state: {result.ErrorValue}", "alert-danger");
        }
    }

    private void CancelEdit()
    {
        isEditingTitle = false;
    }

    private void StartEditCategory()
    {
        if (bookDetails?.Book.Editable ?? false)
        {
            isEditingCategory = true;
            editedCategory = bookDetails!.Book.MainCategory.Value();
        }
        else if (isBookSealed)
        {
            ShowStatus("This book is currently sealed. Please unseal it to change its category.", "alert-warning");
        }
    }

    private async Task UpdateCategory()
    {
        if (bookDetails == null || string.IsNullOrWhiteSpace(editedCategory) || editedCategory == bookDetails.Book.MainCategory.Value())
        {
            isEditingCategory = false;
            return;
        }

        try
        {
            var category = Category.FromString(editedCategory);
            var result = await BookService.ChangeMainCategoryAsync(category, bookDetails.Book.BookId, FSharpOption<CancellationToken>.None);
            if (result.IsOk)
            {
                await LoadBookDetails();
                isEditingCategory = false;
                ShowStatus($"{L["Category"]} {L["HasBeenUpdated"]}.", "alert-success");
            }
            else
            {
                ShowStatus($"Failed to update category: {result.ErrorValue}", "alert-danger");
            }
        }
        catch (Exception ex)
        {
            ShowStatus($"Error updating category: {ex.Message}", "alert-danger");
        }
    }

    private void StartEditAvailability()
    {
        if (bookDetails?.Book.Editable ?? false)
        {
            isEditingAvailability = true;
            editedAvailability = bookDetails!.Book.Availability.ToString();
        }
        else if (isBookSealed)
        {
            ShowStatus("This book is currently sealed. Please unseal it to change its availability status.", "alert-warning");
        }
    }

    private async Task UpdateAvailability()
    {
        if (bookDetails == null || string.IsNullOrWhiteSpace(editedAvailability) || editedAvailability == bookDetails.Book.Availability.ToString())
        {
            isEditingAvailability = false;
            return;
        }

        try
        {
            var availability = Availability.FromString(editedAvailability);
            var result = await BookService.SetAvailabilityAsync(availability, bookDetails.Book.BookId, FSharpOption<CancellationToken>.None);
            if (result.IsOk)
            {
                await LoadBookDetails();
                isEditingAvailability = false;
                ShowStatus($"{L["Availability"]} {L["HasBeenUpdated"]}.", "alert-success");
            }
            else
            {
                ShowStatus($"Failed to update availability: {result.ErrorValue}", "alert-danger");
            }
        }
        catch (Exception ex)
        {
            ShowStatus($"Error updating availability: {ex.Message}", "alert-danger");
        }
    }

    private string GetAvailabilityLocalName(Availability availability)
    {
        if (availability.IsCirculating) return L["CirculatingRule"];
        if (availability.IsReferenceOnly) return L["ReferenceOnlyRule"];
        return L["UnspecifiedRule"];
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await UpdateTitle();
        }
        else if (e.Key == "Escape")
        {
            CancelEdit();
        }
    }

    private async Task DeleteBook()
    {
        if (bookDetails == null) return;
        
        bool confirmed = await JSRuntime.InvokeAsync<bool>("confirm", $"{L["ConfirmPermanentlyDeleteBook"]} '{bookDetails.Book.Title.Value}'?");
        if (!confirmed) return;
        
        try 
        {
            var result = await BookService.RemoveBookAsync(bookDetails.Book.BookId, FSharpOption<CancellationToken>.None);
            if (result.IsOk)
            {
                NavigationManager.NavigateTo("/books-manager");
            }
            else
            {
                ShowStatus($"Failed to delete book: {result.ErrorValue}", "alert-danger");
            }
        }
        catch (Exception ex)
        {
            ShowStatus($"Error during deletion: {ex.Message}", "alert-danger");
        }
    }

    private async Task UpdateTitle()
    {
        if (bookDetails == null || string.IsNullOrWhiteSpace(editedTitle) || editedTitle == bookDetails.Book.Title.Value)
        {
            isEditingTitle = false;
            return;
        }
        
        try 
        {
            var title = Title.New(editedTitle);
            var result = await BookService.UpdateTitleAsync(title, bookDetails.Book.BookId, FSharpOption<CancellationToken>.None);
            
            if (result.IsOk)
            {
                await LoadBookDetails();
                isEditingTitle = false;
                ShowStatus(L["TitleUpdated"], "alert-success");
            }
            else
            {
                ShowStatus($"Failed to update title: {result.ErrorValue}", "alert-danger");
            }
        }
        catch (Exception ex)
        {
            ShowStatus($"Error updating title: {ex.Message}", "alert-danger");
        }
    }

    private async Task UpdateImageUrl()
    {
        if (bookDetails == null) return;
        
        try 
        {
            if (string.IsNullOrWhiteSpace(editedImageUrl))
            {
                await RemoveImageUrl();
                return;
            }

            if (Uri.TryCreate(editedImageUrl, UriKind.Absolute, out var uri))
            {
                var result = await BookService.SetImageUrlAsync(bookDetails.Book.BookId, uri);
                if (result.IsOk)
                {
                    ShowStatus(L["ImageUrlUpdated"], "alert-success");
                    isEditingImageUrl = false;
                    await LoadBookDetails();
                }
                else
                {
                    ShowStatus($"Error updating image: {result.ErrorValue}", "alert-danger");
                }
            }
            else
            {
                ShowStatus("Invalid URL format. Please provide a full absolute URL.", "alert-warning");
            }
        }
        catch (Exception ex)
        {
            ShowStatus($"Exception updating image: {ex.Message}", "alert-danger");
        }
    }

    private async Task RemoveImageUrl()
    {
        if (bookDetails == null) return;
        
        bool confirm = await JSRuntime.InvokeAsync<bool>("confirm", L["ConfirmRemoveBookImage"]);
        if (!confirm) return;

        try
        {
            var result = await BookService.RemoveImageUrlAsync(bookDetails.Book.BookId);
            if (result.IsOk)
            {
                ShowStatus(L["ImageCoverRemoved"], "alert-info");
                isEditingImageUrl = false;
                await LoadBookDetails();
            }
            else
            {
                ShowStatus($"Error removing image: {result.ErrorValue}", "alert-danger");
            }
        }
        catch (Exception ex)
        {
            ShowStatus($"Exception removing image: {ex.Message}", "alert-danger");
        }
    }

    private async Task LookupCover()
    {
        if (bookDetails == null) return;

        isLookingUpCover = true;
        StateHasChanged();

        try
        {
            FSharpResult<FSharpOption<string>, string> result;
            string searchMode = "";

            if (isBookIsbnValid())
            {
                searchMode = "ISBN";
                var size = ThumbRoughSize.Medium;
                if (coverSizeLookup == "Small") size = ThumbRoughSize.Small;
                else if (coverSizeLookup == "Large") size = ThumbRoughSize.Large;

                result = await GoogleBooksService.LookupCoverImageByIsbnWithOpenApiAndThenGoogleAsync(bookDetails.Book.Isbn, FSharpOption<ThumbRoughSize>.Some(size));
            }
            else
            {
                searchMode = "Title/Author";
                var title = bookDetails.Book.Title.Value;
                var firstAuthor = bookDetails.Authors.FirstOrDefault();
                var authorName = firstAuthor != null ? FSharpOption<string>.Some(firstAuthor.Name.Value) : FSharpOption<string>.None;
                
                result = await GoogleBooksService.LookupGoogleApiCoverImageByTitleAndOptionalAuthorAsync(title, authorName);
            }

            if (result.IsOk && FSharpOption<string>.get_IsSome(result.ResultValue))
            {
                coverPreviewUrl = result.ResultValue.Value;
                ShowStatus($"Cover image found via {searchMode}! See preview below.", "alert-success");
            }
            else if (result.IsOk)
            {
                ShowStatus($"No cover found using {searchMode}.", "alert-warning");
            }
            else
            {
                ShowStatus($"Lookup error: {result.ErrorValue}", "alert-danger");
            }
        }
        catch (Exception ex)
        {
            ShowStatus($"Exception during lookup: {ex.Message}", "alert-danger");
        }
        finally
        {
            isLookingUpCover = false;
        }
    }

    private void StartEditDescription()
    {
        if (bookDetails?.Book.Editable ?? false)
        {
            isEditingDescription = true;
            editedDescription = FSharpOption<string>.get_IsSome(bookDetails.Book.Description) 
                ? bookDetails.Book.Description.Value 
                : "";
        }
        else if (isBookSealed)
        {
            ShowStatus("This book is currently sealed. Please unseal it to edit the description.", "alert-warning");
        }
    }

    private void CancelEditDescription()
    {
        isEditingDescription = false;
    }

    private async Task UpdateDescription()
    {
        if (bookDetails == null) return;
        
        try 
        {
            FSharpResult<Microsoft.FSharp.Core.Unit, string> result;
            
            if (string.IsNullOrWhiteSpace(editedDescription))
            {
                result = await BookService.RemoveDescriptionAsync(bookDetails.Book.BookId, FSharpOption<System.Threading.CancellationToken>.None);
                if (result.IsOk) ShowStatus(L["DescriptionRemoved"], "alert-success");
            }
            else
            {
                result = await BookService.UpdateDescriptionAsync(editedDescription, bookDetails.Book.BookId, FSharpOption<System.Threading.CancellationToken>.None);
                if (result.IsOk) ShowStatus(L["DescriptionUpdated"], "alert-success");
            }
            
            if (result.IsOk)
            {
                await LoadBookDetails();
                isEditingDescription = false;
            }
            else
            {
                ShowStatus($"Failed to update description: {result.ErrorValue}", "alert-danger");
            }
        }
        catch (Exception ex)
        {
            ShowStatus($"Error updating description: {ex.Message}", "alert-danger");
        }
    }

    private void AcceptLookup()
    {
        if (coverPreviewUrl != null)
        {
            editedImageUrl = coverPreviewUrl;
            coverPreviewUrl = null;
            ShowStatus("New image URL applied. Click 'Save' to confirm.", "alert-info");
        }
    }

    private void DiscardLookup()
    {
        coverPreviewUrl = null;
        ShowStatus("Cover lookup discarded.", "alert-info");
    }

    private void StartEditIsbn()
    {
        if (bookDetails?.Book.Editable ?? false)
        {
            isEditingIsbn = true;
            editedIsbn = bookDetails.Book.Isbn.Value;
            acceptInvalidIsbn = false;
        }
        else if (isBookSealed)
        {
            ShowStatus("This book is currently sealed. Please unseal it to edit the ISBN.", "alert-warning");
        }
    }

    private void CancelEditIsbn()
    {
        isEditingIsbn = false;
    }

    private async Task UpdateIsbn()
    {
        if (bookDetails == null) return;
        if (string.IsNullOrWhiteSpace(editedIsbn))
        {
            ShowStatus("ISBN cannot be empty.", "alert-warning");
            return;
        }

        try
        {
            Isbn isbn;
            var validResult = Isbn.New(editedIsbn);
            
            if (validResult.IsOk)
            {
                isbn = validResult.ResultValue;
            }
            else if (acceptInvalidIsbn)
            {
                isbn = Isbn.NewInvalid(editedIsbn);
            }
            else
            {
                ShowStatus("Invalid ISBN format. If you need to save it anyway, use the 'Accept Invalid' switch.", "alert-warning");
                return;
            }

            var result = await BookService.UpdateIsbnAsync(isbn, bookDetails.Book.BookId, FSharpOption<CancellationToken>.None);
            if (result.IsOk)
            {
                await LoadBookDetails();
                isEditingIsbn = false;
                ShowStatus(L["IsbnUpdated"], "alert-success");
            }
            else
            {
                ShowStatus($"Failed to update ISBN: {result.ErrorValue}", "alert-danger");
            }
        }
        catch (Exception ex)
        {
            ShowStatus($"Error updating ISBN: {ex.Message}", "alert-danger");
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadBookDetails();
    }

    private async Task LoadBookDetails()
    {
        isLoading = true;
        statusMessage = "";

        try
        {
            if (Guid.TryParse(BookIdStr, out var guid))
            {
                var bookId = BookId.NewBookId(guid);
                var result = await BookService.GetBookDetailsAsync(bookId, FSharpOption<CancellationToken>.None);

                if (result.IsOk)
                {
                    bookDetails = result.ResultValue;
                }
                else
                {
                    ShowStatus($"Failed to load book: {result.ErrorValue}", "alert-danger");
                }
            }
            else
            {
                ShowStatus("Invalid book identifier in URL.", "alert-danger");
            }
        }
        catch (Exception ex)
        {
            ShowStatus($"Error loading data: {ex.Message}", "alert-danger");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ShowStatus(string message, string cssClass)
    {
        statusMessage = message;
        statusClass = cssClass;
    }
}
