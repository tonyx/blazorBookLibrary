@page "/author-details/{AuthorIdStr}"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.QuickGrid
@using BookLibrary.Shared.Services
@using Microsoft.Extensions.Localization
@using blazorBookLibrary.Shared.Resources
@using BookLibrary.Domain
@using static BookLibrary.Shared.Commons
@using BookLibrary.Shared
@using Microsoft.FSharp.Core

@attribute [Authorize(Roles = "Admin, Manager")]
@inject IAuthorService AuthorService
@inject IAuthorsSearchService AuthorsSearchService
@inject NavigationManager NavigationManager
@inject IStringLocalizer<SharedResources> L
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<PageTitle>@L["AuthorDetails"]</PageTitle>

<div class="sanctuary-container" @onclick="CancelAllEdits">
    <!-- Header Area -->
    <div class="d-flex justify-content-between align-items-end mb-5 border-bottom pb-4" style="border-color: var(--outline-variant) !important;">
        <div>
            <nav aria-label="breadcrumb" class="mb-2">
                <ol class="breadcrumb mb-0" style="font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--secondary);">
                    <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-reset">@L["Home"]</a></li>
                    <li class="breadcrumb-item"><a href="/books-manager" class="text-decoration-none text-reset">@L["Library"]</a></li>
                    <li class="breadcrumb-item active" aria-current="page">@L["AuthorProfile"]</li>
                </ol>
            </nav>
            <h1 class="serif display-5 mb-0" style="font-weight: 800; color: var(--primary);">@L["AuthorProfile"]</h1>
        </div>
        <a href="/books-manager" class="btn-sanctuary-outline text-decoration-none">
            <i class="bi bi-arrow-left me-2"></i>@L["BackToLibrary"]
        </a>
    </div>

    @if (isLoading)
    {
        <div class="d-flex justify-content-center align-items-center" style="min-height: 400px;">
            <div class="spinner-grow text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (authorDetails != null)
    {
        <div class="row g-5">
            <!-- Left Column: Portrait & Stats -->
            <div class="col-lg-4">
                <div class="card-sanctuary floating text-center mb-4">
                    <div class="profile-image-wrap mb-4 bg-surface-low rounded-circle mx-auto position-relative" style="width: 200px; height: 200px; overflow: hidden; border: 8px solid var(--surface-container-lowest);">
                        @if (authorDetails.Author.ImageUri != null && FSharpOption<Uri>.get_IsSome(authorDetails.Author.ImageUri))
                        {
                            <img src="@authorDetails.Author.ImageUri.Value.ToString()" 
                                 class="w-100 h-100" 
                                 style="object-fit: cover;" 
                                 alt="@authorDetails.Author.Name.Value Profile" />
                        }
                        else
                        {
                            <div class="w-100 h-100 d-flex flex-column align-items-center justify-content-center text-muted opacity-25">
                                <i class="bi bi-person-fill" style="font-size: 6rem;"></i>
                                @if (authorDetails.Author.Editable)
                                {
                                    <button class="btn btn-link btn-sm text-decoration-none mt-n4 text-serif" @onclick:stopPropagation @onclick="StartEditImageUrl">
                                        + @L["AddPortrait"]
                                    </button>
                                }
                            </div>
                        }

                        @if (authorDetails.Author.Editable)
                        {
                            <div class="image-edit-badge position-absolute" @onclick="StartEditImageUrl" @onclick:stopPropagation title="@L["ChangeProfileImage"]">
                                <i class="bi bi-camera-fill"></i>
                            </div>
                        }
                    </div>

                    <div class="d-flex flex-column gap-3">
                        <div class="d-flex justify-content-center flex-wrap gap-2">
                             <span class="badge-sanctuary badge-neutral">
                                <i class="bi bi-journals me-2"></i> @authorDetails.Books.Length @L["RegisteredTitles"]
                            </span>
                            
                            @if (authorDetails.UnSealable)
                            {
                                <div class="badge-sanctuary @(isAuthorSealed ? "badge-borrowed" : "badge-available") d-flex align-items-center py-1">
                                    <i class="bi @(isAuthorSealed ? "bi-lock-fill" : "bi-unlock-fill") me-2"></i>
                                    <div class="form-check form-switch p-0 m-0 d-flex align-items-center">
                                        <input class="form-check-input ms-0 me-2" type="checkbox" id="sealSwitch" 
                                               checked="@(!isAuthorSealed)" 
                                               @onchange="ToggleSeal"
                                               style="cursor: pointer; width: 2em; height: 1em;" />
                                        <label class="form-check-label small fw-bold" for="sealSwitch">
                                            @(isAuthorSealed ? L["LockedSealed"] : L["EditableUnsealed"])
                                        </label>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    @if (authorDetails.Books.Length == 0 && authorDetails.Author.Editable)
                    {
                        <div class="mt-5 p-4 bg-surface-low rounded-xl text-start">
                            <h6 class="serif text-danger mb-2">@L["DangerZone"]</h6>
                            <p class="small text-muted mb-3">@L["PermanentlyRemoveAuthor"]</p>
                            <button class="btn btn-sm btn-outline-danger w-100 rounded-pill" @onclick="DeleteAuthor">
                                <i class="bi bi-trash me-2"></i>@L["DeleteAuthorProfile"]
                            </button>
                        </div>
                    }
                </div>
            </div>

            <!-- Right Column: Details & Works Ledger -->
            <div class="col-lg-8">
                <!-- Administrative Ledger (Profile Stats) -->
                <div class="card-sanctuary mb-5">
                    <h5 class="serif mb-4 pb-2 border-bottom" style="border-color: var(--outline-variant) !important;">@L["ArchivalRecord"]</h5>
                    
                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="form-label small text-muted text-uppercase fw-bold mb-2">@L["AuthorFullName"]</label>
                            @if (isEditingName)
                            {
                                <div class="input-group input-group-sm mb-2" @onclick:stopPropagation>
                                    <input type="text" class="form-control bg-surface-low border-0 serif fw-bold" @bind="editedName" @onkeyup="HandleKeyUp" autofocus />
                                    <button class="btn btn-primary" @onclick="UpdateName">@L["Confirm"]</button>
                                    <button class="btn btn-outline-secondary" @onclick="CancelEditName"><i class="bi bi-x-lg"></i></button>
                                </div>
                            }
                            else
                            {
                                <div class="d-flex align-items-center gap-3">
                                    <p class="serif h4 mb-0" style="color: var(--primary); font-weight: 700;">@authorDetails.Author.Name.Value</p>
                                    @if (authorDetails.Author.Editable)
                                    {
                                        <button class="btn btn-link p-0 text-muted" @onclick="StartEditName" @onclick:stopPropagation><i class="bi bi-pencil-square"></i></button>
                                    }
                                </div>
                            }
                        </div>
                        
                        <div class="col-md-6">
                            <label class="form-label small text-muted text-uppercase fw-bold mb-2">@L["IsniNumber"]</label>
                            @if (isEditingIsni)
                            {
                                <div class="edit-isni-container" @onclick:stopPropagation>
                                    <div class="input-group input-group-sm mb-2">
                                        <input type="text" class="form-control font-monospace py-2" @bind="editedIsni" placeholder="0000 0001 2140 1961" />
                                        <button class="btn btn-primary px-3" @onclick="UpdateIsni">@L["Confirm"]</button>
                                        <button class="btn btn-outline-secondary" @onclick="CancelEditIsni"><i class="bi bi-x-lg"></i></button>
                                    </div>
                                    <div class="form-check form-switch small">
                                        <input class="form-check-input" type="checkbox" id="invalidIsniSwitch" @bind="acceptInvalidIsni" />
                                        <label class="form-check-label text-muted" for="invalidIsniSwitch">@L["AcceptInvalidIsni"]</label>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="d-flex align-items-center gap-3">
                                    @if (string.IsNullOrEmpty(authorDetails.Author.Isni.Value))
                                    {
                                        <span class="text-muted small fst-italic">@L["NoneNotSet"]</span>
                                    }
                                    else
                                    {
                                        <span class="badge-sanctuary badge-neutral font-monospace">@authorDetails.Author.Isni.Value</span>
                                    }
                                    @if (authorDetails.Author.Editable)
                                    {
                                        <button class="btn btn-link p-0 text-muted" @onclick="StartEditIsni" @onclick:stopPropagation><i class="bi bi-pencil-square"></i></button>
                                    }
                                </div>
                            }
                        </div>

                        @if (isEditingImageUrl)
                        {
                            <div class="col-12 mt-4 animate-fade-in" @onclick:stopPropagation>
                                <div class="p-4 bg-surface-low rounded-xl border border-dashed border-primary-subtle shadow-sm">
                                    <label class="form-label small text-muted text-uppercase fw-bold mb-3 d-flex justify-content-between align-items-center">
                                        <span>@L["ModifyAuthorPortrait"]</span>
                                        @if (isLookingUpImage) { <span class="spinner-border spinner-border-sm text-primary"></span> }
                                    </label>
                                    
                                    <div class="input-group shadow-sm rounded-3 overflow-hidden mb-4 border">
                                        <input type="text" class="form-control border-0 py-2 serif" 
                                               placeholder="@L["EnterPortraitUrlPlaceholder"]" 
                                               @bind="editedImageUrl" />
                                        <button class="btn btn-white border-start" type="button" @onclick="LookupImage" disabled="@isLookingUpImage">
                                            <i class="bi bi-magic me-2 text-primary"></i>@L["DiscoverPortrait"]
                                        </button>
                                    </div>

                                    @if (!string.IsNullOrWhiteSpace(editedImageUrl))
                                    {
                                        <div class="mb-4 text-center animate-fade-in">
                                            <p class="small text-muted mb-2 italic">@L["PortraitPreview"]</p>
                                            <div class="preview-circle bg-surface-container mx-auto rounded-circle overflow-hidden shadow-sm border border-4 border-white" style="width: 120px; height: 120px;">
                                                <img src="@editedImageUrl" class="w-100 h-100" style="object-fit: cover;" @onerror="HandlePreviewError" />
                                            </div>
                                        </div>
                                    }

                                    <div class="d-flex gap-2 mt-2">
                                        <button class="btn btn-primary flex-grow-1" @onclick="UpdateImageUrl" disabled="@(string.IsNullOrWhiteSpace(editedImageUrl))">
                                            <i class="bi bi-check2-circle me-2"></i>@L["FinalizePortraitUpdate"]
                                        </button>
                                        <button class="btn btn-outline-secondary" @onclick="CancelEditImageUrl">@L["Discard"]</button>
                                        @if (authorDetails.Author.ImageUri != null && FSharpOption<Uri>.get_IsSome(authorDetails.Author.ImageUri))
                                        {
                                            <button class="btn btn-outline-danger" @onclick="RemoveImageUrl" title="@L["DiscardPortrait"]">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <!-- Works Published Section -->
                <div class="card-sanctuary p-0 overflow-hidden">
                    <div class="px-5 pt-5 pb-4 d-flex justify-content-between align-items-end">
                        <h5 class="serif display-6 mb-0">@L["WorksPublished"]</h5>
                        <div class="badge-sanctuary badge-neutral">@authorDetails.Books.Length @L["BooksInLibrary"]</div>
                    </div>

                    <div class="px-5 pb-5">
                        <div class="table-responsive">
                            <QuickGrid Items="@authorDetails.Books.AsQueryable()" Pagination="@bookPagination" Class="table table-editorial align-middle mb-0">
                                <TemplateColumn Title="@L["Title"]" SortBy="@sortTitle" Class="col-title serif fw-bold">
                                    <a href="/book-view/@context.Id" class="text-decoration-none text-reset d-flex align-items-center gap-3 py-2">
                                        <div class="bg-surface-low rounded p-2" style="width: 40px; height: 55px; display: flex; align-items: center; justify-content: center;">
                                            @if (FSharpOption<Uri>.get_IsSome(context.ImageUrl))
                                            {
                                                <img src="@context.ImageUrl.Value.ToString()" style="max-width: 100%; max-height: 100%; object-fit: contain;" />
                                            }
                                            else
                                            {
                                                <i class="bi bi-journal-text opacity-25"></i>
                                            }
                                        </div>
                                        <span>@context.Title.Value</span>
                                    </a>
                                </TemplateColumn>
                                
                                <PropertyColumn Property="@(b => b.Year.Value)" Title="@L["Year"]" Sortable="true" Class="col-year text-muted" />
                                
                                <TemplateColumn Title="@L["Category"]" Sortable="true" Class="col-category">
                                    <span class="badge-sanctuary badge-neutral" style="font-size: 0.7rem;">@context.MainCategory.Value()</span>
                                </TemplateColumn>
                                
                                <TemplateColumn Title="@L["Availability"]" Sortable="true" Align="Align.End" Class="col-available">
                                    @if (context.Available)
                                    {
                                        <span class="text-success small fw-bold"><i class="bi bi-circle-fill me-2" style="font-size: 0.5rem;"></i>@L["Available"]</span>
                                    }
                                    else
                                    {
                                        <span class="text-danger small fw-bold"><i class="bi bi-circle-fill me-2" style="font-size: 0.5rem;"></i>@L["OnLoan"]</span>
                                    }
                                </TemplateColumn>
                            </QuickGrid>
                        </div>
                        
                        <div class="mt-4 d-flex justify-content-between align-items-center">
                            <div class="small text-muted serif italic">@L["Showing"] @Math.Min(bookPagination.ItemsPerPage, authorDetails.Books.Length) @L["Of"] @authorDetails.Books.Length @L["CatalogedTitles"]</div>
                            <Paginator State="@bookPagination" />
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else if (!isLoading && authorDetails == null)
    {
        <div class="card-sanctuary text-center p-5">
            <i class="bi bi-exclamation-triangle display-4 text-warning mb-3"></i>
            <h4 class="serif">@L["ErrorLoadingAuthor"]</h4>
            <a href="/books-manager" class="btn-sanctuary-outline text-decoration-none d-inline-block mt-3">@L["BackToLibrary"]</a>
        </div>
    }
</div>

@code {
    [Parameter]
    public string AuthorIdStr { get; set; } = "";

    private bool isLoading = true;
    private Details.AuthorDetails? authorDetails;
    private PaginationState bookPagination = new() { ItemsPerPage = 10 };
    private GridSort<Book> sortTitle = GridSort<Book>.ByAscending(b => b.Title.Value);
    
    private string statusMessage = "";
    private string statusClass = "alert-info";

    private bool isEditingName = false;
    private string editedName = "";
    
    private bool isEditingIsni = false;
    private string editedIsni = "";
    private bool acceptInvalidIsni = false;

    private bool isEditingImageUrl = false;
    private string editedImageUrl = "";
    private bool isLookingUpImage = false;

    private async Task LookupImage()
    {
        if (authorDetails == null) return;
        
        isLookingUpImage = true;
        statusMessage = "Looking up author image...";
        statusClass = "alert-info";
        StateHasChanged();

        try
        {
            var result = await AuthorsSearchService.LookupImageUrlByNameAndThumbSizeAsync(authorDetails.Author.Name.Value, FSharpOption<int>.None);
            if (result.IsOk)
            {
                editedImageUrl = result.ResultValue;
                await ShowStatus("Image URL found. Please click 'Apply' to save.", "alert-info");
            }
            else
            {
                await ShowStatus(string.Format(L["LookupError"], result.ErrorValue), "alert-warning");
            }
        }
        catch (Exception ex)
        {
            await ShowStatus(string.Format(L["LookupErrorGeneric"], ex.Message), "alert-danger");
        }
        finally
        {
            isLookingUpImage = false;
        }
    }

    private bool isAuthorSealed => authorDetails != null && authorDetails.Author.Sealed.IsSealed(DateTime.UtcNow);

    private void StartEditImageUrl()
    {
        if (authorDetails != null && authorDetails.Author.Editable)
        {
            CancelAllEdits();
            isEditingImageUrl = true;
            editedImageUrl = authorDetails.Author.ImageUri != null && FSharpOption<Uri>.get_IsSome(authorDetails.Author.ImageUri) 
                ? authorDetails.Author.ImageUri.Value.ToString() 
                : "";
        }
    }

    private void CancelEditImageUrl()
    {
        isEditingImageUrl = false;
    }

    private void CancelAllEdits()
    {
        isEditingName = false;
        isEditingIsni = false;
        isEditingImageUrl = false;
    }

    private async Task UpdateImageUrl()
    {
        if (authorDetails == null) return;
        
        if (string.IsNullOrWhiteSpace(editedImageUrl))
        {
            await RemoveImageUrl();
            return;
        }

        if (!Uri.TryCreate(editedImageUrl, UriKind.Absolute, out var newUri))
        {
            await ShowStatus(L["InvalidUrlFormat"], "alert-danger");
            return;
        }

        try
        {
            statusMessage = "Validating image link...";
            statusClass = "alert-info";
            StateHasChanged();

            // Perform broken link check
            using var client = new HttpClient();
            client.Timeout = TimeSpan.FromSeconds(5);
            // Wikipedia and some sites require a User-Agent
            client.DefaultRequestHeaders.UserAgent.ParseAdd("BlazorBookLibrary/1.0");
            
            using var response = await client.GetAsync(newUri, HttpCompletionOption.ResponseHeadersRead);
            if (!response.IsSuccessStatusCode)
            {
                await ShowStatus(string.Format(L["BrokenLinkError"], response.StatusCode), "alert-danger");
                return;
            }

            var result = await AuthorService.UpdateImageUrlAsync(authorDetails.Author.AuthorId, newUri);
            if (result.IsOk)
            {
                await LoadAuthorDetails();
                isEditingImageUrl = false;
                await ShowStatus(L["ImageUrlUpdated"], "alert-success");
            }
            else
            {
                await ShowStatus(string.Format(L["ErrorUpdatingImage"], result.ErrorValue), "alert-danger");
            }
        }
        catch (Exception ex)
        {
            await ShowStatus(string.Format(L["ErrorUpdatingImageGeneric"], ex.Message), "alert-danger");
        }
    }

    private async Task RemoveImageUrl()
    {
        if (authorDetails == null) return;

        try
        {
            var result = await AuthorService.RemoveImageUrlAsync(authorDetails.Author.AuthorId);
            if (result.IsOk)
            {
                await LoadAuthorDetails();
                isEditingImageUrl = false;
                await ShowStatus(L["ImageCoverRemoved"], "alert-success");
            }
            else
            {
                await ShowStatus(string.Format(L["ErrorRemovingImage"], result.ErrorValue), "alert-danger");
            }
        }
        catch (Exception ex)
        {
            await ShowStatus(string.Format(L["ErrorRemovingImageGeneric"], ex.Message), "alert-danger");
        }
    }

    private async Task StartEditName()
    {
        if (authorDetails != null && authorDetails.Author.Editable)
        {
            isEditingName = true;
            editedName = authorDetails.Author.Name.Value;
        }
        else if (isAuthorSealed)
        {
            await ShowStatus(L["AuthorLockedCannotEdit"], "alert-warning");
        }
    }

    private void CancelEditName()
    {
        isEditingName = false;
    }

    private async Task UpdateName()
    {
        if (authorDetails == null || string.IsNullOrWhiteSpace(editedName) || editedName == authorDetails.Author.Name.Value)
        {
            isEditingName = false;
            return;
        }

        try
        {
            var newName = Name.New(editedName);
            var result = await AuthorService.RenameAsync(authorDetails.Author.AuthorId, newName);
            if (result.IsOk)
            {
                await LoadAuthorDetails();
                isEditingName = false;
                await ShowStatus(L["AuthorNameUpdated"], "alert-success");
            }
            else
            {
                await ShowStatus(string.Format(L["ErrorRenamingAuthor"], result.ErrorValue), "alert-danger");
            }
        }
        catch (Exception ex)
        {
            await ShowStatus(string.Format(L["ErrorUpdatingNameGeneric"], ex.Message), "alert-danger");
        }
    }

    private async Task StartEditIsni()
    {
        if (authorDetails != null && authorDetails.Author.Editable)
        {
            isEditingIsni = true;
            editedIsni = authorDetails.Author.Isni.Value;
            acceptInvalidIsni = authorDetails.Author.Isni.IsInvalidIsni;
        }
        else if (isAuthorSealed)
        {
            await ShowStatus("This author is currently locked. Please unlock (unseal) to edit.", "alert-warning");
        }
    }

    private void CancelEditIsni()
    {
        isEditingIsni = false;
    }

    private async Task UpdateIsni()
    {
        if (authorDetails == null) return;

        Isni newIsni;
        if (string.IsNullOrWhiteSpace(editedIsni))
        {
            newIsni = Isni.NewEmpty();
        }
        else
        {
            var result = Isni.New(editedIsni);
            if (result.IsOk)
            {
                newIsni = result.ResultValue;
            }
            else if (acceptInvalidIsni)
            {
                newIsni = Isni.NewInvalid(editedIsni);
            }
            else
            {
                await ShowStatus(string.Format(L["InvalidIsniValue"], result.ErrorValue) + ". " + L["AcceptInvalidIsniPrompt"], "alert-danger");
                return;
            }
        }

        try
        {
            var result = await AuthorService.UpdateIsniAsync(authorDetails.Author.AuthorId, newIsni);
            if (result.IsOk)
            {
                await LoadAuthorDetails();
                isEditingIsni = false;
                await ShowStatus(L["IsniUpdated"], "alert-success");
            }
            else
            {
                await ShowStatus(string.Format(L["ErrorUpdatingIsni"], result.ErrorValue), "alert-danger");
            }
        }
        catch (Exception ex)
        {
            await ShowStatus(string.Format(L["ErrorUpdatingIsniGeneric"], ex.Message), "alert-danger");
        }
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await UpdateName();
        }
        else if (e.Key == "Escape")
        {
            CancelEditName();
        }
    }


    private async Task DeleteAuthor()
    {
        if (authorDetails == null) return;
        
        bool confirmed = await JSRuntime.InvokeAsync<bool>("confirm", string.Format(L["ConfirmPermanentlyDeleteAuthor"], authorDetails.Author.Name.Value));
        if (!confirmed) return;
        
        try 
        {
            var result = await AuthorService.RemoveAsync(authorDetails.Author.AuthorId);
            if (result.IsOk)
            {
                NavigationManager.NavigateTo("/books-manager");
            }
            else
            {
                await ShowStatus(string.Format(L["ErrorDuringDeletionGeneric"], result.ErrorValue), "alert-danger");
            }
        }
        catch (Exception ex)
        {
            await ShowStatus(string.Format(L["ErrorDuringDeletion"], ex.Message), "alert-danger");
        }
    }

    private async Task ToggleSeal()
    {
        if (authorDetails == null) return;
        
        try
        {
            var result = isAuthorSealed 
                ? await AuthorService.UnsealAsync(authorDetails.Author.AuthorId)
                : await AuthorService.SealAsync(authorDetails.Author.AuthorId);
                
            if (result.IsOk)
            {
                await LoadAuthorDetails();
                await ShowStatus(isAuthorSealed ? L["AuthorProfileLocked"] : L["AuthorProfileUnlocked"], "alert-success");
            }
            else
            {
                await ShowStatus(string.Format(L["ErrorChangingAuthorSealState"], result.ErrorValue), "alert-danger");
            }
        }
        catch (Exception ex)
        {
            await ShowStatus(string.Format(L["ErrorTogglingSealStateGeneric"], ex.Message), "alert-danger");
        }
    }

    private async Task ShowStatus(string message, string cssClass)
    {
        statusMessage = message;

        string type = "info";
        if (cssClass.Contains("success")) type = "success";
        else if (cssClass.Contains("danger")) type = "error";
        else if (cssClass.Contains("warning")) type = "warning";

        await JSRuntime.InvokeVoidAsync("showToast", message, type);
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadAuthorDetails();
    }

    private async Task LoadAuthorDetails()
    {
        isLoading = true;
        try
        {
            if (Guid.TryParse(AuthorIdStr, out var guid))
            {
                var authorId = AuthorId.NewAuthorId(guid);
                var result = await AuthorService.GetAuthorDetailsAsync(authorId);

                if (result.IsOk)
                {
                    authorDetails = result.ResultValue;
                }
            }
        }
        catch (Exception)
        {
            // Error handling can be expanded here
        }
        finally
        {
            isLoading = false;
        }
    }

    private void HandlePreviewError()
    {
        // For preview purposes, we don't necessarily show an error, but we could toast if interested
    }
}

<style>
    .image-edit-badge {
        bottom: 15px;
        right: 15px;
        background: var(--primary);
        color: white;
        width: 42px;
        height: 42px;
        border-radius: 50%;
        display: flex;
        align-items: center;
