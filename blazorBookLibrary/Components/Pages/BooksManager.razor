    private async Task CaptureCoverPhoto()
    {
        if (isIdentifyingCover) return;
        
        isIdentifyingCover = true;
        StateHasChanged();
        
        try
        {
            Console.WriteLine("CaptureCoverPhoto: Starting...");
            // Small delay to ensure UI is stable
            await Task.Delay(300);

            // Capture frame from the video element rendered by BarcodeReader specifically in the cover scanner
            var base64Data = await JSRuntime.InvokeAsync<string>("captureVideoFrame", "#cover-scanner-wrapper video");
            
            if (string.IsNullOrEmpty(base64Data))
            {
                Console.WriteLine("CaptureCoverPhoto: Failed to capture base64Data.");
                await ShowStatus("Failed to capture image from camera.", "warning");
                return;
            }

            Console.WriteLine("CaptureCoverPhoto: Image captured, length: " + base64Data.Length);
            // Extract base64 part
            var base64Content = base64Data.Split(',')[1];
            var mimeType = "image/jpeg";

            Console.WriteLine("CaptureCoverPhoto: Calling TextEmbeddingService...");
            var result = await TextEmbeddingService.GetPartialBookMatchByCoverImage(base64Content, mimeType);
            Console.WriteLine("CaptureCoverPhoto: Service returned. Success: " + result.IsOk);
            
            if (result.IsOk)
            {
                var match = result.ResultValue;

                if (match.IsValidIsbn)
                {
                    newBookIsbn = match.ValidIsbn.Value;
                    await ShowStatus(string.Format(L["IsbnIdentified"], newBookIsbn), "success");
                    showCoverScanner = false;
                }
                else if (match.IsValidTitle)
                {
                    newBookTitle = match.ValidTitle.Value;
                    await ShowStatus(string.Format(L["TitleIdentified"], newBookTitle), "info");
                    showCoverScanner = false;
                }
                else
                {
                    await ShowStatus(L["NoMatchFoundCover"], "warning");
                }
            }
            else
            {
                await ShowStatus($"Identification error: {result.ErrorValue}", "error");
            }
        }
        catch (Exception ex)
        {
            await ShowStatus($"Error during cover capture: {ex.Message}", "error");
        }
        finally
        {
            isIdentifyingCover = false;
            StateHasChanged();
        }
    }

    private async Task HandleBarcodeReceived(BarcodeReceivedEventArgs args)
    {
        if (string.IsNullOrWhiteSpace(args.BarcodeText)) return;

        var scannedText = args.BarcodeText.Trim();
        
        if (Isbn.IsValid(scannedText))
        {
            newBookIsbn = scannedText;
            showScanner = false;
            await JSRuntime.InvokeVoidAsync("playScanSound");
            StateHasChanged();
        }
    }

