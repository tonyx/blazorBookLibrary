            <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
                <div class="modal-content border-0 shadow-lg bg-surface-lowest">
                    <div class="modal-header border-bottom-0 p-4">
                        <h5 class="modal-title serif h3 text-primary">@L["ImportSummaryTitle"]</h5>
                        <button type="button" class="btn-close" @onclick="() => showImportSummaryModal = false"></button>
                    </div>
                    <div class="modal-body p-4 pt-0">
                        <div class="row g-3 mb-4">
                            <div class="col">
                                <div class="p-3 bg-success-subtle rounded-3 text-center border border-success-subtle h-100 d-flex flex-column justify-content-center">
                                    <div class="h3 mb-0 text-success">@lastImportSummary.SuccessCount</div>
                                    <div class="small text-success-emphasis text-uppercase fw-bold" style="font-size: 0.65rem;">@L["Success"]</div>
                                </div>
                            </div>
                            <div class="col">
                                <div class="p-3 bg-danger-subtle rounded-3 text-center border border-danger-subtle h-100 d-flex flex-column justify-content-center">
                                    <div class="h3 mb-0 text-danger">@lastImportSummary.FailureCount</div>
                                    <div class="small text-danger-emphasis text-uppercase fw-bold" style="font-size: 0.65rem;">@L["Failures"]</div>
                                </div>
                            </div>
                            <div class="col">
                                <div class="p-3 bg-warning-subtle rounded-3 text-center border border-warning-subtle h-100 d-flex flex-column justify-content-center">
                                    <div class="h3 mb-0 text-warning-emphasis">@lastImportSummary.DuplicateCount</div>
                                    <div class="small text-warning-emphasis text-uppercase fw-bold" style="font-size: 0.65rem;">@L["Duplicates"]</div>
                                </div>
                            </div>
                            @if (lastImportSummary.InterruptedCount > 0)
                            {
                                <div class="col">
                                    <div class="p-3 bg-secondary-subtle rounded-3 text-center border border-secondary-subtle h-100 d-flex flex-column justify-content-center">
                                        <div class="h3 mb-0 text-secondary">@lastImportSummary.InterruptedCount</div>
                                        <div class="small text-secondary-emphasis text-uppercase fw-bold" style="font-size: 0.65rem;">@L["Interrupted"]</div>
                                    </div>
                                </div>
                            }
                            <div class="col">
                                <div class="p-3 bg-primary-subtle rounded-3 text-center border border-primary-subtle h-100 d-flex flex-column justify-content-center">
                                    <div class="h3 mb-0 text-primary">@lastImportSummary.TotalProcessed</div>
                                    <div class="small text-primary-emphasis text-uppercase fw-bold" style="font-size: 0.65rem;">@L["Total"]</div>
                                </div>
                            </div>
                        </div>

                        <div class="table-responsive rounded-3 border overflow-auto" style="max-height: 400px;">
                            <table class="table table-editorial align-middle mb-0">
                                <thead class="bg-surface-low sticky-top">
                                    <tr>
                                        <th class="small text-uppercase fw-bold p-3">ISBN</th>
                                        <th class="small text-uppercase fw-bold p-3">@L["Title"]</th>
                                        <th class="small text-uppercase fw-bold p-3">@L["Status"]</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var detail in lastImportSummary.Details)
                                    {
                                        <tr>
                                            <td class="p-3 font-monospace small">@detail.Isbn.Value</td>
                                            <td class="p-3">
                                                @if (FSharpOption<string>.get_IsSome(detail.Title))
                                                {
                                                    <span class="text-serif">@detail.Title.Value</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted small italic">@L["MetadataNotFound"]</span>
                                                }
                                            </td>
                                            <td class="p-3">
                                                @if (detail.Status.IsSuccess)
                                                {
                                                    <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill">
                                                        <i class="bi bi-check-circle-fill me-1"></i> @L["Success"]
                                                    </span>
                                                }
                                                else if (detail.Status.IsDuplicate)
                                                {
                                                    <span class="badge bg-warning-subtle text-warning-emphasis border border-warning-subtle rounded-pill">
                                                        <i class="bi bi-intersect me-1"></i> @L["Duplicate"]
                                                    </span>
                                                }
                                                else if (detail.Status.IsInterrupted)
                                                {
                                                    <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle rounded-pill">
                                                        <i class="bi bi-stop-circle-fill me-1"></i> @L["Interrupted"]
                                                    </span>
                                                }
                                                else if (detail.Status is ImportStatus.Failure f)
                                                {
                                                    <span class="badge bg-danger-subtle text-danger border border-danger-subtle rounded-pill" title="@f.reason">
                                                        <i class="bi bi-exclamation-triangle-fill me-1"></i> @L["Failure"]
                                                    </span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="modal-footer border-top-0 p-4 gap-2">
                        <button type="button" class="btn btn-outline-primary flex-grow-1" @onclick="CopyFailedIsbns">
                            <i class="bi bi-clipboard me-2"></i>@L["CopyFailedIsbns"]
                        </button>
                        <button type="button" class="btn btn-sanctuary flex-grow-1" @onclick="() => showImportSummaryModal = false">@L["Close"]</button>
                    </div>
                </div>
            </div>
        </div>
