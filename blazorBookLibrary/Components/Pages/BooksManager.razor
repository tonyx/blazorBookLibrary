@page "/books-manager"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.Extensions.Localization
@using blazorBookLibrary.Shared.Resources
@using BookLibrary.Domain
@using blazorBookLibrary.Components.Shared
@using Microsoft.FSharp.Core
@using Microsoft.FSharp.Collections
@using System.Threading
@using BlazorBarcodeScanner.ZXing.JS
@using static BookLibrary.Shared.Commons
@using BookLibrary.Shared
@using BookLibrary.Utils

@attribute [Authorize(Roles = "Admin, Manager")]
@inject IBookService BookService
@inject IDataExportService DataExportService
@inject IAuthorService AuthorService
@inject IJSRuntime JSRuntime
@inject IGoogleBooksService GoogleBooksService
@inject IAuthorsSearchService AuthorsSearchService
@inject IStringLocalizer<SharedResources> L
@inject IConfiguration Configuration
@inject ITextEmbeddingService TextEmbeddingService
@inject IVectorDbService VectorDbService
@rendermode InteractiveServer

<PageTitle>@L["BooksManager"] — @L["TheModernArchivist"]</PageTitle>

<div class="sanctuary-container py-5">
    @* Page Header *@
    <div class="mb-5">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-muted">@L["Home"]</a></li>
                <li class="breadcrumb-item active text-serif" aria-current="page">@L["BooksManager"]</li>
            </ol>
        </nav>
        <div class="d-flex justify-content-between align-items-end">
            <div>
                <h1 class="display-4 text-serif mb-2">@L["CatalogManagement"]</h1>
                <p class="text-muted lead mb-0">@L["BooksManagerDescription"]</p>
            </div>
            
            <div class="d-flex gap-3">
                <div class="dropdown">
                    <button class="btn btn-outline-sanctuary dropdown-toggle" type="button" id="exportDropdown" data-bs-toggle="dropdown" aria-expanded="false" disabled="@(isExporting || isImporting)">
                        @if (isExporting)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                            @L["Exporting"]
                        }
                        else
                        {
                            <i class="bi bi-download me-2"></i> @L["Export"]
                        }
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0" aria-labelledby="exportDropdown">
                        <li><a class="dropdown-item py-2" href="javascript:void(0)" @onclick="() => ExportBooks(ExportFormat.Json)"><i class="bi bi-filetype-json me-2 text-primary"></i> JSON</a></li>
                        <li><a class="dropdown-item py-2" href="javascript:void(0)" @onclick="() => ExportBooks(ExportFormat.Csv)"><i class="bi bi-filetype-csv me-2 text-success"></i> CSV</a></li>
                    </ul>
                </div>
                
                <div class="dropdown border-start ps-3">
                    <button class="btn btn-outline-sanctuary dropdown-toggle @(isImporting || isExporting ? "disabled" : "")" type="button" id="importDropdown" data-bs-toggle="dropdown" aria-expanded="false" data-bs-auto-close="outside">
                        @if (isImporting)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                            @L["Importing"]
                        }
                        else
                        {
                            <i class="bi bi-file-earmark-arrow-up me-2"></i> @L["Import"]
                        }
                    </button>
                    <div class="dropdown-menu dropdown-menu-end shadow-lg border-0 p-3" aria-labelledby="importDropdown" style="min-width: 280px;">
                        <h6 class="dropdown-header px-0 mb-3 text-primary fw-bold border-bottom pb-2">
                            <i class="bi bi-gear-fill me-2"></i>@L["ImportSettings"]
                        </h6>
                        
                        <div class="form-check form-switch mb-3">
                            <input class="form-check-input" type="checkbox" id="allowDuplicatesSwitch" @bind="importAllowDuplicates">
                            <label class="form-check-label small fw-bold" for="allowDuplicatesSwitch">@L["AllowDuplicates"]</label>
                            <div class="form-text mt-0 small opacity-75">@L["AllowDuplicatesHelp"]</div>
                        </div>
                        
                        <div class="form-check form-switch mb-3">
                            <input class="form-check-input" type="checkbox" id="generateAuthorsSwitch" @bind="importGenerateAuthors">
                            <label class="form-check-label small fw-bold" for="generateAuthorsSwitch">@L["GenerateUnknownAuthors"]</label>
                            <div class="form-text mt-0 small opacity-75">@L["GenerateAuthorsHelp"]</div>
                        </div>
                        
                        <div class="form-check form-switch mb-3">
                            <input class="form-check-input" type="checkbox" id="generateDescriptionsSwitch" @bind="importGenerateMissingDescriptions">
                            <label class="form-check-label small fw-bold" for="generateDescriptionsSwitch">@L["GenerateMissingDescriptions"]</label>
                            <div class="form-text mt-0 small opacity-75">@L["GenerateDescriptionsHelp"]</div>
                        </div>
                        
                        <div class="form-check form-switch mb-4">
                            <input class="form-check-input" type="checkbox" id="generateEmbeddingsSwitch" @bind="importGenerateEmbeddings">
                            <label class="form-check-label small fw-bold" for="generateEmbeddingsSwitch">@L["GenerateEmbeddings"]</label>
                            <div class="form-text mt-0 small opacity-75">@L["GenerateEmbeddingsHelp"]</div>
                        </div>
                        
                        <div class="pt-2">
                            <label for="importFileInput" class="btn btn-sanctuary w-100 mb-0 shadow-sm py-2">
                                <i class="bi bi-file-earmark-arrow-up me-2"></i> @L["SelectFileAndImport"]
                            </label>
                        </div>
                    </div>
                </div>
                <InputFile id="importFileInput" OnChange="HandleImportFile" style="display:none" accept=".txt,.csv" />
                
                <button class="btn btn-sanctuary @(showAddSection ? "active" : "")" @onclick="() => showAddSection = !showAddSection">
                    <i class="bi @(showAddSection ? "bi-dash-lg" : "bi-plus-lg") me-2"></i>
                    @(showAddSection ? L["CloseEntryForm"] : L["AddNewBookEntry"])
                </button>
            </div>
        </div>
    </div>
    
    @if (isImporting && currentProgress != null)
    {
        <div class="card card-sanctuary mb-5 p-4 border-0 shadow-sm bg-surface-low animate-fade-in">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <div>
                    <span class="text-muted fw-bold">@L["ImportProgress"]: @currentProgress.Current / @currentProgress.Total</span>
                    @if (importCts != null && importCts.IsCancellationRequested)
                    {
                        <span class="badge bg-warning text-dark ms-2">@L["Cancelling"]...</span>
                    }
                </div>
                <div class="d-flex align-items-center gap-3">
                    @if (FSharpOption<TimeSpan>.get_IsSome(currentProgress.EstimatedRemainingTime))
                    {
                        <span class="text-primary small fw-bold">
                            <i class="bi bi-clock-history me-1"></i>
                            @L["EstimatedTimeRemaining"]: @FormatTimeSpan(currentProgress.EstimatedRemainingTime.Value)
                        </span>
                    }
                    <button class="btn btn-outline-danger btn-sm rounded-pill px-3" @onclick="CancelImport" disabled="@(importCts == null || importCts.IsCancellationRequested)">
                        <i class="bi bi-x-circle me-1"></i> @L["Cancel"]
                    </button>
                </div>
            </div>
            <div class="progress" style="height: 10px; border-radius: 5px; background-color: var(--surface-high);">
                <div class="progress-bar progress-bar-striped progress-bar-animated bg-sanctuary" 
                     role="progressbar" 
                     style="width: @(GetProgressPercentage())%; transition: width 0.3s ease;">
                </div>
            </div>
            @if (FSharpOption<string>.get_IsSome(currentProgress.CurrentItemLabel))
            {
                <div class="mt-2 text-muted small italic animate-fade-in">
                    <i class="bi bi-info-circle me-1"></i> @currentProgress.CurrentItemLabel.Value
                </div>
            }
        </div>
    }

    @* Search & Filter Toolbar *@
    <div class="card-sanctuary mb-5 p-4 border-0 shadow-none bg-surface-low">
        <BookSearchToolbar OnSearchResultsFound="HandleSearchResultsFound" OnError="ShowSearchError" OnSearchStarted="HandleSearchStarted" />
    </div>

    @if (searchBooksPerformed)
    {
        <div class="mb-5 animate-fade-in">
            <div class="card-sanctuary p-0 overflow-hidden">
                <div class="px-4 py-4 bg-surface-container d-flex justify-content-between align-items-center border-bottom">
                    <div class="d-flex align-items-center gap-3">
                        <h2 class="h4 text-serif mb-0">@L["SearchResults"]</h2>
                        <span class="badge-sanctuary badge-neutral">@foundBooks.Count @L["BooksFound"]</span>
                        
                        @if (selectedBookIds.Count > 0)
                        {
                            <button class="btn btn-primary btn-sm rounded-pill px-4 ms-3 animate-slide-in" @onclick="EnableBulkEdit">
                                <i class="bi bi-pencil-square me-2"></i> @L["BulkEdit"] (@selectedBookIds.Count)
                            </button>
                        }
                    </div>
                </div>

                <div class="table-responsive">
                    <QuickGrid Items="@FilteredBooks" Pagination="@bookPagination" Class="editorial-ledger w-100 align-middle">
                        <TemplateColumn Title="@L["Select"]" Align="Align.Center" Class="col-select">
                            <div class="form-check d-inline-block">
                                <input type="checkbox" class="form-check-input" 
                                       checked="@selectedBookIds.Contains(context.Book.BookId)" 
                                       @onchange="@(e => ToggleBookSelection(context.Book.BookId, e.Value))" />
                            </div>
                        </TemplateColumn>
                        
                        <TemplateColumn Title="@L["Title"]" SortBy="@sortTitle" Class="col-title text-serif fw-bold h5">
                            <ColumnOptions>
                                <div class="p-3 bg-surface-low rounded-3 border shadow-sm" style="min-width: 300px;">
                                    <div class="input-group input-group-sm">
                                        <span class="input-group-text bg-transparent border-end-0 text-muted"><i class="bi bi-filter"></i></span>
                                        <input type="search" autofocus @bind="titleRefinementFilter" @bind:event="oninput" 
                                               placeholder="@L["RefineResultsByTitlePlaceholder"]" 
                                               class="form-control border-start-0 ps-0" />
                                    </div>
                                </div>
                            </ColumnOptions>
                            <ChildContent>
                                <a href="/book-edit/@context.Book.Id" class="text-decoration-none text-reset transition-hover py-2 d-block">
                                    @context.Book.Title.Value
                                </a>
                            </ChildContent>
                        </TemplateColumn>

                        @if (foundBooks.Any(b => FSharpOption<double>.get_IsSome(b.Score)))
                        {
                            <TemplateColumn Title="@L["Match"]" SortBy="@sortScore" Class="col-score text-primary small fw-bold">
                                @if (FSharpOption<double>.get_IsSome(context.Score))
                                {
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="progress flex-grow-1" style="height: 4px; width: 40px; background-color: var(--surface-high);">
                                            <div class="progress-bar bg-primary" style="width: @((context.Score.Value * 100).ToString("F0"))%"></div>
                                        </div>
                                        <span>@((context.Score.Value * 100).ToString("F1"))%</span>
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted opacity-50">-</span>
                                }
                            </TemplateColumn>
                        }

                        <TemplateColumn Title="@L["Status"]" Align="Align.Center">
                            @if (context.Book.ImageUrl != null && FSharpOption<Uri>.get_IsSome(context.Book.ImageUrl))
                            {
                                <span class="text-success" title="@L["RecordHasImage"]"><i class="bi bi-image-fill"></i></span>
                            }
                            else
                            {
                                <span class="text-muted opacity-25" title="@L["RecordMissingImage"]"><i class="bi bi-image"></i></span>
                            }
                        </TemplateColumn>

                        <PropertyColumn Property="@(b => b.Book.Year.Value)" Title="@L["Year"]" Sortable="true" Class="col-year text-muted small px-3" />
                        
                        <TemplateColumn Title="@L["EditorialTaxonomy"]" SortBy=@sortTaxonomy Class="col-category small">
                            <span class="badge-sanctuary badge-neutral">@context.Book.MainCategory.Value()</span>
                        </TemplateColumn>

                        <TemplateColumn Title="@L["ArchivalStatus"]" SortBy=@sortAvailability Align="Align.End" Class="col-available pe-5">
                            @if (context.Book.AvailabilityStatus == BookLibrary.Shared.Commons.AvailabilityStatus.Available)
                            {
                                <span class="text-success small fw-bold"><i class="bi bi-check-circle-fill me-2" style="font-size: 0.5rem;"></i>@L["Available"]</span>
                            }
                            else if (context.Book.AvailabilityStatus == BookLibrary.Shared.Commons.AvailabilityStatus.Reserved)
                            {
                                <span class="text-warning small fw-bold"><i class="bi bi-circle-fill me-2" style="font-size: 0.5rem;"></i>@L["Reserved"]</span>
                            }
                            else if (context.Book.AvailabilityStatus == BookLibrary.Shared.Commons.AvailabilityStatus.NotAvailable)
                            {
                                <span class="text-danger small fw-bold"><i class="bi bi-circle-fill me-2" style="font-size: 0.5rem;"></i>@L["NotAvailable"]</span>
                            }
                            else if (context.Book.AvailabilityStatus == BookLibrary.Shared.Commons.AvailabilityStatus.Consultable)
                            {
                                <span class="text-info small fw-bold"><i class="bi bi-circle-fill me-2" style="font-size: 0.5rem;"></i>@L["Consultable"]</span>
                            }
                            else 
                            {
                                <span class="text-muted small fw-bold"><i class="bi bi-circle-fill me-2" style="font-size: 0.5rem;"></i>@L["Unspecified"]</span>
                            }
                        </TemplateColumn>
                    </QuickGrid>
                </div>
                
                <div class="px-4 py-3 bg-surface-container border-top d-flex justify-content-between align-items-center">
                    <div class="small text-muted serif italic">@L["Showing"] @FilteredBooks.Count() @L["Records"]</div>
                    <Paginator State="@bookPagination" />
                </div>
            </div>
        </div>
    }

    @if (showBulkEdit && selectedBookIds.Count > 0)
    {
        <div class="mb-5 animate-fade-in">
            <div class="card-sanctuary p-4 bg-surface-low border-primary-subtle border">
                <BulkEditComponent BookIds="@selectedBookIds.ToList()" OnCancel="() => showBulkEdit = false" OnSuccess="HandleBulkEditSuccess" />
            </div>
        </div>
    }

    @* Add New Book Entry Section *@
    @if (showAddSection)
    {
        <div class="row g-5 mb-5 animate-slide-up">
            <div class="col-lg-8">
                <div class="card-sanctuary p-5">
                    <div class="border-bottom pb-4 mb-4">
                        <h2 class="display-6 text-serif mb-2">@L["NewArchivalRegistration"]</h2>
                        <p class="text-muted">@L["CompleteTheFormBelowToRegister"]</p>
                    </div>

                    <EditForm Model="@this" OnValidSubmit="HandleAddBook" FormName="AddBookForm">
                        <div class="row g-4">
                            @* Title Lookup Section *@
                            <div class="col-12">
                                <label class="form-label small text-muted text-uppercase fw-bold mb-2">@L["PrimaryTitle"]</label>
                                <div class="input-group input-group-lg shadow-sm rounded-3 overflow-hidden border">
                                    <InputText class="form-control border-0 serif fw-bold bg-surface-low" 
                                               @bind-Value="newBookTitle" 
                                               placeholder="@L["EnterTitleToSearchPlaceholder"]" />
                                    <button type="button" class="btn btn-white border-start px-4" 
                                            @onclick="PerformGoogleLookup" disabled="@isAutofilling">
                                        @if (isAutofilling) { <span class="spinner-border spinner-border-sm me-2"></span> }
                                        <i class="bi bi-search me-2"></i> @L["SearchApi"]
                                    </button>
                                </div>
                            </div>

                            @if (lookupResults.Any())
                            {
                                <div class="col-12 animate-fade-in">
                                    <div class="p-4 bg-surface-low rounded-3 border border-primary-subtle shadow-sm">
                                        <label class="form-label small fw-bold text-primary mb-3">@L["SelectFromResultToPopulate"]</label>
                                        <div class="input-group">
                                            <select class="form-select border-primary-subtle serif" @bind="selectedLookupIndex">
                                                <option value="-1">@L["SelectABook"]</option>
                                                @for (int i = 0; i < lookupResults.Count; i++)
                                                {
                                                    var book = lookupResults[i];
                                                    var yearText = FSharpOption<int>.get_IsSome(book.Year) ? $" ({book.Year.Value})" : "";
                                                    var authorsText = book.Authors.Any() ? $" by {string.Join(", ", book.Authors)}" : "";
                                                    <option value="@i">@book.Title @yearText@authorsText</option>
                                                }
                                            </select>
                                            <button type="button" class="btn btn-primary px-4" @onclick="AutofillFromSelected" disabled="@(selectedLookupIndex < 0)">
                                                <i class="bi bi-magic me-2"></i> @L["AutofillFields"]
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }

                            @* ISBN & Scanner *@
                            <div class="col-md-7">
                                <label class="form-label small text-muted text-uppercase fw-bold mb-2">@L["IsbnIdentifier"]</label>
                                <div class="input-group shadow-sm rounded-3 overflow-hidden border">
                                    <span class="input-group-text bg-surface-low border-0"><i class="bi bi-upc-scan"></i></span>
                                    <InputText @ref="isbnInput" class="form-control border-0 font-monospace" 
                                               @bind-Value="newBookIsbn" 
                                               placeholder="@L["IsbnExamplePlaceholder"]" />
                                    <button type="button" class="btn btn-white border-start" @onclick="ToggleScanner" title="@L["BarCodeScan"]">
                                        <i class="bi bi-upc-scan text-primary"></i>
                                    </button>
                                    <button type="button" class="btn btn-white border-start" @onclick="ToggleCoverScanner" title="@L["CoverScan"]">
                                        <i class="bi bi-camera text-primary"></i>
                                    </button>
                                    <button type="button" class="btn btn-white border-start text-primary" @onclick="LookupMetadataByIsbn" disabled="@(!IsNewBookIsbnValid || isLookingUpMetadata)">
                                        <i class="bi bi-search"></i>
                                    </button>
                                </div>
                                <div class="form-check form-switch mt-2 small">
                                    <InputCheckbox class="form-check-input" @bind-Value="allowInvalidIsbn" id="invalidIsbnSwitch" />
                                    <label class="form-check-label text-muted" for="invalidIsbnSwitch">@L["AcceptInvalidIsbn"]</label>
                                </div>
                            </div>

                            @* Publication Year *@
                            <div class="col-md-5">
                                <label class="form-label small text-muted text-uppercase fw-bold mb-2">@L["PublicationYear"]</label>
                                <InputNumber class="form-control bg-surface-low border-0 py-2 shadow-sm" @bind-Value="newBookYear" placeholder="YYYY" />
                            </div>

                            @* Cover Image Section *@
                            <div class="col-12">
                                <label class="form-label small text-muted text-uppercase fw-bold mb-2">@L["ArchivalCoverImage"]</label>
                                <div class="input-group shadow-sm rounded-3 overflow-hidden border">
                                    <span class="input-group-text bg-surface-low border-0"><i class="bi bi-image"></i></span>
                                    <InputText class="form-control border-0 serif" 
                                               @bind-Value="newBookImageUrl" 
                                               placeholder="@L["PasteImageUrl"]" />
                                    <button type="button" class="btn btn-white border-start d-flex align-items-center gap-2" @onclick="LookupCover" disabled="@(isLookingUpCover || (string.IsNullOrWhiteSpace(newBookTitle) && !IsNewBookIsbnValid))">
                                        @if (isLookingUpCover) { <span class="spinner-border spinner-border-sm text-primary"></span> }
                                        <select class="form-select form-select-sm border-0 bg-transparent py-0" @bind="coverSizeLookup" style="width: auto;" @onclick:stopPropagation>
                                            <option value="Small">S</option>
                                            <option value="Medium">M</option>
                                            <option value="Large">L</option>
                                        </select>
                                        <i class="bi bi-magic text-primary"></i>@L["DiscoverCover"]
                                    </button>
                                </div>

                                @if (coverPreviewUrl != null)
                                {
                                    <div class="mt-4 p-4 bg-surface-low rounded-3 border border-primary-subtle shadow-sm animate-fade-in text-center">
                                        <p class="small text-muted mb-3 italic">@L["DiscoveredCoverPreview"]</p>
                                        <div class="preview-rect bg-white mx-auto overflow-hidden shadow-sm border border-4 border-white" style="width: 120px; height: 170px;">
                                            <img src="@coverPreviewUrl" class="w-100 h-100" style="object-fit: contain;" />
                                        </div>
                                        <div class="d-flex gap-2 justify-content-center mt-3">
                                            <button type="button" class="btn btn-primary btn-sm px-4" @onclick="AcceptLookup">@L["UseThisCover"]</button>
                                            <button type="button" class="btn btn-outline-secondary btn-sm px-4" @onclick="DiscardLookup">@L["Discard"]</button>
                                        </div>
                                    </div>
                                }
                                else if (!string.IsNullOrWhiteSpace(newBookImageUrl))
                                {
                                    <div class="mt-3 text-center">
                                        <div class="preview-rect bg-white mx-auto shadow-sm border border-2 border-white rounded" style="width: 80px; height: 110px; overflow: hidden;">
                                            <img src="@newBookImageUrl" class="w-100 h-100" style="object-fit: contain;" />
                                        </div>
                                    </div>
                                }
                            </div>

                            @if (showScanner)
                            {
                                <div class="col-12 animate-fade-in mt-2">
                                    <div class="barcode-scanner-container p-4 bg-dark rounded-4 shadow-lg text-white">
                                        <div class="d-flex justify-content-between align-items-center mb-3">
                                            <h6 class="mb-0 text-primary text-serif"><i class="bi bi-camera-fill me-2"></i>@L["ArchivalScannerActive"]</h6>
                                            <button type="button" class="btn btn-link text-white p-0" @onclick="ToggleScanner">@L["Close"]</button>
                                        </div>
                                        <div class="scanner-preview-wrapper rounded-3 overflow-hidden position-relative bg-black" style="min-height: 300px;">
                                            <BarcodeReader 
                                                OnBarcodeReceived="HandleBarcodeReceived" 
                                                Title=""
                                                StartCameraAutomatically="true"
                                                ShowStart="false"
                                                ShowReset="false"
                                                ShowVideoDeviceList="true"
                                            />
                                            <div class="scanner-overlay border-0">
                                                <div class="scanner-laser border-primary"></div>
                                            </div>
                                        </div>
                                        <p class="small text-muted mt-3 text-center mb-0 serif italic">@L["PositionBarcodeInsideFrameNote"]</p>
                                    </div>
                                </div>
                            }

                            @if (showCoverScanner)
                            {
                                <div class="col-12 animate-fade-in mt-2">
                                    <div class="barcode-scanner-container p-4 bg-dark rounded-4 shadow-lg text-white">
                                        <div class="d-flex justify-content-between align-items-center mb-3">
                                            <h6 class="mb-0 text-primary text-serif"><i class="bi bi-journal-medical me-2"></i>@L["CoverScannerActive"]</h6>
                                            <button type="button" class="btn btn-link text-white p-0" @onclick="ToggleCoverScanner">@L["Close"]</button>
                                        </div>
                                        <div id="cover-scanner-wrapper" class="scanner-preview-wrapper rounded-3 overflow-hidden position-relative bg-black" style="min-height: 300px;">
                                            <BarcodeReader 
                                                OnBarcodeReceived="(args) => { }" 
                                                Title=""
                                                StartCameraAutomatically="true"
                                                ShowStart="false"
                                                ShowReset="false"
                                                ShowVideoDeviceList="true"
                                            />
                                            <div class="d-flex justify-content-center position-absolute bottom-0 w-100 p-4" style="z-index: 10;">
                                                <button type="button" class="btn btn-primary btn-lg rounded-pill px-5 shadow-lg" @onclick="CaptureCoverPhoto" disabled="@isIdentifyingCover">
                                                    @if (isIdentifyingCover)
                                                    {
                                                        <span class="spinner-border spinner-border-sm me-2"></span>
                                                        @L["IdentifyingCover"]
                                                    }
                                                    else
                                                    {
                                                        <i class="bi bi-camera-fill me-2"></i> @L["CaptureCoverPhoto"]
                                                    }
                                                </button>
                                            </div>
                                        </div>
                                        <p class="small text-muted mt-3 text-center mb-0 serif italic">@L["PositionCoverInsideFrameNote"]</p>
                                    </div>
                                </div>
                            }

                             @* Description / Narrative Abstract *@
                             <div class="col-12">
                                 <div class="d-flex justify-content-between align-items-end mb-2">
                                     <label class="form-label small text-muted text-uppercase fw-bold mb-0">@L["NarrativeAbstract"]</label>
                                     <div class="d-flex gap-2">
                                         @if (previousDescriptionBuffer != null)
                                         {
                                             <button type="button" class="btn btn-link btn-sm text-decoration-none p-0 animate-fade-in" @onclick="UndoDescription" title="@L["UndoLastDescriptionChange"]">
                                                 <i class="bi bi-arrow-counterclockwise me-1"></i> @L["Undo"]
                                             </button>
                                         }
