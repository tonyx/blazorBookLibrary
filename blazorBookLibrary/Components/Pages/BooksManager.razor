@page "/books-manager"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.Extensions.Localization
@using blazorBookLibrary.Shared.Resources
@using BookLibrary.Domain
@using blazorBookLibrary.Components.Shared
@using Microsoft.FSharp.Core
@using Microsoft.FSharp.Collections
@using System.Threading
@using BlazorBarcodeScanner.ZXing.JS
@using static BookLibrary.Shared.Commons
@using BookLibrary.Utils

@attribute [Authorize(Roles = "Admin, Manager")]
@inject IBookService BookService
@inject IDataExportService DataExportService
@inject IAuthorService AuthorService
@inject IJSRuntime JSRuntime
@inject IGoogleBooksService GoogleBooksService
@inject IAuthorsSearchService AuthorsSearchService
@inject IStringLocalizer<SharedResources> L
@inject IConfiguration Configuration
@rendermode InteractiveServer

<PageTitle>@L["BooksManager"] — @L["TheModernArchivist"]</PageTitle>

<div class="sanctuary-container py-5">
    @* Page Header *@
    <div class="mb-5">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-muted">@L["Home"]</a></li>
                <li class="breadcrumb-item active text-serif" aria-current="page">@L["BooksManager"]</li>
            </ol>
        </nav>
        <div class="d-flex justify-content-between align-items-end">
            <div>
                <h1 class="display-4 text-serif mb-2">@L["CatalogManagement"]</h1>
                <p class="text-muted lead mb-0">@L["BooksManagerDescription"]</p>
            </div>
            
            <div class="d-flex gap-3">
                <div class="dropdown">
                    <button class="btn btn-outline-sanctuary dropdown-toggle" type="button" id="exportDropdown" data-bs-toggle="dropdown" aria-expanded="false" disabled="@(isExporting || isImporting)">
                        @if (isExporting)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                            @L["Exporting"]
                        }
                        else
                        {
                            <i class="bi bi-download me-2"></i> @L["Export"]
                        }
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0" aria-labelledby="exportDropdown">
                        <li><a class="dropdown-item py-2" href="javascript:void(0)" @onclick="() => ExportBooks(ExportFormat.Json)"><i class="bi bi-filetype-json me-2 text-primary"></i> JSON</a></li>
                        <li><a class="dropdown-item py-2" href="javascript:void(0)" @onclick="() => ExportBooks(ExportFormat.Csv)"><i class="bi bi-filetype-csv me-2 text-success"></i> CSV</a></li>
                    </ul>
                </div>
                
                <div class="d-flex align-items-center gap-3 border-start ps-3 me-1">
                    <div class="form-check form-switch mb-0" style="font-size: 0.7rem;">
                        <input class="form-check-input" type="checkbox" id="allowDuplicatesSwitch" @bind="importAllowDuplicates">
                        <label class="form-check-label text-muted" for="allowDuplicatesSwitch">@L["AllowDuplicates"]</label>
                    </div>
                    <div class="form-check form-switch mb-0" style="font-size: 0.7rem;">
                        <input class="form-check-input" type="checkbox" id="generateAuthorsSwitch" @bind="importGenerateAuthors">
                        <label class="form-check-label text-muted" for="generateAuthorsSwitch">@L["GenerateUnknownAuthors"]</label>
                    </div>
                    <div class="form-check form-switch mb-0" style="font-size: 0.7rem;">
                        <input class="form-check-input" type="checkbox" id="generateEmbeddingsSwitch" @bind="importGenerateEmbeddings">
                        <label class="form-check-label text-muted" for="generateEmbeddingsSwitch">@L["GenerateEmbeddings"]</label>
                    </div>
                </div>

                <label for="importFileInput" class="btn btn-outline-sanctuary mb-0 @(isImporting || isExporting ? "disabled" : "")">
                    @if (isImporting)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                        @L["Importing"]
                    }
                    else
                    {
                        <i class="bi bi-file-earmark-arrow-up me-2"></i> @L["Import"]
                    }
                </label>
                <InputFile id="importFileInput" OnChange="HandleImportFile" style="display:none" accept=".txt,.csv" />
                
                <button class="btn btn-sanctuary @(showAddSection ? "active" : "")" @onclick="() => showAddSection = !showAddSection">
                    <i class="bi @(showAddSection ? "bi-dash-lg" : "bi-plus-lg") me-2"></i>
                    @(showAddSection ? L["CloseEntryForm"] : L["AddNewBookEntry"])
                </button>
            </div>
        </div>
    </div>
    
    @if (isImporting && currentProgress != null)
    {
        <div class="card card-sanctuary mb-5 p-4 border-0 shadow-sm bg-surface-low animate-fade-in">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <span class="text-muted fw-bold">@L["ImportProgress"]: @currentProgress.Current / @currentProgress.Total</span>
                @if (FSharpOption<TimeSpan>.get_IsSome(currentProgress.EstimatedRemainingTime))
                {
                    <span class="text-primary small fw-bold">
                        <i class="bi bi-clock-history me-1"></i>
                        @L["EstimatedTimeRemaining"]: @FormatTimeSpan(currentProgress.EstimatedRemainingTime.Value)
                    </span>
                }
            </div>
            <div class="progress" style="height: 10px; border-radius: 5px; background-color: var(--surface-high);">
                <div class="progress-bar progress-bar-striped progress-bar-animated bg-sanctuary" 
                     role="progressbar" 
                     style="width: @(GetProgressPercentage())%; transition: width 0.3s ease;">
                </div>
            </div>
        </div>
    }

    @* Search & Filter Toolbar *@
    <div class="card-sanctuary mb-5 p-4 border-0 shadow-none bg-surface-low">
        <BookSearchToolbar OnSearchResultsFound="HandleSearchResultsFound" OnError="ShowSearchError" OnSearchStarted="HandleSearchStarted" />
    </div>

    @if (searchBooksPerformed)
    {
        <div class="mb-5 animate-fade-in">
            <div class="card-sanctuary p-0 overflow-hidden">
                <div class="px-4 py-4 bg-surface-container d-flex justify-content-between align-items-center border-bottom">
                    <div class="d-flex align-items-center gap-3">
                        <h2 class="h4 text-serif mb-0">@L["SearchResults"]</h2>
                        <span class="badge-sanctuary badge-neutral">@foundBooks.Count @L["BooksFound"]</span>
                        
                        @if (selectedBookIds.Count > 0)
                        {
                            <button class="btn btn-primary btn-sm rounded-pill px-4 ms-3 animate-slide-in" @onclick="EnableBulkEdit">
                                <i class="bi bi-pencil-square me-2"></i> @L["BulkEdit"] (@selectedBookIds.Count)
                            </button>
                        }
                    </div>
                </div>

                <div class="table-responsive">
                    <QuickGrid Items="@FilteredBooks" Pagination="@bookPagination" Class="editorial-ledger w-100 align-middle">
                        <TemplateColumn Title="@L["Select"]" Align="Align.Center" Class="col-select">
                            <div class="form-check d-inline-block">
                                <input type="checkbox" class="form-check-input" 
                                       checked="@selectedBookIds.Contains(context.BookId)" 
                                       @onchange="@(e => ToggleBookSelection(context.BookId, e.Value))" />
                            </div>
                        </TemplateColumn>
                        
                        <TemplateColumn Title="@L["Title"]" SortBy="@sortTitle" Class="col-title text-serif fw-bold h5">
                            <ColumnOptions>
                                <div class="p-3 bg-surface-low rounded-3 border shadow-sm" style="min-width: 300px;">
                                    <div class="input-group input-group-sm">
                                        <span class="input-group-text bg-transparent border-end-0 text-muted"><i class="bi bi-filter"></i></span>
                                        <input type="search" autofocus @bind="titleRefinementFilter" @bind:event="oninput" 
                                               placeholder="@L["RefineResultsByTitlePlaceholder"]" 
                                               class="form-control border-start-0 ps-0" />
                                    </div>
                                </div>
                            </ColumnOptions>
                            <ChildContent>
                                <a href="/book-edit/@context.Id" class="text-decoration-none text-reset transition-hover py-2 d-block">
                                    @context.Title.Value
                                </a>
                            </ChildContent>
                        </TemplateColumn>

                        <TemplateColumn Title="@L["Status"]" Align="Align.Center">
                            @if (context.ImageUrl != null && FSharpOption<Uri>.get_IsSome(context.ImageUrl))
                            {
                                <span class="text-success" title="@L["RecordHasImage"]"><i class="bi bi-image-fill"></i></span>
                            }
                            else
                            {
                                <span class="text-muted opacity-25" title="@L["RecordMissingImage"]"><i class="bi bi-image"></i></span>
                            }
                        </TemplateColumn>

                        <PropertyColumn Property="@(b => b.Year.Value)" Title="@L["Year"]" Sortable="true" Class="col-year text-muted small px-3" />
                        
                        <TemplateColumn Title="@L["EditorialTaxonomy"]" SortBy=@sortTaxonomy Class="col-category small">
                            <span class="badge-sanctuary badge-neutral">@context.MainCategory.Value()</span>
                        </TemplateColumn>

                        <TemplateColumn Title="@L["ArchivalStatus"]" SortBy=@sortAvailability Align="Align.End" Class="col-available pe-5">
                            @if (context.AvailabilityStatus == BookLibrary.Shared.Commons.AvailabilityStatus.Available)
                            {
                                <span class="text-success small fw-bold"><i class="bi bi-check-circle-fill me-2" style="font-size: 0.5rem;"></i>@L["Available"]</span>
                            }
                            else if (context.AvailabilityStatus == BookLibrary.Shared.Commons.AvailabilityStatus.Reserved)
                            {
                                <span class="text-warning small fw-bold"><i class="bi bi-circle-fill me-2" style="font-size: 0.5rem;"></i>@L["Reserved"]</span>
                            }
                            else if (context.AvailabilityStatus == BookLibrary.Shared.Commons.AvailabilityStatus.NotAvailable)
                            {
                                <span class="text-danger small fw-bold"><i class="bi bi-circle-fill me-2" style="font-size: 0.5rem;"></i>@L["NotAvailable"]</span>
                            }
                            else if (context.AvailabilityStatus == BookLibrary.Shared.Commons.AvailabilityStatus.Consultable)
                            {
                                <span class="text-info small fw-bold"><i class="bi bi-circle-fill me-2" style="font-size: 0.5rem;"></i>@L["Consultable"]</span>
                            }
                            else 
                            {
                                <span class="text-muted small fw-bold"><i class="bi bi-circle-fill me-2" style="font-size: 0.5rem;"></i>@L["Unspecified"]</span>
                            }
                        </TemplateColumn>
                    </QuickGrid>
                </div>
                
                <div class="px-4 py-3 bg-surface-container border-top d-flex justify-content-between align-items-center">
                    <div class="small text-muted serif italic">@L["Showing"] @FilteredBooks.Count() @L["Records"]</div>
                    <Paginator State="@bookPagination" />
                </div>
            </div>
        </div>
    }

    @if (showBulkEdit && selectedBookIds.Count > 0)
    {
        <div class="mb-5 animate-fade-in">
            <div class="card-sanctuary p-4 bg-surface-low border-primary-subtle border">
                <BulkEditComponent BookIds="@selectedBookIds.ToList()" OnCancel="() => showBulkEdit = false" OnSuccess="HandleBulkEditSuccess" />
            </div>
        </div>
    }

    @* Add New Book Entry Section *@
    @if (showAddSection)
    {
        <div class="row g-5 mb-5 animate-slide-up">
            <div class="col-lg-8">
                <div class="card-sanctuary p-5">
                    <div class="border-bottom pb-4 mb-4">
                        <h2 class="display-6 text-serif mb-2">@L["NewArchivalRegistration"]</h2>
                        <p class="text-muted">@L["CompleteTheFormBelowToRegister"]</p>
                    </div>

                    <EditForm Model="@this" OnValidSubmit="HandleAddBook" FormName="AddBookForm">
                        <div class="row g-4">
                            @* Title Lookup Section *@
                            <div class="col-12">
                                <label class="form-label small text-muted text-uppercase fw-bold mb-2">@L["PrimaryTitle"]</label>
                                <div class="input-group input-group-lg shadow-sm rounded-3 overflow-hidden border">
                                    <InputText class="form-control border-0 serif fw-bold bg-surface-low" 
                                               @bind-Value="newBookTitle" 
                                               placeholder="@L["EnterTitleToSearchPlaceholder"]" />
                                    <button type="button" class="btn btn-white border-start px-4" 
                                            @onclick="PerformGoogleLookup" disabled="@isAutofilling">
                                        @if (isAutofilling) { <span class="spinner-border spinner-border-sm me-2"></span> }
                                        <i class="bi bi-search me-2"></i> @L["SearchApi"]
                                    </button>
                                </div>
                            </div>

                            @if (lookupResults.Any())
                            {
                                <div class="col-12 animate-fade-in">
                                    <div class="p-4 bg-surface-low rounded-3 border border-primary-subtle shadow-sm">
                                        <label class="form-label small fw-bold text-primary mb-3">@L["SelectFromResultToPopulate"]</label>
                                        <div class="input-group">
                                            <select class="form-select border-primary-subtle serif" @bind="selectedLookupIndex">
                                                <option value="-1">@L["SelectABook"]</option>
                                                @for (int i = 0; i < lookupResults.Count; i++)
                                                {
                                                    var book = lookupResults[i];
                                                    var yearText = FSharpOption<int>.get_IsSome(book.Year) ? $" ({book.Year.Value})" : "";
                                                    var authorsText = book.Authors.Any() ? $" by {string.Join(", ", book.Authors)}" : "";
                                                    <option value="@i">@book.Title @yearText@authorsText</option>
                                                }
                                            </select>
                                            <button type="button" class="btn btn-primary px-4" @onclick="AutofillFromSelected" disabled="@(selectedLookupIndex < 0)">
                                                <i class="bi bi-magic me-2"></i> @L["AutofillFields"]
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }

                            @* ISBN & Scanner *@
                            <div class="col-md-7">
                                <label class="form-label small text-muted text-uppercase fw-bold mb-2">@L["IsbnIdentifier"]</label>
                                <div class="input-group shadow-sm rounded-3 overflow-hidden border">
                                    <span class="input-group-text bg-surface-low border-0"><i class="bi bi-upc-scan"></i></span>
                                    <InputText @ref="isbnInput" class="form-control border-0 font-monospace" 
                                               @bind-Value="newBookIsbn" 
                                               placeholder="@L["IsbnExamplePlaceholder"]" />
                                    <button type="button" class="btn btn-white border-start" @onclick="ToggleScanner">
                                        <i class="bi bi-camera me-1"></i> <span class="d-none d-sm-inline">@(showScanner ? L["Close"] : L["Scan"])</span>
                                    </button>
                                    <button type="button" class="btn btn-white border-start text-primary" @onclick="LookupMetadataByIsbn" disabled="@(!IsNewBookIsbnValid || isLookingUpMetadata)">
                                        <i class="bi bi-search"></i>
                                    </button>
                                </div>
                                <div class="form-check form-switch mt-2 small">
                                    <InputCheckbox class="form-check-input" @bind-Value="allowInvalidIsbn" id="invalidIsbnSwitch" />
                                    <label class="form-check-label text-muted" for="invalidIsbnSwitch">@L["AcceptInvalidIsbn"]</label>
                                </div>
                            </div>

                            @* Publication Year *@
                            <div class="col-md-5">
                                <label class="form-label small text-muted text-uppercase fw-bold mb-2">@L["PublicationYear"]</label>
                                <InputNumber class="form-control bg-surface-low border-0 py-2 shadow-sm" @bind-Value="newBookYear" placeholder="YYYY" />
                            </div>

                            @* Cover Image Section *@
                            <div class="col-12">
                                <label class="form-label small text-muted text-uppercase fw-bold mb-2">@L["ArchivalCoverImage"]</label>
                                <div class="input-group shadow-sm rounded-3 overflow-hidden border">
                                    <span class="input-group-text bg-surface-low border-0"><i class="bi bi-image"></i></span>
                                    <InputText class="form-control border-0 serif" 
                                               @bind-Value="newBookImageUrl" 
                                               placeholder="@L["PasteImageUrl"]" />
                                    <button type="button" class="btn btn-white border-start d-flex align-items-center gap-2" @onclick="LookupCover" disabled="@(isLookingUpCover || (string.IsNullOrWhiteSpace(newBookTitle) && !IsNewBookIsbnValid))">
                                        @if (isLookingUpCover) { <span class="spinner-border spinner-border-sm text-primary"></span> }
                                        <select class="form-select form-select-sm border-0 bg-transparent py-0" @bind="coverSizeLookup" style="width: auto;" @onclick:stopPropagation>
                                            <option value="Small">S</option>
                                            <option value="Medium">M</option>
                                            <option value="Large">L</option>
                                        </select>
                                        <i class="bi bi-magic text-primary"></i>@L["DiscoverCover"]
                                    </button>
                                </div>

                                @if (coverPreviewUrl != null)
                                {
                                    <div class="mt-4 p-4 bg-surface-low rounded-3 border border-primary-subtle shadow-sm animate-fade-in text-center">
                                        <p class="small text-muted mb-3 italic">@L["DiscoveredCoverPreview"]</p>
                                        <div class="preview-rect bg-white mx-auto overflow-hidden shadow-sm border border-4 border-white" style="width: 120px; height: 170px;">
                                            <img src="@coverPreviewUrl" class="w-100 h-100" style="object-fit: contain;" />
                                        </div>
                                        <div class="d-flex gap-2 justify-content-center mt-3">
                                            <button type="button" class="btn btn-primary btn-sm px-4" @onclick="AcceptLookup">@L["UseThisCover"]</button>
                                            <button type="button" class="btn btn-outline-secondary btn-sm px-4" @onclick="DiscardLookup">@L["Discard"]</button>
                                        </div>
                                    </div>
                                }
                                else if (!string.IsNullOrWhiteSpace(newBookImageUrl))
                                {
                                    <div class="mt-3 text-center">
                                        <div class="preview-rect bg-white mx-auto shadow-sm border border-2 border-white rounded" style="width: 80px; height: 110px; overflow: hidden;">
                                            <img src="@newBookImageUrl" class="w-100 h-100" style="object-fit: contain;" />
                                        </div>
                                    </div>
                                }
                            </div>

                            @if (showScanner)
                            {
                                <div class="col-12 animate-fade-in mt-2">
                                    <div class="barcode-scanner-container p-4 bg-dark rounded-4 shadow-lg text-white">
                                        <div class="d-flex justify-content-between align-items-center mb-3">
                                            <h6 class="mb-0 text-primary text-serif"><i class="bi bi-camera-fill me-2"></i>@L["ArchivalScannerActive"]</h6>
                                            <button type="button" class="btn btn-link text-white p-0" @onclick="ToggleScanner">@L["Close"]</button>
                                        </div>
                                        <div class="scanner-preview-wrapper rounded-3 overflow-hidden position-relative bg-black" style="min-height: 300px;">
                                            <BarcodeReader 
                                                OnBarcodeReceived="HandleBarcodeReceived" 
                                                Title=""
                                                StartCameraAutomatically="true"
                                                ShowStart="false"
                                                ShowReset="false"
                                                ShowVideoDeviceList="true"
                                            />
                                            <div class="scanner-overlay border-0">
                                                <div class="scanner-laser border-primary"></div>
                                            </div>
                                        </div>
                                        <p class="small text-muted mt-3 text-center mb-0 serif italic">@L["PositionBarcodeInsideFrameNote"]</p>
                                    </div>
                                </div>
                            }

                            @* Description / Narrative Abstract *@
                            <div class="col-12">
                                <label class="form-label small text-muted text-uppercase fw-bold mb-2">@L["NarrativeAbstract"]</label>
                                <InputTextArea class="form-control bg-surface-low border-0 shadow-sm p-4 serif" 
                                               @bind-Value="newBookDescription" rows="5" 
                                               placeholder="@L["BookDescriptionPlaceholder"]" />
                            </div>

                            @* Taxonomy & Availability *@
                            <div class="col-md-6 text-serif">
                                <label class="form-label small text-muted text-uppercase fw-bold mb-2">@L["PrimaryTaxonomy"]</label>
                                <select class="form-select bg-surface-low border-0 py-2 shadow-sm" @bind="mainCategoryString">
                                    @foreach (var cat in allCategories)
                                    {
                                        <option value="@cat.Value()">@cat.Value()</option>
                                    }
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label small text-muted text-uppercase fw-bold mb-2">@L["ArchivalAvailability"]</label>
                                <select class="form-select bg-surface-low border-0 py-2 shadow-sm" @bind="newBookAvailability">
                                    <option value="Circulating">@L["Circulating"]</option>
                                    <option value="ReferenceOnly">@L["ReferenceOnly"]</option>
                                    <option value="Unspecified">@L["Unspecified"]</option>
                                </select>
                            </div>

                            @* Selected Authors Ledger *@
                            <div class="col-12 mt-2">
                                <label class="form-label small text-muted text-uppercase fw-bold d-flex justify-content-between mb-3">
                                    @L["CatalogedAuthors"] 
                                    <span class="badge-sanctuary badge-neutral">@selectedAuthors.Count @L["Linked"]</span>
                                </label>
                                <div class="bg-surface-low rounded-3 p-4 border border-dashed text-serif" style="min-height: 120px;">
                                    @if (selectedAuthors.Count == 0)
                                    {
                                        <div class="text-center py-4 text-muted italic">
                                            <i class="bi bi-person-plus d-block h3 mb-2 opacity-25"></i>
                                            @L["NoAuthorsLinkedUseSidebar"]
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="d-flex flex-wrap gap-2">
                                            @foreach (var author in selectedAuthors)
                                            {
                                                <div class="badge-sanctuary badge-neutral d-flex align-items-center gap-3 py-2 px-3 shadow-sm">
                                                    <span class="fw-bold">@author.Name.Value</span>
                                                    <button type="button" class="btn-close" style="font-size: 0.6rem" 
                                                            @onclick="() => RemoveAuthor(author)"></button>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                            
                            @* Action Buttons *@
                            <div class="col-12 mt-5">
                                <div class="d-flex gap-3">
                                    <button type="submit" class="btn btn-sanctuary btn-lg flex-grow-1 py-3 shadow-sm shadow-hover">
                                        <i class="bi bi-journal-plus me-2"></i> @L["FinalizeArchivalRegistration"]
                                    </button>
                                    <button type="button" class="btn btn-outline-secondary btn-lg px-4" @onclick="() => showAddSection = false">
                                        @L["Discard"]
                                    </button>
                                </div>
                            </div>
                        </div>
                    </EditForm>
                </div>
            </div>

            @* Sidebar: Author Association Ledger *@
            <div class="col-lg-4">
                <div class="card-sanctuary p-4 sticky-top" style="top: 2rem;">
                    <div class="border-bottom pb-3 mb-4">
                        <h3 class="h5 text-serif mb-1">@L["AuthorDiscovery"]</h3>
                        <p class="small text-muted mb-0">@L["LocateAuthorsToAssociateWithThisRecord"]</p>
                    </div>

                    <EditForm Model="@this" OnValidSubmit="HandleAuthorSearch" FormName="AuthorSearchForm">
                        <div class="mb-4">
                            <div class="mb-3">
                                <label class="form-label small text-muted text-uppercase fw-bold mb-1">@L["SearchByName"]</label>
                                <InputText class="form-control bg-surface-low border-0 shadow-sm" @bind-Value="searchAuthorName" placeholder="@L["AuthorName"]" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label small text-muted text-uppercase fw-bold mb-1">@L["SearchByIsni"]</label>
                                <InputText class="form-control bg-surface-low border-0 shadow-sm" @bind-Value="searchAuthorIsni" placeholder="0000 0001..." />
                            </div>
                            <button type="submit" class="btn btn-outline-primary btn-sm w-100 rounded-pill mt-2 py-2">
                                <i class="bi bi-search me-2"></i>@L["SearchAuthors"]
                            </button>
                        </div>
                    </EditForm>
                    
                    @if (metadataAuthors.Any())
                    {
                        <div class="metadata-authors-ledger mb-4 border rounded-3 overflow-hidden animate-fade-in" style="background-color: var(--surface-container-low);">
                            <div class="bg-primary bg-opacity-10 px-3 py-2 border-bottom fw-bold small text-primary text-uppercase letter-spacing-1">
                                <i class="bi bi-magic me-2"></i>@L["FoundInMetadata"]
                            </div>
                            <div class="list-group list-group-flush">
                                @foreach (var name in metadataAuthors.Where(n => !selectedAuthors.Any(sa => sa.Name.Value.Equals(n, StringComparison.OrdinalIgnoreCase))))
                                {
                                    <div class="list-group-item bg-transparent px-3 py-2 small d-flex align-items-center justify-content-between gap-2">
                                        <div class="d-flex align-items-center gap-2">
                                            <i class="bi bi-person-badge text-muted"></i>
                                            <span>@name</span>
                                        </div>
                                        <button type="button" class="btn btn-link btn-sm text-primary p-0 text-decoration-none" 
                                                title="@L["AddAndLinkAuthor"]"
                                                @onclick="() => AddMetadataAuthor(name)">
                                            <i class="bi bi-person-plus-fill me-1"></i>@L["AddLink"]
                                        </button>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    <div class="author-results-ledger border rounded-3 overflow-hidden">
                        <div class="bg-surface-container px-3 py-2 border-bottom fw-bold small text-muted text-uppercase letter-spacing-1">
                            @L["RepositorySearch"]
                        </div>
                        <div class="list-group list-group-flush overflow-auto" style="max-height: 400px;">
                            @if (!foundAuthors.Any())
                            {
                                <div class="p-4 text-center text-muted small italic">@L["NoResultsYet"]</div>
                            }
                            else
                            {
                                @foreach (var author in foundAuthors)
                                {
                                    <div class="list-group-item bg-transparent px-3 py-3 d-flex justify-content-between align-items-center transition-hover">
                                        <div class="text-serif">@author.Name.Value</div>
                                        @if (selectedAuthors.Any(sa => sa.AuthorId == author.AuthorId))
                                        {
                                            <span class="text-success h5 mb-0"><i class="bi bi-check-circle-fill"></i></span>
                                        }
                                        else
                                        {
                                            <button type="button" class="btn btn-link text-primary p-0" @onclick="() => AddAuthor(author)">
                                                <i class="bi bi-plus-circle h5 mb-0"></i>
                                            </button>
                                        }
                                    </div>
                                }
                            }
                        </div>
                        @if (foundAuthors.Any())
                        {
                            <div class="p-2 bg-surface-low border-top d-flex justify-content-center">
                                <Paginator State="@pagination" />
                            </div>
                        }
                    </div>
                    
                    <div class="mt-4 p-3 bg-surface-neutral rounded-3">
                        <h6 class="small fw-bold mb-2 text-serif">@L["ArchivalNote"]</h6>
                        <p class="small text-muted mb-0 italic">
                            @L["AssociationNote"]
                        </p>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool showBulkEdit = false;
    private HashSet<BookId> selectedBookIds = new();

    private void ToggleBookSelection(BookId bookId, object? checkedValue)
    {
        bool isChecked = checkedValue is bool b && b;
        if (isChecked)
        {
            selectedBookIds.Add(bookId);
        }
        else
        {
            selectedBookIds.Remove(bookId);
        }
    }

    private void EnableBulkEdit()
    {
        showBulkEdit = true;
    }

    private void HandleBulkEditSuccess()
    {
        showBulkEdit = false;
        selectedBookIds.Clear();
    }

    private bool _showAddSection = false;
    private bool showAddSection 
    {
        get => _showAddSection;
        set 
        {
            if (_showAddSection != value)
            {
                _showAddSection = value;
                if (_showAddSection)
                {
                    shouldFocusIsbn = true;
                }
            }
        }
    }
    private bool shouldFocusIsbn = false;
    private Microsoft.AspNetCore.Components.Forms.InputText? isbnInput;
    private string newBookTitle = "";
    private string newBookIsbn = "";
    private string newBookDescription = "";
    private bool allowInvalidIsbn = false;
    private bool isLookingUpMetadata = false;
    private int? newBookYear = DateTime.Now.Year;
    private List<Author> selectedAuthors = new();
    private bool isAutofilling = false;
    private List<GoogleBookMetadata> lookupResults = new();
    private int selectedLookupIndex = -1;
    private string newBookImageUrl = "";
    private string? coverPreviewUrl = null;
    private bool isLookingUpCover = false;
    private string coverSizeLookup = "Medium";
    private bool showScanner = false;
    private List<string> metadataAuthors = new();
    private bool isExporting = false;
    private bool isImporting = false;
    private bool importAllowDuplicates = false;
    private bool importGenerateAuthors = true;
    private bool importGenerateEmbeddings = false;

    private void ToggleScanner()
    {
        showScanner = !showScanner;
    }

    private async Task HandleBarcodeReceived(BarcodeReceivedEventArgs args)
    {
        if (string.IsNullOrWhiteSpace(args.BarcodeText)) return;

        var scannedText = args.BarcodeText.Trim();
        
        if (Isbn.IsValid(scannedText))
        {
            newBookIsbn = scannedText;
            showScanner = false;
            await JSRuntime.InvokeVoidAsync("playScanSound");
            StateHasChanged();
        }
    }

    private string searchAuthorName = "";
    private string searchAuthorIsni = "";
    private List<Author> foundAuthors = new();
    private PaginationState pagination = new() { ItemsPerPage = 5 };

    private void HandleSearchStarted(bool started)
    {
        searchBooksPerformed = true;
        statusMessage = "";
    }

    private void HandleSearchResultsFound(List<Book> books)
    {
        foundBooks = books;
    }

    private async Task ShowSearchError(string error)
    {
        await ShowStatus(error, "error");
    }

    private string newBookAvailability = "Circulating";

    protected override void OnInitialized()
    {
        var configDefault = Configuration["DefaultAvailability"];
        if (!string.IsNullOrWhiteSpace(configDefault))
        {
            newBookAvailability = configDefault;
        }
    }

    private bool IsNewBookIsbnValid 
    {
        get 
        {
            if (string.IsNullOrWhiteSpace(newBookIsbn)) return false;
            return Isbn.IsValid(newBookIsbn);
        }
    }

    private List<Book> foundBooks = new();
    private string titleRefinementFilter = "";
    private IQueryable<Book> FilteredBooks => 
        foundBooks.AsQueryable()
            .Where(b => string.IsNullOrEmpty(titleRefinementFilter) || 
                        b.Title.Value.Contains(titleRefinementFilter, StringComparison.OrdinalIgnoreCase));

    private bool searchBooksPerformed = false;
    private PaginationState bookPagination = new() { ItemsPerPage = 10 };
    private GridSort<Book> sortTitle = GridSort<Book>.ByAscending(b => b.Title.Value);
    private GridSort<Book> sortAvailability = GridSort<Book>.ByAscending(b => b.ImmediatelyAvailable);    
    private GridSort<Book> sortTaxonomy = GridSort<Book>.ByAscending(b => b.MainCategory.Value());    

    private string statusMessage = "";
    private Category mainCategory = Category.Other;
    private List<Category> additionalCategories = new();
    private Category categoryToAdd = Category.Other;
    private FSharpList<Category> allCategories = Category.AllCases();

    private string mainCategoryString 
    {
        get => mainCategory.Value();
        set => mainCategory = Category.FromString(value);
    }

    private string categoryToAddString
    {
        get => categoryToAdd.Value();
        set => categoryToAdd = Category.FromString(value);
    }

    private void AddAuthor(Author author)
    {
        if (!selectedAuthors.Any(a => a.AuthorId == author.AuthorId))
        {
            selectedAuthors.Add(author);
        }
    }

    private void RemoveAuthor(Author author)
    {
        selectedAuthors.RemoveAll(a => a.AuthorId == author.AuthorId);
    }

    private async Task HandleAddBook()
    {
        if (string.IsNullOrWhiteSpace(newBookTitle))
        {
            await ShowStatus(L["TitleIsRequired"], "warning");
            return;
        }

        if (!newBookYear.HasValue)
        {
            await ShowStatus(L["YearIsRequired"], "warning");
            return;
        }

        Isbn isbn;
        if (string.IsNullOrWhiteSpace(newBookIsbn))
        {
            isbn = Isbn.EmptyIsbn;
        }
        else if (allowInvalidIsbn)
        {
            isbn = Isbn.NewInvalid(newBookIsbn);
        }
        else
        {
            var isbnResult = Isbn.New(newBookIsbn);
            if (isbnResult.IsError)
            {
                await ShowStatus(L["InvalidIsniValue", isbnResult.ErrorValue], "error");
                return;
            }
            isbn = isbnResult.ResultValue;
        }

        var title = Title.New(newBookTitle);
        var year = Year.New(newBookYear.Value);
        var authorIds = selectedAuthors.Select(a => a.AuthorId).ToList();

        FSharpOption<Uri> resolvedImageUrl = FSharpOption<Uri>.None;
        if (!string.IsNullOrWhiteSpace(newBookImageUrl))
        {
            if (Uri.TryCreate(newBookImageUrl, UriKind.Absolute, out var uri))
            {
                resolvedImageUrl = FSharpOption<Uri>.Some(uri);
            }
        }

        var availability = Availability.FromString(newBookAvailability);

        var book = Book.NewWithAvailability(
            title, 
            ListModule.OfSeq(authorIds),
            ListModule.OfSeq(Enumerable.Empty<AuthorId>()),
            ListModule.OfSeq(Enumerable.Empty<System.Globalization.CultureInfo>()),
            FSharpOption<EditorId>.None,
            mainCategory,
            ListModule.OfSeq(additionalCategories),
            year,
            isbn,
            resolvedImageUrl,
            availability
        );

        if (!string.IsNullOrWhiteSpace(newBookDescription))
        {
            var updateResult = book.UpdateDescription(newBookDescription, DateTime.UtcNow);
            if (updateResult.IsOk)
            {
                book = updateResult.ResultValue;
            }
        }

        var result = await BookService.AddBookAsync(book);
        if (result.IsOk)
        {
            await ShowStatus(string.Format(L["BookCreatedSuccessfully"], newBookTitle), "success");
            ResetForm();
            // Refresh managers list if needed or redirect
        }
        else
        {
            await ShowStatus(string.Format(L["ErrorCreatingBook"], result.ErrorValue), "error");
        }
    }

    private void ResetForm()
    {
        newBookTitle = "";
        newBookIsbn = "";
        newBookDescription = "";
        newBookImageUrl = "";
        coverPreviewUrl = null;
        selectedAuthors.Clear();
        metadataAuthors.Clear();
        lookupResults.Clear();
        selectedLookupIndex = -1;
    }

    private async Task ShowStatus(string message, string type)
    {
        statusMessage = message;
        await JSRuntime.InvokeVoidAsync("showToast", message, type);
    }

    private async Task HandleAuthorSearch()
    {
        bool hasName = !string.IsNullOrWhiteSpace(searchAuthorName);
        bool hasIsni = !string.IsNullOrWhiteSpace(searchAuthorIsni);

        FSharpResult<FSharpList<Author>, string> result;

        if (hasName && hasIsni)
        {
            var name = Name.New(searchAuthorName);
            var isni = Isni.NewInvalid(searchAuthorIsni);
            result = await AuthorService.SearchByIsniAndNameAsync(isni, name);
        }
        else if (hasName)
        {
            var name = Name.New(searchAuthorName);
            result = await AuthorService.SearchByNameAsync(name);
        }
        else if (hasIsni)
        {
            var isni = Isni.NewInvalid(searchAuthorIsni);
            result = await AuthorService.SearchByIsniAsync(isni);
        }
        else
        {
            result = await AuthorService.GetAllAsync();
        }

        if (result.IsOk)
        {
            foundAuthors = result.ResultValue.ToList();
        }
        else
        {
            await ShowStatus(L["ErrorSearchingAuthors", result.ErrorValue], "error");
        }
    }

    private async Task PerformGoogleLookup()
    {
        if (string.IsNullOrWhiteSpace(newBookTitle))
        {
            await ShowStatus(L["EnterTitleToSearch"], "warning");
            return;
        }

        isAutofilling = true;
        try
        {
            var results = await GoogleBooksService.LookupMultipleByTitleAsync(newBookTitle);
            if (results.IsOk)
            {
                lookupResults = results.ResultValue.ToList();
                if (lookupResults.Any())
                {
                    await ShowStatus(string.Format(L["FoundResultsFromApi"], lookupResults.Count), "success");
                }
                else
                {
                    await ShowStatus(L["NoBooksFoundTitle"], "warning");
                }
            }
            else
            {
                await ShowStatus(string.Format(L["GoogleBooksServiceError"], results.ErrorValue), "error");
            }
        }
        finally
        {
            isAutofilling = false;
        }
    }

    private async Task AutofillFromSelected()
    {
        if (selectedLookupIndex < 0 || selectedLookupIndex >= lookupResults.Count) return;
        
        var book = lookupResults[selectedLookupIndex];
        newBookTitle = book.Title;
        if (FSharpOption<int>.get_IsSome(book.Year)) newBookYear = book.Year.Value;
        if (FSharpOption<string>.get_IsSome(book.Isbn)) newBookIsbn = book.Isbn.Value;
        if (FSharpOption<string>.get_IsSome(book.Description)) newBookDescription = book.Description.Value;
        
        // Search and link authors
        await ProcessMetadataAuthors(book.Authors);
        
        // Discover image
        await LookupCover();
        
        await ShowStatus(L["FieldsPopulatedReview"], "success");
    }

    private async Task LookupMetadataByIsbn()
    {
        if (!IsNewBookIsbnValid) return;
        isLookingUpMetadata = true;
        try
        {
            var result = await GoogleBooksService.LookupByIsbnAsync(newBookIsbn);
            if (result.IsOk && FSharpOption<GoogleBookMetadata>.get_IsSome(result.ResultValue))
            {
                var book = result.ResultValue.Value;
                newBookTitle = book.Title;
                if (FSharpOption<int>.get_IsSome(book.Year)) newBookYear = book.Year.Value;
                if (FSharpOption<string>.get_IsSome(book.Description)) newBookDescription = book.Description.Value;
                
                // Search and link authors
                await ProcessMetadataAuthors(book.Authors);
                
                // Discover image
                await LookupCover();
                
                await ShowStatus(L["MetadataFound"], "success");
            }
            else if (result.IsOk)
            {
                await ShowStatus(L["MetadataNotFound"], "warning");
            }
            else
            {
                await ShowStatus(string.Format(L["GoogleBooksServiceError"], result.ErrorValue), "error");
            }
        }
        finally
        {
            isLookingUpMetadata = false;
        }
    }

    private async Task ProcessMetadataAuthors(IEnumerable<string> names)
    {
        metadataAuthors.Clear();
        foreach (var name in names)
        {
            var searchResult = await AuthorService.SearchByNameAsync(Name.New(name));
            if (searchResult.IsOk && searchResult.ResultValue.Any())
            {
                // Find exact name match in the list
                var localAuthor = searchResult.ResultValue.FirstOrDefault(a => a.Name.Value.Equals(name, StringComparison.OrdinalIgnoreCase));
                if (localAuthor != null)
                {
                    AddAuthor(localAuthor);
                }
                else
                {
                    metadataAuthors.Add(name);
                }
            }
            else
            {
                metadataAuthors.Add(name);
            }
        }
    }

    private async Task AddMetadataAuthor(string name)
    {
        var author = Author.NewWithoutIsni(Name.New(name));
        var result = await AuthorService.AddAuthorAsync(author);
        if (result.IsOk)
        {
            AddAuthor(author);
            await ShowStatus(string.Format(L["AuthorAddedAndLinked"], name), "success");
        }
        else
        {
            await ShowStatus(string.Format(L["ErrorAddingAuthor"], result.ErrorValue), "error");
        }
    }

    private async Task AcceptLookup()
    {
        if (coverPreviewUrl != null)
        {
            newBookImageUrl = coverPreviewUrl;
            coverPreviewUrl = null;
            await ShowStatus(L["ImageUrlAppliedConfirm"], "info");
        }
    }

    private void DiscardLookup()
    {
        coverPreviewUrl = null;
    }

    private async Task LookupCover()
    {
        isLookingUpCover = true;
        coverPreviewUrl = null;
        StateHasChanged();

        try
        {
            FSharpResult<FSharpOption<string>, string> result;
            string searchMode = "";

            if (IsNewBookIsbnValid)
            {
                searchMode = "ISBN";
                var size = ThumbRoughSize.Medium;
                if (coverSizeLookup == "Small") size = ThumbRoughSize.Small;
                else if (coverSizeLookup == "Large") size = ThumbRoughSize.Large;

                result = await GoogleBooksService.LookupCoverImageByIsbnWithOpenApiAndThenGoogleAsync(Isbn.New(newBookIsbn).ResultValue, FSharpOption<ThumbRoughSize>.Some(size));
            }
            else
            {
                searchMode = "Title/Author";
                var title = newBookTitle;
                var firstAuthor = selectedAuthors.FirstOrDefault();
                var authorName = firstAuthor != null ? FSharpOption<string>.Some(firstAuthor.Name.Value) : FSharpOption<string>.None;
                
                result = await GoogleBooksService.LookupGoogleApiCoverImageByTitleAndOptionalAuthorAsync(title, authorName);
            }

            if (result.IsOk && FSharpOption<string>.get_IsSome(result.ResultValue))
            {
                coverPreviewUrl = result.ResultValue.Value;
                await ShowStatus(string.Format(L["CoverImageFoundVia"], searchMode), "success");
            }
            else if (result.IsOk)
            {
                await ShowStatus(string.Format(L["NoCoverFoundUsing"], searchMode), "warning");
            }
            else
            {
                await ShowStatus(string.Format(L["LookupError"], result.ErrorValue), "error");
            }
        }
        catch (Exception ex)
        {
            await ShowStatus(string.Format(L["LookupErrorGeneric"], ex.Message), "error");
        }
        finally
        {
            isLookingUpCover = false;
        }
    }

    private async Task ExportBooks(ExportFormat format)
    {
        if (isExporting) return;
        
        isExporting = true;
        try
        {
            var result = await DataExportService.ExportAllBooksAsync(format, CancellationToken.None);
            if (result.IsOk)
            {
                var fileName = $"books_export_{DateTime.Now:yyyyMMdd_HHmmss}{format.Extension}";
                await JSRuntime.InvokeVoidAsync("downloadFile", fileName, result.ResultValue);
                await ShowStatus(L["ExportSuccessful"], "success");
            }
            else
            {
                await ShowStatus(string.Format(L["ExportError"], result.ErrorValue), "error");
            }
        }
        catch (Exception ex)
        {
            await ShowStatus(string.Format(L["ExportErrorGeneric"], ex.Message), "error");
        }
        finally
        {
            isExporting = false;
        }
    }

    private async Task HandleImportFile(InputFileChangeEventArgs e)
    {
        if (isImporting) return;
        
        var file = e.File;
        if (file == null) return;

        isImporting = true;
        try
        {
            // Set a reasonable limit for bulk ISBN files (e.g., 512KB)
            using var stream = file.OpenReadStream(maxAllowedSize: 512 * 1024);
            using var reader = new System.IO.StreamReader(stream);
            var content = await reader.ReadToEndAsync();
            
            var isbns = ConverterUtils.parseIsbns(content);
            if (isbns.Length == 0)
            {
                await ShowStatus("No valid ISBNs found in file.", "warning");
                return;
            }

            // We use FSharpList directly as returned by parseIsbns
            var progress = new Progress<ImportProgress>(p => 
            {
                currentProgress = p;
                StateHasChanged();
            });

            var result = await DataExportService.ImportFromIsbns(isbns, !importAllowDuplicates, importGenerateAuthors, importGenerateEmbeddings, progress, CancellationToken.None);
            
            if (result.IsOk)
            {
                var (successCount, failureCount) = result.ResultValue;
                await ShowStatus(string.Format(L["ImportSummary"], successCount, failureCount), "success");
            }
            else
            {
                await ShowStatus(string.Format(L["ImportFailed"], result.ErrorValue), "error");
            }
        }
        catch (Exception ex)
        {
            await ShowStatus(string.Format(L["ImportFailed"], ex.Message), "error");
        }
        finally
        {
            isImporting = false;
        }
    }
    private ImportProgress? currentProgress;
    
    private double GetProgressPercentage()
    {
        if (currentProgress == null || currentProgress.Total == 0) return 0;
        return (double)currentProgress.Current / currentProgress.Total * 100;
    }

    private string FormatTimeSpan(TimeSpan ts)
    {
        if (ts.TotalHours >= 1)
            return $"{(int)ts.TotalHours}h {ts.Minutes}m {ts.Seconds}s";
        if (ts.TotalMinutes >= 1)
            return $"{(int)ts.TotalMinutes}m {ts.Seconds}s";
        return $"{(int)ts.TotalSeconds}s";
    }
}

