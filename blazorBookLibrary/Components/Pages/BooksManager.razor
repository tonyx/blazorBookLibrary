@page "/books-manager"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.QuickGrid
@using BookLibrary.Shared.Services
@using Microsoft.Extensions.Localization
@using blazorBookLibrary.Shared.Resources
@using BookLibrary.Domain
@using static BookLibrary.Shared.Commons
@using Microsoft.FSharp.Core
@using Microsoft.FSharp.Collections
@using System.Threading

@attribute [Authorize(Roles = "Admin, Manager")]
@inject IBookService BookService
@inject IAuthorService AuthorService
@inject IJSRuntime JSRuntime
@inject IGoogleBooksService GoogleBooksService
@inject IAuthorsSearchService AuthorsSearchService
@inject IStringLocalizer<SharedResources> L
@inject IConfiguration Configuration
@rendermode InteractiveServer

<style>
    .book-grid {
        table-layout: fixed;
        width: 100%;
    }
    .col-title { width: auto; min-width: 200px; }
    .col-year { width: 100px; }
    .col-category { width: 180px; }
    .col-available { width: 140px; }
    .col-isbn { width: 170px; }
    .col-actions { width: 120px; }
    
    /* Ensure text truncation for the title if it's too long */
    .title-cell {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
</style>

<PageTitle>@L["BooksManager"]</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-primary mb-0"><i class="bi bi-book-half me-2"></i>@L["BooksManager"]</h1>
        @if (!string.IsNullOrEmpty(statusMessage))
        {
            <div class="alert @(statusClass) alert-dismissible fade show mb-0" role="alert">
                @statusMessage
                <button type="button" class="btn-close" @onclick='() => statusMessage = ""'></button>
            </div>
        }
    </div>
<div class="row mb-4">
    <div class="col-12">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-secondary text-white py-3">
                <h5 class="card-title mb-0"><i class="bi bi-search me-2"></i>@L["SearchBooksForm"]</h5>
            </div>
            <div class="card-body bg-light">
                <EditForm Model="@this" OnValidSubmit="HandleBookSearch" FormName="SearchBookForm">
                    <div class="row g-3">
                        <div class="col-md-2">
                            <label class="form-label fw-bold small text-muted text-uppercase mb-2">@L["TitleSearch"]</label>
                            <InputText class="form-control border-primary shadow-sm" @bind-Value="searchBookTitle" placeholder="@L["SearchByTitlePlaceholder"]" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label fw-bold small text-muted text-uppercase mb-2">@L["IsbnSearch"]</label>
                            <InputText class="form-control border-primary shadow-sm" @bind-Value="searchBookIsbn" placeholder="@L["PartialIsbnPlaceholder"]" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold small text-muted text-uppercase mb-2"><i class="bi bi-funnel-fill me-1"></i>@L["Availability"]</label>
                            <div class="btn-group w-100 shadow-sm" role="group">
                                <input type="radio" class="btn-check" name="availSearch" id="availAll" checked="@(searchBookAvailability == "All")" @onclick='() => searchBookAvailability = "All"' autocomplete="off">
                                <label class="btn btn-outline-primary btn-sm py-2" for="availAll">@L["All"]</label>

                                <input type="radio" class="btn-check" name="availSearch" id="availCirc" checked="@(searchBookAvailability == "Circulating")" @onclick='() => searchBookAvailability = "Circulating"' autocomplete="off">
                                <label class="btn btn-outline-primary btn-sm py-2" for="availCirc" title="@L["Circulating"]">
                                    <i class="bi bi-journal-text me-1"></i><span class="d-none d-xl-inline">@L["Circulating"]</span>
                                </label>

                                <input type="radio" class="btn-check" name="availSearch" id="availRef" checked="@(searchBookAvailability == "ReferenceOnly")" @onclick='() => searchBookAvailability = "ReferenceOnly"' autocomplete="off">
                                <label class="btn btn-outline-primary btn-sm py-2" for="availRef" title="@L["ReferenceOnly"]">
                                    <i class="bi bi-lock-fill me-1"></i><span class="d-none d-xl-inline">@L["ReferenceOnly"]</span>
                                </label>

                                <input type="radio" class="btn-check" name="availSearch" id="availUnsp" checked="@(searchBookAvailability == "Unspecified")" @onclick='() => searchBookAvailability = "Unspecified"' autocomplete="off">
                                <label class="btn btn-outline-primary btn-sm py-2" for="availUnsp" title="@L["Unspecified"]">
                                    <i class="bi bi-question-circle me-1"></i><span class="d-none d-xl-inline">@L["Unspecified"]</span>
                                </label>
                            </div>
                        </div>
                        <div class="col-md-2 @(IsIsbnSearchActive ? "opacity-50" : "") transition-opacity" style="transition: opacity 0.3s ease;">
                            <label class="form-label fw-bold small text-muted text-uppercase mb-2 @(IsIsbnSearchActive ? "text-decoration-line-through" : "")">
                                <i class="bi bi-calendar-range me-1"></i>@L["PublicationYear"]
                            </label>
                            <div class="year-search-container bg-white p-3 rounded shadow-sm border @(IsIsbnSearchActive ? "bg-light border-secondary-subtle" : "border-primary-subtle")">
                                <fieldset disabled="@IsIsbnSearchActive">
                                    <div class="d-flex flex-wrap gap-2 mb-2">
                                        <div class="form-check">
                                            <input class="form-check-input" type="radio" name="yearSearchOption" id="exactYear" value="exact" 
                                                   checked='@(yearSearchMode == "exact")' @onclick='() => yearSearchMode = "exact"' />
                                            <label class="form-check-label small" for="exactYear">@L["Exact"]</label>
                                        </div>
                                        <div class="form-check">
                                            <input class="form-check-input" type="radio" name="yearSearchOption" id="afterYear" value="after" 
                                                   checked='@(yearSearchMode == "after")' @onclick='() => yearSearchMode = "after"' />
                                            <label class="form-check-label small" for="afterYear">@L["From"]</label>
                                        </div>
                                        <div class="form-check">
                                            <input class="form-check-input" type="radio" name="yearSearchOption" id="beforeYear" value="before" 
                                                   checked='@(yearSearchMode == "before")' @onclick='() => yearSearchMode = "before"' />
                                            <label class="form-check-label small" for="beforeYear">@L["ToYear"]</label>
                                        </div>
                                        <div class="form-check">
                                            <input class="form-check-input" type="radio" name="yearSearchOption" id="betweenYear" value="between" 
                                                   checked='@(yearSearchMode == "between")' @onclick='() => yearSearchMode = "between"' />
                                            <label class="form-check-label small" for="betweenYear">@L["Between"]</label>
                                        </div>
                                    </div>
                                    <div class="row g-2">
                                        <div class="@(yearSearchMode == "between" ? "col-6" : "col-12")">
                                            <div class="input-group">
                                                <span class="input-group-text bg-light text-primary"><i class="bi bi-calendar-event"></i></span>
                                                <InputNumber class="form-control" @bind-Value="searchBookYear" 
                                                             placeholder='@(yearSearchMode == "between" ? L["StartingYear"] : L["YearValue"])' />
                                            </div>
                                        </div>
                                        @if (yearSearchMode == "between")
                                        {
                                            <div class="col-6">
                                                <div class="input-group">
                                                    <span class="input-group-text bg-light text-primary"><i class="bi bi-calendar-check"></i></span>
                                                    <InputNumber class="form-control" @bind-Value="searchBookYearTo" placeholder="@L["EndingYear"]" />
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </fieldset>
                            </div>
                        </div>
                        <div class="col-md-2 d-flex align-items-end justify-content-center">
                            <button type="submit" class="btn btn-primary btn-lg w-100 shadow-sm transition-hover mb-1 py-1 h-50 d-flex align-items-center justify-content-center">
                                <i class="bi bi-search me-2 fs-5"></i><span>@L["SearchBooks"]</span>
                            </button>
                        </div>
                    </div>

                    <div class="row g-3 mt-4 border-top pt-4 @(IsIsbnSearchActive ? "opacity-50" : "") transition-opacity" style="transition: opacity 0.3s ease;">
                        <div class="col-md-5">
                            <label class="form-label fw-bold small text-muted text-uppercase mb-2 @(IsIsbnSearchActive ? "text-decoration-line-through" : "")">
                                <i class="bi bi-person-lines-fill me-1"></i>@L["RefineByAuthors"]
                            </label>
                            <fieldset disabled="@IsIsbnSearchActive">
                                <div class="input-group shadow-sm">
                                    <span class="input-group-text bg-white text-primary border-primary"><i class="bi bi-person-search"></i></span>
                                    <input type="text" class="form-control border-primary border-end-0" @bind="authorSearchNameFilter" placeholder="@L["SearchAuthorNamePlaceholder"]" @onkeyup='(e) => { if (e.Key == "Enter") SearchAuthorsForFilter(); }' />
                                    <button type="button" class="btn btn-outline-primary border-primary px-3 transition-hover" @onclick="SearchAuthorsForFilter">
                                        <i class="bi bi-search"></i>
                                    </button>
                                </div>
                                
                                @if (foundAuthorsForFilter.Any())
                                {
                                    <div class="mt-3 p-3 border-start border-4 border-primary bg-white shadow-sm rounded-end animate-fade-in">
                                        <label class="form-label small text-muted text-uppercase d-block mb-2 fw-semibold">@L["ClickToAddAuthor"]</label>
                                        <div class="d-flex gap-2">
                                            <select class="form-select border-primary shadow-sm" @bind="selectedAuthorIdForFilter">
                                                <option value="">@L["ChooseFromResults"]</option>
                                                @foreach (var author in foundAuthorsForFilter)
                                                {
                                                    <option value="@author.AuthorId.Value.ToString()">@author.Name.Value</option>
                                                }
                                            </select>
                                            <button type="button" class="btn btn-success shadow-sm transition-hover d-flex align-items-center" @onclick="AddAuthorToSearchCriteria" disabled="@(string.IsNullOrEmpty(selectedAuthorIdForFilter))">
                                                <i class="bi bi-plus-lg me-1"></i>@L["Add"]
                                            </button>
                                        </div>
                                    </div>
                                }
                            </fieldset>
                        </div>
                        
                        <div class="col-md-7">
                            <label class="form-label fw-bold small text-muted text-uppercase mb-2">@L["ActiveAuthorCriteria"]</label>
                            <div class="d-flex flex-wrap gap-2 p-3 border border-dashed rounded bg-white shadow-inner min-vh-10" style="min-height: 80px;">
                                @if (!searchAuthorsCriteria.Any())
                                {
                                    <div class="w-100 d-flex align-items-center justify-content-center text-muted small italic">
                                        <i class="bi bi-info-circle me-2"></i>@L["NoAuthorsSelected"]
                                    </div>
                                }
                                else
                                {
                                    @foreach (var author in searchAuthorsCriteria)
                                    {
                                        <div class="badge bg-primary text-white d-flex align-items-center py-2 px-3 rounded-pill shadow-sm animate-pop-in">
                                            <i class="bi bi-person-fill me-2 border-end pe-2 border-white-50"></i>
                                            <span class="me-2 fw-normal">@author.Name.Value</span>
                                            <button type="button" class="btn-close btn-close-white ms-1 small" style="transform: scale(0.7);" title="@L["Remove"]" @onclick="() => { if (!IsIsbnSearchActive) RemoveAuthorFromSearchCriteria(author); }"></button>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    </div>

                    <!-- Category Selection Section -->
                    <div class="row g-3 mt-4 border-top pt-4 @(IsIsbnSearchActive ? "opacity-50" : "") transition-opacity" style="transition: opacity 0.3s ease;">
                        <div class="col-md-5">
                            <label class="form-label fw-bold small text-muted text-uppercase mb-2 @(IsIsbnSearchActive ? "text-decoration-line-through" : "")">
                                <i class="bi bi-tags-fill me-1"></i>@L["RefineByCategory"]
                            </label>
                            <fieldset disabled="@IsIsbnSearchActive">
                                <div class="d-flex gap-2">
                                    <select class="form-select border-primary shadow-sm" @bind="selectedCategoryForFilter">
                                        <option value="">@L["SelectCategoryPlaceholder"]</option>
                                        @foreach (var category in allCategories)
                                        {
                                            <option value="@category.Value()">@category.Value()</option>
                                        }
                                    </select>
                                    <button type="button" class="btn btn-info text-white shadow-sm transition-hover d-flex align-items-center" @onclick="AddCategoryToSearchCriteria" disabled="@(string.IsNullOrEmpty(selectedCategoryForFilter))">
                                        <i class="bi bi-bookmark-plus-fill me-1"></i>@L["Add"]
                                    </button>
                                </div>
                            </fieldset>
                        </div>
                        
                        <div class="col-md-7">
                            <label class="form-label fw-bold small text-muted text-uppercase mb-2">@L["ActiveCategoryCriteria"]</label>
                            <div class="d-flex flex-wrap gap-2 p-3 border border-dashed rounded bg-white shadow-inner" style="min-height: 80px;">
                                @if (!searchCategoriesCriteria.Any())
                                {
                                    <div class="w-100 d-flex align-items-center justify-content-center text-muted small italic">
                                        <i class="bi bi-info-circle me-2"></i>@L["NoCategoriesSelected"]
                                    </div>
                                }
                                else
                                {
                                    @foreach (var category in searchCategoriesCriteria)
                                    {
                                        <div class="badge bg-info text-white d-flex align-items-center py-2 px-3 rounded shadow-sm animate-pop-in">
                                            <i class="bi bi-tag-fill me-2 border-end pe-2 border-white-50"></i>
                                            <span class="me-2 fw-normal">@category.Value()</span>
                                            <button type="button" class="btn-close btn-close-white ms-1 small" style="transform: scale(0.7);" title="@L["Remove"]" @onclick="() => { if (!IsIsbnSearchActive) RemoveCategoryFromSearchCriteria(category); }"></button>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
</div>

@if (searchBooksPerformed)
{
    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow-sm border-0 overflow-hidden">
                <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center py-3">
                    <h5 class="card-title mb-0"><i class="bi bi-list-stars me-2"></i>@L["SearchResults"]</h5>
                    <span class="badge bg-primary text-white">@foundBooks.Count @L["BooksFound"]</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <QuickGrid Items="@FilteredBooks" Pagination="@bookPagination" Class="table table-hover align-middle mb-0 book-grid">
                            <TemplateColumn Title="@L["Title"]" SortBy="@sortTitle" Class="fw-bold text-dark col-title title-cell">
                                <ColumnOptions>
                                    <div class="p-3 shadow-sm border rounded bg-white" style="min-width: 250px;">
                                        <div class="input-group">
                                            <span class="input-group-text bg-primary text-white border-0"><i class="bi bi-filter"></i></span>
                                            <input type="search" autofocus @bind="titleRefinementFilter" @bind:event="oninput" placeholder="@L["RefineResultsByTitlePlaceholder"]" class="form-control border-primary shadow-none" />
                                        </div>
                                    </div>
                                </ColumnOptions>
                                <ChildContent>
                                    <a href="/book-edit/@context.Id" class="text-decoration-none text-primary-emphasis transition-hover d-block w-100 h-100 py-1" title="View details for '@context.Title.Value'">
                                        <i class="bi bi-book-fill me-2 small opacity-75"></i>@context.Title.Value
                                    </a>
                                </ChildContent>
                            </TemplateColumn>
                            <TemplateColumn Title="@L["Image"]" Align="Align.Center" SortBy="@sortImage">
                                @if (context.ImageUrl != null && FSharpOption<Uri>.get_IsSome(context.ImageUrl))
                                {
                                    <span class="text-success" title="@context.ImageUrl.Value.ToString()"><i class="bi bi-check-circle-fill"></i></span>
                                }
                                else
                                {
                                    <span class="text-muted opacity-25"><i class="bi bi-x-circle"></i></span>
                                }
                            </TemplateColumn>
                            <PropertyColumn Property="@(b => b.Year.Value)" Title="@L["Year"]" Sortable="true" Class="col-year" />
                            <PropertyColumn Property="@(b => b.MainCategory.Value())" Title="@L["Category"]" Sortable="true" Class="col-category" />
                            <TemplateColumn Title="@L["AvailabilityType"]" Align="Align.Center" Class="col-availability-type" Sortable="true">
                                @{
                                    var label = context.Availability.ToString();
                                    var localizedLabel = L[label].Value;
                                    var contraction = localizedLabel.Length >= 3 ? localizedLabel.Substring(0, 3).ToUpper() : localizedLabel.ToUpper();
                                }
                                <span class="badge bg-light text-dark border p-1" style="font-size: 0.7rem;" title="@localizedLabel">@contraction</span>
                            </TemplateColumn>
                            <TemplateColumn Title="@L["Availability"]" Sortable="true" Align="Align.Center" Class="col-available">
                                @if (context.Available)
                                {
                                    <span class="text-success small fw-bold"><i class="bi bi-check-circle-fill me-1"></i>@L["Available"]</span>
                                }
                                else
                                {
                                    <span class="text-danger small fw-bold"><i class="bi bi-dash-circle-fill me-1"></i>@L["OnLoan"]</span>
                                }
                            </TemplateColumn>
                            <PropertyColumn Property="@(b => b.Isbn.Value)" Title="@L["IsbnSearch"]" Class="col-isbn" />
                        </QuickGrid>
                    </div>
                    @if (foundBooks.Count > 0)
                    {
                        <div class="p-3 border-top bg-light">
                            <Paginator State="@bookPagination" />
                        </div>
                    }
                    else
                    {
                        <div class="p-5 text-center text-muted">
                            <i class="bi bi-search fs-1 mb-3 d-block opacity-25"></i>
                            <p class="mb-0">@L["NoBooksFoundCriteria"]</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

<div class="row mb-4">
    <div class="col-12 text-center">
        <div class="d-inline-flex align-items-center bg-white p-2 rounded-pill shadow-sm border border-primary-subtle px-4 animate-fade-in">
            <label class="form-check-label me-3 fw-bold text-primary" for="showAddSectionToggle">
                <i class="bi bi-plus-circle me-1"></i> @L["AddNewBookEntry"]
            </label>
            <div class="form-check form-switch mb-0">
                <input class="form-check-input" type="checkbox" role="switch" id="showAddSectionToggle" @bind="showAddSection" style="width: 2.5em; height: 1.25em; cursor: pointer;">
            </div>
            <span class="ms-2 badge @(showAddSection ? "bg-success" : "bg-secondary") rounded-pill">@(showAddSection ? L["Visible"] : L["Hidden"])</span>
        </div>
    </div>
</div>

@if (showAddSection)
{
    <div class="row g-4 mb-5 animate-fade-in">
        <!-- Add New Book Form (Left Side) -->
        <div class="col-lg-7">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="card-title mb-0"><i class="bi bi-plus-circle-fill me-2"></i>@L["AddNewBook"]</h5>
                </div>
                <div class="card-body p-4 bg-light">
                    <EditForm Model="@this" OnValidSubmit="HandleAddBook" FormName="AddBookForm">
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label fw-bold">@L["BookTitleSearchApi"]</label>
                                <div class="input-group">
                                    <InputText class="form-control form-control-lg" @bind-Value="newBookTitle" placeholder="@L["EnterTitleToSearchPlaceholder"]" />
                                    <button type="button" class="btn btn-outline-secondary px-4" @onclick="PerformGoogleLookup" disabled="@isAutofilling">
                                        @if (isAutofilling) { <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span> }
                                        <i class="bi bi-search me-1"></i> @L["SearchApi"]
                                    </button>
                                </div>
                            </div>

                            @if (lookupResults.Any())
                            {
                                <div class="col-12 animate-fade-in">
                                    <div class="p-3 bg-white border border-primary rounded shadow-sm">
                                        <label class="form-label small fw-bold text-primary mb-2">@L["SelectFromResultToPopulate"]</label>
                                        <div class="input-group">
                                            <select class="form-select border-primary" @bind="selectedLookupIndex">
                                                <option value="-1">@L["SelectABook"]</option>
                                                @for (int i = 0; i < lookupResults.Count; i++)
                                                {
                                                    var book = lookupResults[i];
                                                    var yearText = FSharpOption<int>.get_IsSome(book.Year) ? $" ({book.Year.Value})" : "";
                                                    var authorsText = book.Authors.Any() ? $" by {string.Join(", ", book.Authors)}" : "";
                                                    <option value="@i">@book.Title @yearText@authorsText</option>
                                                }
                                            </select>
                                            <button type="button" class="btn btn-primary px-4" @onclick="AutofillFromSelected" disabled="@(selectedLookupIndex < 0)">
                                                <i class="bi bi-magic me-1"></i> @L["AutofillFields"]
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }

                            <div class="col-md-8">
                                <label class="form-label fw-bold">@L["IsbnSearch"]</label>
                                <div class="input-group shadow-sm">
                                    <span class="input-group-text"><i class="bi bi-upc-scan"></i></span>
                                    <InputText class="form-control" @bind-Value="newBookIsbn" placeholder="@L["IsbnExamplePlaceholder"]" />
                                    <button type="button" class="btn btn-info text-white" @onclick="LookupCoverImage" disabled="@(!IsNewBookIsbnValid || isLookingUpCover)">
                                        @if (isLookingUpCover) { <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span> }
                                        <i class="bi bi-image me-1"></i> <span class="d-none d-sm-inline">@L["LookupCover"]</span>
                                    </button>
                                    <button type="button" class="btn btn-primary" @onclick="LookupMetadataByIsbn" disabled="@(!IsNewBookIsbnValid || isLookingUpMetadata)">
                                        @if (isLookingUpMetadata) { <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span> }
                                        <i class="bi bi-search me-1"></i> <span class="d-none d-sm-inline">@L["MetadataSearch"]</span>
                                    </button>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label fw-bold text-transparent">.</label>
                                <div class="form-check form-switch pt-2">
                                    <InputCheckbox class="form-check-input" @bind-Value="allowInvalidIsbn" id="invalidIsbnSwitch" />
                                    <label class="form-check-label text-muted small" for="invalidIsbnSwitch">@L["AcceptInvalidIsbn"]</label>
                                </div>
                            </div>

                            <div class="col-12 mt-3">
                                <label class="form-label fw-bold">@L["ImageURL"]</label>
                                <div class="input-group shadow-sm">
                                    <span class="input-group-text bg-white text-info border-info"><i class="bi bi-link-45deg"></i></span>
                                    <InputText class="form-control border-info" @bind-Value="newBookImageUrl" placeholder="@L["PasteImageUrlPlaceholder"]" />
                                    @if (!string.IsNullOrWhiteSpace(newBookImageUrl))
                                    {
                                        <button type="button" class="btn btn-outline-danger border-info" @onclick='() => newBookImageUrl = ""'>
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    }
                                </div>
                                <div class="form-text small italic text-muted">@L["UseCoverLookupInfo"]</div>
                            </div>

                            @if (coverPreviewUrl != null)
                            {
                                <div class="col-12 mt-3 animate-fade-in">
                                    <div class="p-3 bg-white border border-info rounded shadow-sm d-flex align-items-center gap-4">
                                        <div class="flex-shrink-0" style="width: 100px; height: 140px; overflow: hidden; border: 1px solid #dee2e6; border-radius: 4px;">
                                            <img src="@coverPreviewUrl" alt="Cover Preview" style="width: 100%; height: 100%; object-fit: contain;" />
                                        </div>
                                        <div class="flex-grow-1">
                                            <h6 class="text-info fw-bold mb-1">@L["CoverFound"]</h6>
                                            <p class="small text-muted mb-3">@L["UseThisImageUrl"]</p>
                                            <div class="d-flex gap-2">
                                                <button type="button" class="btn btn-info text-white btn-sm px-4" @onclick="AcceptCoverUrl">
                                                    <i class="bi bi-check2-circle me-1"></i> @L["AcceptAndUse"]
                                                </button>
                                                <button type="button" class="btn btn-outline-secondary btn-sm" @onclick='() => coverPreviewUrl = null'>
                                                    @L["Discard"]
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                            <div class="col-md-4">
                                <label class="form-label fw-bold">@L["PublicationYear"]</label>
                                <InputNumber class="form-control" @bind-Value="newBookYear" placeholder="YYYY" />
                            </div>

                            <div class="col-12 mt-3">
                                <label class="form-label fw-bold">@L["Description"]</label>
                                <InputTextArea class="form-control" @bind-Value="newBookDescription" rows="4" placeholder="@L["BookDescriptionPlaceholder"]" />
                            </div>

                            <div class="col-md-12 mt-3">
                                <label class="form-label fw-bold">@L["MainCategory"]</label>
                                <select class="form-select" @bind="mainCategoryString">
                                    @foreach (var cat in allCategories)
                                    {
                                        <option value="@cat.Value()">@cat.Value()</option>
                                    }
                                </select>
                            </div>

                            <div class="col-md-12 mt-3">
                                <label class="form-label fw-bold">@L["AvailabilityType"]</label>
                                <select class="form-select" @bind="newBookAvailability">
                                    <option value="Circulating">@L["Circulating"]</option>
                                    <option value="ReferenceOnly">@L["ReferenceOnly"]</option>
                                    <option value="Unspecified">@L["Unspecified"]</option>
                                </select>
                            </div>

                            <div class="col-12 mt-3">
                                <label class="form-label fw-bold">@L["AdditionalCategories"]</label>
                                <div class="input-group mb-2">
                                    <select class="form-select" @bind="categoryToAddString">
                                        @foreach (var cat in allCategories)
                                        {
                                            <option value="@cat.Value()">@cat.Value()</option>
                                        }
                                    </select>
                                    <button type="button" class="btn btn-outline-secondary" @onclick="AddAdditionalCategory">
                                        <i class="bi bi-plus-lg"></i> @L["Add"]
                                    </button>
                                </div>
                                <div class="d-flex flex-wrap gap-2">
                                    @if (additionalCategories.Count == 0)
                                    {
                                        <span class="text-muted small italic">@L["NoAdditionalCategories"]</span>
                                    }
                                    else
                                    {
                                        @foreach (var cat in additionalCategories)
                                        {
                                            <div class="badge bg-secondary p-2 d-flex align-items-center gap-2">
                                                @cat.Value()
                                                <button type="button" class="btn-close btn-close-white" style="font-size: 0.5rem" @onclick="() => additionalCategories.Remove(cat)"></button>
                                            </div>
                                        }
                                    }
                                </div>
                            </div>

                            <div class="col-12 mt-4">
                                <label class="form-label fw-bold d-flex justify-content-between">
                                    @L["Authors"] 
                                    <span class="badge bg-secondary">@selectedAuthors.Count @L["Selected"]</span>
                                </label>
                                <div class="selected-authors-container p-3 border rounded bg-white" style="min-height: 100px;">
                                    @if (selectedAuthors.Count == 0)
                                    {
                                        <p class="text-muted text-center mb-0 mt-3 small italic">@L["NoAuthorsAssociatedDescription"]</p>
                                    }
                                    else
                                    {
                                        <div class="d-flex flex-wrap gap-2">
                                            @foreach (var author in selectedAuthors)
                                            {
                                                <div class="badge bg-info text-dark p-2 d-flex align-items-center gap-2 shadow-sm font-monospace">
                                                    @author.Name.Value
                                                    <button type="button" class="btn-close btn-close-white" style="font-size: 0.5rem" @onclick="() => RemoveAuthor(author)"></button>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>

                            <div class="col-12 mt-5">
                                <button type="submit" class="btn btn-success btn-lg w-100 shadow">
                                    <i class="bi bi-cloud-arrow-up-fill me-2"></i>@L["CreateBookEntry"]
                                </button>
                            </div>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>

        <!-- Author Search (Right Side) -->
        <div class="col-lg-5">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-dark text-white py-3">
                    <h5 class="card-title mb-0"><i class="bi bi-person-search me-2"></i>@L["FindAuthors"]</h5>
                </div>
                <div class="card-body p-4">
                    <EditForm Model="@this" OnValidSubmit="HandleAuthorSearch" FormName="AuthorSearchForm">
                        <div class="row g-3 mb-4">
                            <div class="col-12">
                                <label class="form-label small fw-bold">@L["Name"]</label>
                                <InputText class="form-control" @bind-Value="searchAuthorName" placeholder="@L["SearchByName"]" />
                            </div>
                            <div class="col-12">
                                <label class="form-label small fw-bold">@L["IsniNumber"]</label>
                                <InputText class="form-control" @bind-Value="searchAuthorIsni" placeholder="@L["SearchByIsni"]" />
                            </div>
                            <div class="col-12">
                                <button type="submit" class="btn btn-outline-primary w-100">
                                    <i class="bi bi-search me-2"></i>@L["SearchAuthors"]
                                </button>
                            </div>
                        </div>
                    </EditForm>

                    <div class="author-results table-responsive border rounded">
                        <QuickGrid Items="@foundAuthors.AsQueryable()" Pagination="@pagination" Class="table table-sm table-hover mb-0">
                            <PropertyColumn Property="@(a => a.Name.Value)" Title="@L["Name"]" Class="small fw-bold" />
                            <TemplateColumn Title="@L["Actions"]" Align="Align.Center">
                                @if (selectedAuthors.Any(sa => sa.AuthorId == context.AuthorId))
                                {
                                    <span class="text-success"><i class="bi bi-check-circle-fill"></i></span>
                                }
                                else
                                {
                                    <button type="button" class="btn btn-sm btn-outline-primary shadow-sm" @onclick="() => AddAuthor(context)" title="@L["AddAuthor"]">
                                        <i class="bi bi-plus-circle-fill me-1"></i> @L["Add"]
                                    </button>
                                }
                            </TemplateColumn>
                        </QuickGrid>
                    </div>
                    <div class="mt-3 d-flex justify-content-center">
                        <Paginator State="@pagination" />
                    </div>
                </div>
            </div>
        </div>
    </div>
}
</div>

@code {

    private bool showAddSection = false;
    private string newBookTitle = "";
    private string newBookIsbn = "";
    private string newBookDescription = "";
    private bool allowInvalidIsbn = false;
    private bool isLookingUpMetadata = false;
    private int? newBookYear = DateTime.Now.Year;
    private List<Author> selectedAuthors = new();
    private bool isAutofilling = false;
    private List<GoogleBookMetadata> lookupResults = new();
    private int selectedLookupIndex = -1;
    private string newBookImageUrl = "";
    private string? coverPreviewUrl = null;
    private bool isLookingUpCover = false;

    private string searchAuthorName = "";
    private string searchAuthorIsni = "";
    private List<Author> foundAuthors = new();
    private PaginationState pagination = new() { ItemsPerPage = 5 };

    private string searchBookTitle = "";
    private string searchBookIsbn = "";
    private int? searchBookYear = null;
    private int? searchBookYearTo = null;
    private string yearSearchMode = "exact"; // exact, after, before, between
    
    private string authorSearchNameFilter ="";
    private List<Author> foundAuthorsForFilter = new();
    private string selectedAuthorIdForFilter = "";
    private List<Author> searchAuthorsCriteria = new();

    private string selectedCategoryForFilter = "";
    private List<Category> searchCategoriesCriteria = new();

    private string searchBookAvailability = "All"; // All, Circulating, ReferenceOnly
    private BookSearchCriteria searchCriteria = null;

    private string newBookAvailability = "Circulating";

    protected override void OnInitialized()
    {
        var configDefault = Configuration["DefaultAvailability"];
        if (!string.IsNullOrWhiteSpace(configDefault))
        {
            newBookAvailability = configDefault;
        }
    }

    private bool IsIsbnSearchActive => !string.IsNullOrWhiteSpace(searchBookIsbn);
    private bool IsNewBookIsbnValid 
    {
        get 
        {
            if (string.IsNullOrWhiteSpace(newBookIsbn)) return false;
            return Isbn.IsValid(newBookIsbn);
        }
    }

    private List<Book> foundBooks = new();
    private string titleRefinementFilter = "";
    private IQueryable<Book> FilteredBooks => 
        foundBooks.AsQueryable()
            .Where(b => string.IsNullOrEmpty(titleRefinementFilter) || 
                        b.Title.Value.Contains(titleRefinementFilter, StringComparison.OrdinalIgnoreCase));

    private bool searchBooksPerformed = false;
    private PaginationState bookPagination = new() { ItemsPerPage = 5 };
    private GridSort<Book> sortTitle = GridSort<Book>.ByAscending(b => b.Title.Value);
    private GridSort<Book> sortImage = GridSort<Book>.ByDescending(b => b.ImageUrl != null && FSharpOption<Uri>.get_IsSome(b.ImageUrl));

    private string statusMessage = "";
    private string statusClass = "alert-info";

    private Category mainCategory = Category.Other;
    private List<Category> additionalCategories = new();
    private Category categoryToAdd = Category.Other;

    private FSharpList<Category> allCategories = Category.AllCases();

    private string mainCategoryString 
    {
        get => mainCategory.Value();
        set => mainCategory = Category.FromString(value);
    }

    private string categoryToAddString
    {
        get => categoryToAdd.Value();
        set => categoryToAdd = Category.FromString(value);
    }

    private void AddAdditionalCategory()
    {
        if (categoryToAdd != null && !additionalCategories.Contains(categoryToAdd) && categoryToAdd != mainCategory)
        {
            additionalCategories.Add(categoryToAdd);
        }
    }

    private async Task HandleAuthorSearch()
    {
        bool hasName = !string.IsNullOrWhiteSpace(searchAuthorName);
        bool hasIsni = !string.IsNullOrWhiteSpace(searchAuthorIsni);

        FSharpResult<FSharpList<Author>, string> result;

        if (hasName && hasIsni)
        {
            var name = Name.New(searchAuthorName);
            var isni = Isni.NewInvalid(searchAuthorIsni);
            result = await AuthorService.SearchByIsniAndNameAsync(isni, name);
        }
        else if (hasName)
        {
            var name = Name.New(searchAuthorName);
            result = await AuthorService.SearchByNameAsync(name);
        }
        else if (hasIsni)
        {
            var isni = Isni.NewInvalid(searchAuthorIsni);
            result = await AuthorService.SearchByIsniAsync(isni);
        }
        else
        {
            result = await AuthorService.GetAllAsync();
        }

        if (result.IsOk)
        {
            foundAuthors = result.ResultValue.ToList();
        }
        else
        {
            ShowStatus(L["ErrorSearchingAuthors", result.ErrorValue], "alert-danger");
        }
    }

    private async Task SearchAuthorsForFilter()
    {
        if (string.IsNullOrWhiteSpace(authorSearchNameFilter)) return;
        
        var name = Name.New(authorSearchNameFilter);
        var result = await AuthorService.SearchByNameAsync(name);
        
        if (result.IsOk)
        {
            foundAuthorsForFilter = result.ResultValue.ToList();
            if (!foundAuthorsForFilter.Any())
            {
                ShowStatus(L["NoAuthorsFoundMatchingName"], "alert-warning");
            }
        }
        else
        {
            ShowStatus(L["ErrorSearchingAuthors", result.ErrorValue], "alert-danger");
        }
    }

    private void AddAuthorToSearchCriteria()
    {
        if (string.IsNullOrEmpty(selectedAuthorIdForFilter)) return;
        
        var author = foundAuthorsForFilter.FirstOrDefault(a => a.AuthorId.Value.ToString() == selectedAuthorIdForFilter);
        if (author != null && !searchAuthorsCriteria.Any(a => a.AuthorId == author.AuthorId))
        {
            searchAuthorsCriteria.Add(author);
        }
    }

    private void RemoveAuthorFromSearchCriteria(Author author)
    {
        searchAuthorsCriteria.Remove(author);
    }

    private void AddCategoryToSearchCriteria()
    {
        if (string.IsNullOrEmpty(selectedCategoryForFilter)) return;
        var category = Category.FromString(selectedCategoryForFilter);
        if (!searchCategoriesCriteria.Contains(category))
        {
            searchCategoriesCriteria.Add(category);
        }
    }

    private void RemoveCategoryFromSearchCriteria(Category category)
    {
        searchCategoriesCriteria.Remove(category);
    }

    private async Task HandleBookSearch()
    {
        searchBooksPerformed = true;
        
        bool hasTitle = !string.IsNullOrWhiteSpace(searchBookTitle);
        bool hasIsbn = !string.IsNullOrWhiteSpace(searchBookIsbn);
        bool hasYear = searchBookYear.HasValue;
        bool hasBetweenYear = yearSearchMode == "between" && searchBookYear.HasValue && searchBookYearTo.HasValue;

        if (string.IsNullOrEmpty(searchBookAvailability) || searchBookAvailability == "All")
        {
            searchCriteria = null;
        }
        else
        {
            searchCriteria = book => 
                (searchBookAvailability == "Circulating" && book.Availability.IsCirculating) || 
                (searchBookAvailability == "ReferenceOnly" && book.Availability.IsReferenceOnly) ||
                (searchBookAvailability == "Unspecified" && book.Availability.IsUnspecified);
        }

        FSharpResult<FSharpList<Book>, string> result;

        if (hasIsbn)
        {
            var isbn = Isbn.NewInvalid(searchBookIsbn);
            if (hasTitle)
            {
                result = await BookService.SearchByIsbnOrTitleAsync(isbn, Title.New(searchBookTitle), criteria: searchCriteria);
            }
            else
            {
                result = await BookService.SearchByIsbnAsync(isbn, criteria: searchCriteria);
            }
        }
        else 
        {
            YearSearch GetYearSearch() {
                var year = searchBookYear ?? 0;
                var yearTo = searchBookYearTo ?? 0;
                return yearSearchMode switch
                {
                    "after" => YearSearch.NewAfter(year),
                    "before" => YearSearch.NewBefore(year),
                    "between" => YearSearch.NewRange(year, yearTo),
                    _ => YearSearch.NewExact(year)
                };
            }
            
            bool hasEffectiveYear = hasYear || hasBetweenYear;
            
            if (searchCategoriesCriteria.Any())
            {
                var authorIds = ListModule.OfSeq(searchAuthorsCriteria.Select(a => a.AuthorId));
                var categories = ListModule.OfSeq(searchCategoriesCriteria);
                var yearSearch = GetYearSearch();
                bool hasAuthors = searchAuthorsCriteria.Any();
                
                if (hasAuthors)
                {
                    if (hasTitle && hasEffectiveYear)
                    {
                        result = await BookService.SearchByTitleAndAuthorsAndYearAndCategoriesAsync(Title.New(searchBookTitle), authorIds, yearSearch, categories, criteria: searchCriteria);
                    }
                    else if (hasTitle)
                    {
                        result = await BookService.SearchByTitleAndAuthorsAndCategoriesAsync(Title.New(searchBookTitle), authorIds, categories, criteria: searchCriteria);
                    }
                    else if (hasEffectiveYear)
                    {
                        result = await BookService.SearchByAuthorsAndYearAndCategoriesAsync(authorIds, yearSearch, categories, criteria: searchCriteria);
                    }
                    else
                    {
                        result = await BookService.SearchByAuthorsAndCategoriesAsync(authorIds, categories, criteria: searchCriteria); 
                    }
                }
                else
                {
                    if (hasTitle && hasEffectiveYear)
                    {
                        result = await BookService.SearchByTitleAndYearAndCategoriesAsync(Title.New(searchBookTitle), yearSearch, categories, criteria: searchCriteria);
                    }
                    else if (hasTitle)
                    {
                        result = await BookService.SearchByTitleAndCategoriesAsync(Title.New(searchBookTitle), categories, criteria: searchCriteria);
                    }
                    else if (hasEffectiveYear)
                    {
                        result = await BookService.SearchByYearAndCategoriesAsync(yearSearch, categories, criteria: searchCriteria);
                    }
                    else
                    {
                        result = await BookService.SearchByCategoriesAsync(categories, criteria: searchCriteria);
                    }
                }
            }
            else if (searchAuthorsCriteria.Any())
            {
                var authorIds = ListModule.OfSeq(searchAuthorsCriteria.Select(a => a.AuthorId));
                if (hasTitle && hasEffectiveYear)
                {
                    result = await BookService.SearchByTitleAndAuthorsAndYearAsync(Title.New(searchBookTitle), authorIds, GetYearSearch(), criteria: searchCriteria);
                }
                else if (hasTitle)
                {
                    result = await BookService.SearchByTitleAndAuthorsAsync(Title.New(searchBookTitle), authorIds, criteria: searchCriteria);
                }
                else if (hasEffectiveYear)
                {
                    result = await BookService.SearchByAuthorsAndYearAsync(authorIds, GetYearSearch(), criteria: searchCriteria);
                }
                else
                {
                    result = await BookService.SearchByAuthorsAsync(authorIds, criteria: searchCriteria);
                }
            }
            else if (hasTitle && hasEffectiveYear)
            {
                result = await BookService.SearchByTitleAndYearAsync(Title.New(searchBookTitle), GetYearSearch(), criteria: searchCriteria);
            }
            else if (hasTitle)
            {
                result = await BookService.SearchByTitleAsync(Title.New(searchBookTitle), criteria: searchCriteria);
            }
            else if (hasEffectiveYear)
            {
                result = await BookService.SearchByYearAsync(GetYearSearch(), criteria: searchCriteria);
            }
            else
            {
                result = await BookService.GetAllAsync(criteria: searchCriteria);
            }
        }

        if (result.IsOk)
        {
            foundBooks = result.ResultValue.ToList();
        }
        else
        {
            ShowStatus(L["ErrorSearchingBooks", result.ErrorValue], "alert-danger");
        }
    }

    private void AddAuthor(Author author)
    {
        if (!selectedAuthors.Any(a => a.AuthorId == author.AuthorId))
        {
            selectedAuthors.Add(author);
        }
    }

    private void RemoveAuthor(Author author)
    {
        selectedAuthors.RemoveAll(a => a.AuthorId == author.AuthorId);
    }

    private async Task HandleAddBook()
    {
        if (string.IsNullOrWhiteSpace(newBookTitle))
        {
            ShowStatus(L["TitleIsRequired"], "alert-warning");
            return;
        }

        if (!newBookYear.HasValue)
        {
            ShowStatus(L["YearIsRequired"], "alert-warning");
            return;
        }

        Isbn isbn;
        if (string.IsNullOrWhiteSpace(newBookIsbn))
        {
            isbn = Isbn.EmptyIsbn;
        }
        else if (allowInvalidIsbn)
        {
            isbn = Isbn.NewInvalid(newBookIsbn);
        }
        else
        {
            var isbnResult = Isbn.New(newBookIsbn);
            if (isbnResult.IsError)
            {
                ShowStatus(L["InvalidIsniValue", isbnResult.ErrorValue], "alert-danger");
                return;
            }
            isbn = isbnResult.ResultValue;
        }

        var title = Title.New(newBookTitle);
        var year = Year.New(newBookYear.Value);
        var authorIds = selectedAuthors.Select(a => a.AuthorId).ToList();

        FSharpOption<Uri> resolvedImageUrl = FSharpOption<Uri>.None;
        if (!string.IsNullOrWhiteSpace(newBookImageUrl))
        {
            if (Uri.TryCreate(newBookImageUrl, UriKind.Absolute, out var uri))
            {
                resolvedImageUrl = FSharpOption<Uri>.Some(uri);
            }
        }

        // Construct the book aggregate using the new constructor with categories.
        var book = Book.New(
            title, 
            ListModule.OfSeq(authorIds),
            ListModule.OfSeq(Enumerable.Empty<AuthorId>()),
            ListModule.OfSeq(Enumerable.Empty<System.Globalization.CultureInfo>()),
            FSharpOption<EditorId>.None,
            mainCategory,
            ListModule.OfSeq(additionalCategories),
            year,
            isbn,
            resolvedImageUrl
        );

        var result = await BookService.AddBookAsync(book);

        if (result.IsOk)
        {
            if (!string.IsNullOrWhiteSpace(newBookDescription))
            {
                await BookService.UpdateDescriptionAsync(newBookDescription, book.BookId, FSharpOption<System.Threading.CancellationToken>.None);
            }
            
            var availability = BookLibrary.Shared.Commons.Availability.FromString(newBookAvailability);
            await BookService.SetAvailabilityAsync(availability, book.BookId, FSharpOption<System.Threading.CancellationToken>.None);

            ShowStatus(L["BookCreatedSuccessfully", newBookTitle], "alert-success");
            ResetForm();
        }
        else
        {
            ShowStatus(L["ErrorCreatingBook", result.ErrorValue], "alert-danger");
        }
    }

    private void ShowStatus(string message, string cssClass)
    {
        statusMessage = message;
        statusClass = cssClass;
    }

    private void ResetForm()
    {
        newBookTitle = "";
        newBookIsbn = "";
        newBookDescription = "";
        allowInvalidIsbn = false;
        newBookYear = DateTime.Now.Year;
        selectedAuthors.Clear();
        mainCategory = Category.Other;
        additionalCategories.Clear();
        newBookImageUrl = "";
        coverPreviewUrl = null;
        newBookAvailability = Configuration["DefaultAvailability"] ?? "Circulating";
    }

    private async Task PerformGoogleLookup()
    {
        if (string.IsNullOrWhiteSpace(newBookTitle))
        {
            ShowStatus(L["EnterTitleToSearch"], "alert-warning");
            return;
        }

        isAutofilling = true;
        lookupResults.Clear();
        selectedLookupIndex = -1;
        StateHasChanged();

        try
        {
            var result = await GoogleBooksService.LookupMultipleByTitleAsync(newBookTitle);

            if (result.IsOk)
            {
                lookupResults = result.ResultValue.ToList();
                if (!lookupResults.Any())
                {
                    ShowStatus(L["NoBooksFoundTitle"], "alert-warning");
                }
                else
                {
                    ShowStatus(L["FoundResultsFromApi", lookupResults.Count], "alert-info");
                }
            }
            else
            {
                ShowStatus(L["ErrorSearchingApi", result.ErrorValue], "alert-danger");
            }
        }
        catch (Exception ex)
        {
            ShowStatus(L["ErrorDuringLookup", ex.Message], "alert-danger");
        }
        finally
        {
            isAutofilling = false;
        }
    }

    private async Task AutofillFromSelected()
    {
        if (selectedLookupIndex < 0 || selectedLookupIndex >= lookupResults.Count) return;

        var metadata = lookupResults[selectedLookupIndex];
        isAutofilling = true;
        StateHasChanged();

        try
        {
            newBookTitle = metadata.Title;
            if (FSharpOption<string>.get_IsSome(metadata.Isbn) && !string.IsNullOrWhiteSpace(metadata.Isbn.Value))
            {
                newBookIsbn = metadata.Isbn.Value;
            }
            
            if (FSharpOption<int>.get_IsSome(metadata.Year))
            {
                newBookYear = metadata.Year.Value;
            }
            
            if (FSharpOption<string>.get_IsSome(metadata.Description))
            {
                newBookDescription = metadata.Description.Value;
            }

            // Categories
            if (metadata.Categories != null && metadata.Categories.Any())
            {
                var firstCatStr = metadata.Categories.First();
                try 
                {
                    var domainCat = Category.FromString(firstCatStr);
                    mainCategory = domainCat;
                } 
                catch 
                {
                    ShowStatus(L["MappingCategoryWarning", firstCatStr], "alert-warning");
                }
            }

            // Authors
            if (metadata.Authors != null && metadata.Authors.Any())
            {
                selectedAuthors.Clear();
                foreach (var authorName in metadata.Authors)
                {
                    var nameCriteria = Name.New(authorName);
                    var authorResult = await AuthorService.SearchByNameAsync(nameCriteria);
                    if (authorResult.IsOk && authorResult.ResultValue.Any())
                    {
                        selectedAuthors.Add(authorResult.ResultValue.First());
                    }
                    else
                    {
                        bool create = await JSRuntime.InvokeAsync<bool>("confirm", L["AuthorNotFoundCreateAssign", authorName].Value);
                        if (create)
                        {
                            var newAuthor = Author.NewWithoutIsni(nameCriteria);
                            var addResult = await AuthorService.AddAuthorAsync(newAuthor);
                            if (addResult.IsOk)
                            {
                                selectedAuthors.Add(newAuthor);
                            }
                            else 
                            {
                                ShowStatus(L["FailedToCreateAuthor", authorName], "alert-danger");
                            }
                        }
                    }
                }
            }
            
            ShowStatus(L["FieldsPopulatedReview"], "alert-success");
            lookupResults.Clear();
            selectedLookupIndex = -1;
        }
        catch (Exception ex)
        {
            ShowStatus(L["ErrorAutofillingFields", ex.Message], "alert-danger");
        }
        finally
        {
            isAutofilling = false;
        }
    }

    private async Task AutofillBookInfo() => await PerformGoogleLookup();

    private async Task LookupCoverImage()
    {
        if (!IsNewBookIsbnValid) return;

        isLookingUpCover = true;
        coverPreviewUrl = null;
        StateHasChanged();

        try
        {
            var isbnResult = Isbn.New(newBookIsbn);
            if (isbnResult.IsOk)
            {
                var result = await GoogleBooksService.LookupCoverImageByIsbnWithOpenApiAndThenGoogleAsync(isbnResult.ResultValue, FSharpOption<ThumbRoughSize>.Some(ThumbRoughSize.Medium));
                if (result.IsOk && FSharpOption<string>.get_IsSome(result.ResultValue))
                {
                    coverPreviewUrl = result.ResultValue.Value;
                    ShowStatus(L["CoverImageFoundCatalogs"], "alert-info");
                }
                else
                {
                    ShowStatus(L["NoCoverImageFoundIsbn"], "alert-warning");
                }
            }
        }
        catch (Exception ex)
        {
            ShowStatus(L["ErrorLookingUpCover", ex.Message], "alert-danger");
        }
        finally
        {
            isLookingUpCover = false;
        }
    }

    private void AcceptCoverUrl()
    {
        if (!string.IsNullOrEmpty(coverPreviewUrl))
        {
            newBookImageUrl = coverPreviewUrl;
            coverPreviewUrl = null;
            ShowStatus(L["CoverUrlApplied"], "alert-success");
        }
    }

    private async Task LookupMetadataByIsbn()
    {
        if (!IsNewBookIsbnValid) return;

        isLookingUpMetadata = true;
        StateHasChanged();

        try
        {
            var result = await GoogleBooksService.LookupByIsbnAsync(newBookIsbn);
            if (result.IsOk && FSharpOption<GoogleBookMetadata>.get_IsSome(result.ResultValue))
            {
                var metadata = result.ResultValue.Value;
                
                newBookTitle = metadata.Title;
                
                if (FSharpOption<int>.get_IsSome(metadata.Year))
                {
                    newBookYear = metadata.Year.Value;
                }
                
                if (FSharpOption<string>.get_IsSome(metadata.Description))
                {
                    newBookDescription = metadata.Description.Value;
                }
                
                // Authors
                if (metadata.Authors != null && metadata.Authors.Any())
                {
                    selectedAuthors.Clear();
                    foreach (var authorName in metadata.Authors)
                    {
                        var nameCriteria = Name.New(authorName);
                        var authorResult = await AuthorService.SearchByNameAsync(nameCriteria);
                        if (authorResult.IsOk && authorResult.ResultValue.Any())
                        {
                            selectedAuthors.Add(authorResult.ResultValue.First());
                        }
                    }
                }
                
                // Categories
                if (metadata.Categories != null && metadata.Categories.Any())
                {
                    var firstCatStr = metadata.Categories.First();
                    try 
                    {
                        var domainCat = Category.FromString(firstCatStr);
                        mainCategory = domainCat;
                    } 
                    catch 
                    {
                        // Quietly fail for category mapping
                    }
                }

                ShowStatus(L["FieldsPopulatedReview"], "alert-success");
            }
            else
            {
                ShowStatus(L["MetadataNotFound"], "alert-warning");
            }
        }
        catch (Exception ex)
        {
            ShowStatus(L["ErrorLookingUpMetadata", ex.Message], "alert-danger");
        }
        finally
        {
            isLookingUpMetadata = false;
        }
    }
}
