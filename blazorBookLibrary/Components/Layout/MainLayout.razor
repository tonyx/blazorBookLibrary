@inherits LayoutComponentBase
@using blazorBookLibrary.Components.Shared
@inject NavigationManager NavigationManager

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main class="main-content">
        <div class="top-row">
            <div class="top-row-inner d-flex align-items-center justify-content-end w-100 px-4">
                <CultureSelector currentUrl="@currentUrl" />
            </div>
        </div>

        <div class="sanctuary-viewport">
            @Body
        </div>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    <div class="d-flex align-items-center gap-3">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <span>An unexpected error occurred in the repository interface.</span>
        <a href="." class="reload btn btn-sm btn-outline-dark">Reload</a>
        <span class="dismiss ms-auto">🗙</span>
    </div>
</div>

@code {
    private string? currentUrl;

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += (s, e) => {
            currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
            StateHasChanged();
        };
    }
}

<style>
    .main-content {
        min-height: 100vh;
        background-color: var(--surface);
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .top-row {
        height: 4rem;
        background-color: var(--surface-container-lowest);
        border-bottom: 1px solid var(--outline-variant);
        position: sticky;
        top: 0;
        z-index: 50;
        display: flex;
        align-items: center;
    }

    .sanctuary-viewport {
        flex: 1;
        overflow-y: auto;
    }

    #blazor-error-ui {
        background: var(--error-container);
        color: var(--on-error-container);
        padding: 1rem 2rem;
        font-weight: 600;
        display: none;
        position: fixed;
        bottom: 0;
        width: 100%;
        z-index: 1000;
        box-shadow: 0 -4px 20px rgba(0,0,0,0.1);
        border-top: 1px solid var(--error);
    }
</style>
