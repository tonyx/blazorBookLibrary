@page "/Account/Manage/PersonalData"

@using Microsoft.AspNetCore.Identity
@using blazorBookLibrary.Data
@using BookLibrary.Domain
@using BookLibrary.Shared.Services
@using static BookLibrary.Shared.Commons

@inject UserManager<ApplicationUser> UserManager
@inject IStringLocalizer<SharedResources> L
@inject IReviewService ReviewService
@inject IdentityRedirectManager RedirectManager

<PageTitle>@L["PersonalData"]</PageTitle>

<StatusMessage />
<h3>@L["PersonalData"]</h3>

<div class="row">
    <div class="col-md-6">
        <p>@L["PersonalDataInfo"]</p>
        <p>
            <strong>@L["PersonalDataDeleteWarning"]</strong>
        </p>
        <form action="Account/Manage/DownloadPersonalData" method="post">
            <AntiforgeryToken />
            <button class="btn btn-primary" type="submit">@L["Download"]</button>
        </form>
        <p class="mt-3">
            <a href="Account/Manage/DeletePersonalData" class="btn btn-danger">@L["Delete"]</a>
        </p>
    </div>
</div>

<div class="row mt-5">
    <div class="col-md-8">
        <div class="card-sanctuary p-4">
            <h4 class="text-serif mb-4">@L["MyReviews"]</h4>
            @if (reviews == null)
            {
                <div class="d-flex align-items-center gap-3 text-muted italic">
                    <div class="spinner-border spinner-border-sm" role="status"></div>
                    <span>@L["Loading"]...</span>
                </div>
            }
            else if (!reviews.Any())
            {
                <div class="p-4 bg-surface-low rounded-lg text-center italic text-muted">
                    <i class="bi bi-chat-left-text d-block mb-2 fs-4"></i>
                    @L["NoReviewsFound"]
                </div>
            }
            else
            {
                <div class="list-group list-group-flush shadow-sm rounded-lg border overflow-hidden">
                    @foreach (var item in reviews)
                    {
                        var book = item.Item1;
                        var review = item.Item2;
                        <div class="list-group-item list-group-item-action p-4">
                            <div class="d-flex flex-column flex-md-row justify-content-between gap-3">
                                <div class="flex-grow-1">
                                    <div class="d-flex align-items-center gap-2 mb-1">
                                        <h5 class="h6 mb-0 text-serif">@book.Title.Value</h5>
                                        <div class="d-flex gap-1">
                                            @{
                                                var status = review.ApprovalStatus;
                                                var badgeClass = status.IsApproved ? "bg-success" : (status.IsRejected ? "bg-danger" : "bg-warning text-dark");
                                                var statusLabel = status.IsApproved ? L["Approved"] : (status.IsRejected ? L["Rejected"] : L["Pending"]);
                                            }
                                            <span class="badge @badgeClass px-2 py-1 small" style="font-size: 0.7rem;">@statusLabel</span>
                                            @if (review.Hidden)
                                            {
                                                <span class="badge bg-secondary px-2 py-1 small" style="font-size: 0.7rem;">@L["Hidden"]</span>
                                            }
                                        </div>
                                    </div>
                                    <p class="mb-0 text-muted small text-truncate-2 italic">
                                        "@review.Comment"
                                    </p>
                                    <div class="small text-muted mt-2" style="font-size: 0.75rem;">
                                        <i class="bi bi-calendar3 me-1"></i> @review.Date.ToLocalTime().ToString("d MMM yyyy")
                                    </div>
                                </div>
                                <div class="d-flex align-items-center">
                                    <a href="edit-review/@review.ReviewId.Value" class="btn btn-sm btn-outline-primary shadow-sm px-3">
                                        <i class="bi bi-pencil-square me-1"></i> @L["EditReview"]
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

<style>
    .text-truncate-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .rounded-lg { border-radius: 12px !important; }
    .bg-surface-low { background-color: var(--surface-low, #f8f9fa); }
</style>

@code {
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    private List<Tuple<Book, Review>>? reviews;

    protected override async Task OnInitializedAsync()
    {
        var user = await UserManager.GetUserAsync(HttpContext.User);
        if (user is null)
        {
            RedirectManager.RedirectToInvalidUser(UserManager, HttpContext);
            return;
        }

        var userIdStr = await UserManager.GetUserIdAsync(user);
        if (Guid.TryParse(userIdStr, out var userGuid))
        {
            var result = await ReviewService.GetReviewsOfUserAsync(UserId.NewUserId(userGuid));
            if (result.IsOk)
            {
                // Convert F# list to C# list
                reviews = result.ResultValue.Select(x => Tuple.Create(x.Item1, x.Item2)).ToList();
            }
            else
            {
                reviews = new();
            }
        }
    }
}
