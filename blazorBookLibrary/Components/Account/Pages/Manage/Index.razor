@page "/Account/Manage"

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Identity
@using blazorBookLibrary.Data
@using BookLibrary.Shared.Services
@using blazorBookLibrary.Shared.Resources

@inject UserManager<ApplicationUser> UserManager
@inject IUserService UserService
@inject SignInManager<ApplicationUser> SignInManager
@inject IStringLocalizer<SharedResources> L
@inject IdentityRedirectManager RedirectManager

<PageTitle>@L["Profile"]</PageTitle>

<h3>@L["Profile"]</h3>
<StatusMessage />

<div class="row">
    <div class="col-xl-6">
        <EditForm Model="Input" FormName="profile" OnValidSubmit="OnValidSubmitAsync" method="post">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" role="alert" />
            <div class="mb-4">
                <label class="form-label d-block text-muted small text-uppercase fw-bold mb-2">@L["AccountVerificationStatus"]</label>
                @if (isIdentified)
                {
                    <span class="badge bg-success py-2 px-3 fs-6 rounded-pill shadow-sm">
                        <i class="bi bi-patch-check-fill me-2"></i>@L["PhysicallyIdentifiedVerified"]
                    </span>
                    <p class="text-muted small mt-2 mb-0">@L["IdentityVerifiedLibrarianLocked"]</p>
                }
                else
                {
                    <span class="badge bg-secondary py-2 px-3 fs-6 rounded-pill">
                        <i class="bi bi-person-exclamation me-2"></i>@L["PendingPhysicalIdentification"]
                    </span>
                    <p class="text-muted small mt-2 mb-0">@L["VisitLibraryToVerify"]</p>
                }
            </div>

            <div class="form-floating mb-3">
                <input type="text" value="@username" id="username" class="form-control" placeholder="@username" disabled />
                <label for="username" class="form-label">@L["Username"]</label>
            </div>
            
            <div class="row">
                <div class="col-md-6 px-1">
                    <div class="form-floating mb-3">
                        <InputText @bind-Value="Input.Name" id="Input.Name" class="form-control" placeholder="@L["Name"]" />
                        <label for="Input.Name" class="form-label">@L["Name"]</label>
                        <ValidationMessage For="() => Input.Name" class="text-danger" />
                    </div>
                </div>
                <div class="col-md-6 px-1">
                    <div class="form-floating mb-3">
                        <InputText @bind-Value="Input.Surname" id="Input.Surname" class="form-control" placeholder="@L["Surname"]" />
                        <label for="Input.Surname" class="form-label">@L["Surname"]</label>
                        <ValidationMessage For="() => Input.Surname" class="text-danger" />
                    </div>
                </div>
            </div>
            <div class="form-floating mb-3">
                <InputText @bind-Value="Input.PhoneNumber" id="Input.PhoneNumber" class="form-control" placeholder="@L["PhoneNumber"]" />
                <label for="Input.PhoneNumber" class="form-label">@L["PhoneNumber"]</label>
                <ValidationMessage For="() => Input.PhoneNumber" class="text-danger" />
            </div>
            
            <div class="form-floating mb-3">
@if (isIdentified)
                {
                    <input type="text" value="@Input.CodiceFiscale" class="form-control" id="Input.CodiceFiscale" readonly disabled />
                    <label for="Input.CodiceFiscale" class="form-label">@L["FiscalCodeVerified"]</label>
                    <div class="form-text text-success small mt-1">
                        <i class="bi bi-patch-check-fill me-1"></i>@L["IdentityVerifiedLocked"]
                    </div>
                }
                else
                {
                    <InputText @bind-Value="Input.CodiceFiscale" id="Input.CodiceFiscale" class="form-control text-uppercase" placeholder="RSSMRA80A01H501U" />
                    <label for="Input.CodiceFiscale" class="form-label">@L["FiscalCode"]</label>
                    <ValidationMessage For="() => Input.CodiceFiscale" class="text-danger" />
                    <div class="form-text small mt-1">@L["FiscalCodeVerificationSubject"]</div>
                }
            </div>

            <button type="submit" class="w-100 btn btn-lg btn-primary">@L["Save"]</button>
        </EditForm>
    </div>
</div>

@code {
    private ApplicationUser? user;
    private string? username;
    private string? phoneNumber;
    private string? codiceFiscale;
    private string? nome;
    private string? cognome;
    private bool isIdentified;

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        Input ??= new();

        user = await UserManager.GetUserAsync(HttpContext.User);
        if (user is null)
        {
            RedirectManager.RedirectToInvalidUser(UserManager, HttpContext);
            return;
        }

        username = await UserManager.GetUserNameAsync(user);
        phoneNumber = await UserManager.GetPhoneNumberAsync(user);
        codiceFiscale = user.CodiceFiscale;
        nome = user.Nome;
        cognome = user.Cognome;
        isIdentified = user.IsIdentifiedPhysically;

        Input.PhoneNumber ??= phoneNumber;
        Input.CodiceFiscale ??= codiceFiscale;
        Input.Name ??= nome;
        Input.Surname ??= cognome;
    }

    private async Task OnValidSubmitAsync()
    {
        if (user is null)
        {
            RedirectManager.RedirectToInvalidUser(UserManager, HttpContext);
            return;
        }

        bool changed = false;
        List<string> successMessages = new();

        if ((Input.Name ?? "") != (nome ?? ""))
        {
            if (Guid.TryParse(user.Id, out var userGuid))
            {
                var userId = UserId.NewUserId(userGuid);
                var result = await UserService.SetNameAsync(userId, Input.Name ?? "", default);
                if (!result.IsOk)
                {
                    RedirectManager.RedirectToCurrentPageWithStatus($"Error: {result.ErrorValue}", HttpContext);
                    return;
                }
                changed = true;
                successMessages.Add(L["NameUpdated"]);
            }
        }

        if ((Input.Surname ?? "") != (cognome ?? ""))
        {
            if (Guid.TryParse(user.Id, out var userGuid))
            {
                var userId = UserId.NewUserId(userGuid);
                var result = await UserService.SetSurnameAsync(userId, Input.Surname ?? "", default);
                if (!result.IsOk)
                {
                    RedirectManager.RedirectToCurrentPageWithStatus($"Error: {result.ErrorValue}", HttpContext);
                    return;
                }
                changed = true;
                successMessages.Add(L["SurnameUpdated"]);
            }
        }

        // Manual validation for phone number if provided
        if (!string.IsNullOrWhiteSpace(Input.PhoneNumber))
        {
            var phoneAttr = new PhoneAttribute();
            if (!phoneAttr.IsValid(Input.PhoneNumber))
            {
                RedirectManager.RedirectToCurrentPageWithStatus($"{L["Error"]}: {L["InvalidPhoneNumber"]}", HttpContext);
                return;
            }
        }

        if ((Input.PhoneNumber ?? "") != (phoneNumber ?? ""))
        {
            if (Guid.TryParse(user.Id, out var userGuid))
            {
                var userId = UserId.NewUserId(userGuid);
                BookLibrary.Shared.Commons.PhoneNumber phoneObj;
                string statusMsg;

                if (BookLibrary.Shared.Commons.PhoneNumber.IsValid(Input.PhoneNumber ?? ""))
                {
                    phoneObj = BookLibrary.Shared.Commons.PhoneNumber.NewPhoneNumber(Input.PhoneNumber ?? "");
                    statusMsg = L["ValidPhoneNumberUpdated"];
                }
                else
                {
                    phoneObj = BookLibrary.Shared.Commons.PhoneNumber.NewInvalidPhoneNumber(Input.PhoneNumber ?? "");
                    statusMsg = L["InvalidPhoneNumberUpdated"];
                }

                var result = await UserService.SetPhoneNumberAsync(userId, phoneObj, default);
                if (!result.IsOk)
                {
                    RedirectManager.RedirectToCurrentPageWithStatus($"Error: {result.ErrorValue}", HttpContext);
                    return;
                }
                changed = true;
                successMessages.Add(statusMsg);
            }
        }

        if (!isIdentified && (Input.CodiceFiscale ?? "") != (codiceFiscale ?? ""))
        {
            if (Guid.TryParse(user.Id, out var userGuid))
            {
                var userId = UserId.NewUserId(userGuid);
                BookLibrary.Shared.Commons.FiscalCode fiscalObj;
                string statusMsg;
                string cfInput = Input.CodiceFiscale?.ToUpper() ?? string.Empty;

                if (BookLibrary.Shared.Commons.FiscalCode.IsValid(cfInput))
                {
                    fiscalObj = BookLibrary.Shared.Commons.FiscalCode.NewFiscalCode(cfInput);
                    statusMsg = L["ValidFiscalCodeUpdated"];
                }
                else
                {
                    fiscalObj = BookLibrary.Shared.Commons.FiscalCode.NewInvalidFiscalCode(cfInput);
                    statusMsg = L["InvalidFiscalCodeUpdated"];
                }

                var result = await UserService.SetFiscalCodeAsync(userId, fiscalObj, default);
                if (!result.IsOk)
                {
                    RedirectManager.RedirectToCurrentPageWithStatus($"Error: {result.ErrorValue}", HttpContext);
                    return;
                }
                changed = true;
                successMessages.Add(statusMsg);
            }
        }

        if (changed)
        {
            await SignInManager.RefreshSignInAsync(user);
            string finalMsg = successMessages.Count > 0 ? string.Join(", ", successMessages) : L["ProfileUpdated"];
            RedirectManager.RedirectToCurrentPageWithStatus(finalMsg, HttpContext);
        }
    }

    private sealed class InputModel
    {
        [Required]
        [Display(Name = "Name")]
        public string? Name { get; set; }

        [Required]
        [Display(Name = "Surname")]
        public string? Surname { get; set; }

        [Display(Name = "Phone number")]
        public string? PhoneNumber { get; set; }

        [MaxLength(16)]
        [Display(Name = "Fiscal Code")]
        public string? CodiceFiscale { get; set; }
    }
}
