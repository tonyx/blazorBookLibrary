@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.QuickGrid
@using BookLibrary.Shared.Services
@using BookLibrary.Domain
@using static BookLibrary.Shared.Commons
@using Microsoft.FSharp.Core
@using Microsoft.FSharp.Collections
@using static BookLibrary.Shared.SearchCriteria
@using System.Threading
@using Microsoft.Extensions.Localization
@inject IBookService BookService
@inject IAuthorService AuthorService
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<SharedResources> L

@if (_isLoading || isLoadingAuthors)
{
    <img src="/images/loading-gif.gif" alt="Uploading..." style="height:32px;"/>
}
<div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-secondary text-white py-3">
        <h5 class="card-title mb-0"><i class="bi bi-search me-2"></i>@L["SearchBooks"]</h5>
    </div>
    <div class="card-body bg-light">
        <EditForm Model="@this" OnValidSubmit="HandleBookSearch" FormName="SearchBookComponentForm">
            <div class="row g-3 align-items-start">
                <div class="col-md-4">
                    <label class="form-label fw-bold small text-muted text-uppercase mb-2">@L["TitleSearch"]</label>
                    <InputText class="form-control border-primary shadow-sm py-2" @bind-Value="searchBookTitle" placeholder="@L["SearchByTitlePlaceholder"]" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold small text-muted text-uppercase mb-2">@L["IsbnSearch"]</label>
                    <InputText class="form-control border-primary shadow-sm py-2" @bind-Value="searchBookIsbn" placeholder="@L["PartialIsbnPlaceholder"]" />
                </div>
                <div class="col-md-4 @(IsIsbnSearchActive ? "opacity-50" : "") transition-opacity" style="transition: opacity 0.3s ease;">
                    <label class="form-label fw-bold small text-muted text-uppercase mb-2 @(IsIsbnSearchActive ? "text-decoration-line-through" : "")">
                        <i class="bi bi-calendar-range me-1"></i>@L["PublicationYear"]
                    </label>
                    <div class="year-search-container bg-white p-2 rounded shadow-sm border @(IsIsbnSearchActive ? "bg-light border-secondary-subtle" : "border-primary-subtle")">
                        <fieldset disabled="@IsIsbnSearchActive">
                            <div class="d-flex flex-wrap gap-2 mb-2">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="yearSearchOption" id="exactYear" value="exact" 
                                           checked='@(yearSearchMode == "exact")' @onclick='() => yearSearchMode = "exact"' />
                                    <label class="form-check-label small" for="exactYear">@L["Exact"]</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="yearSearchOption" id="afterYear" value="after" 
                                           checked='@(yearSearchMode == "after")' @onclick='() => yearSearchMode = "after"' />
                                    <label class="form-check-label small" for="afterYear">@L["From"]</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="yearSearchOption" id="beforeYear" value="before" 
                                           checked='@(yearSearchMode == "before")' @onclick='() => yearSearchMode = "before"' />
                                    <label class="form-check-label small" for="beforeYear">@L["To"]</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="yearSearchOption" id="betweenYear" value="between" 
                                           checked='@(yearSearchMode == "between")' @onclick='() => yearSearchMode = "between"' />
                                    <label class="form-check-label small" for="betweenYear">@L["Range"]</label>
                                </div>
                            </div>
                            <div class="row g-2">
                                <div class="@(yearSearchMode == "between" ? "col-6" : "col-12")">
                                    <div class="input-group input-group-sm">
                                        <span class="input-group-text bg-light text-primary"><i class="bi bi-calendar-event"></i></span>
                                        <InputNumber class="form-control" @bind-Value="searchBookYear" 
                                                       placeholder='@(yearSearchMode == "between" ? L["StartingYear"] : L["YearValue"])' />
                                    </div>
                                </div>
                                @if (yearSearchMode == "between")
                                {
                                    <div class="col-6">
                                        <div class="input-group input-group-sm">
                                            <span class="input-group-text bg-light text-primary"><i class="bi bi-calendar-check"></i></span>
                                            <InputNumber class="form-control" @bind-Value="searchBookYearTo" placeholder="@L["EndingYear"]" />
                                        </div>
                                    </div>
                                }
                            </div>
                        </fieldset>
                    </div>
                </div>
            </div>

            <div class="row g-3 mt-1">
                <div class="col-md-10">
                    <label class="form-label fw-bold small text-muted text-uppercase mb-2"><i class="bi bi-funnel-fill me-1"></i>@L["AvailabilityFilters"]</label>
                    <div class="d-flex flex-wrap gap-3">
                        <div class="btn-group shadow-sm flex-grow-1" role="group">
                            <input type="radio" class="btn-check" name="availSearch" id="availAll" checked="@(searchBookAvailability == "All")" @onclick='() => searchBookAvailability = "All"' autocomplete="off">
                            <label class="btn btn-outline-primary py-2" for="availAll">@L["AllBooks"]</label>

                            <input type="radio" class="btn-check" name="availSearch" id="availCirc" checked="@(searchBookAvailability == "Circulating")" @onclick='() => searchBookAvailability = "Circulating"' autocomplete="off">
                            <label class="btn btn-outline-primary py-2" for="availCirc" title="@L["Circulating"]">
                                <i class="bi bi-journal-text me-1"></i><span class="d-none d-lg-inline">@L["CirculatingRule"]</span>
                            </label>

                            <input type="radio" class="btn-check" name="availSearch" id="availRef" checked="@(searchBookAvailability == "ReferenceOnly")" @onclick='() => searchBookAvailability = "ReferenceOnly"' autocomplete="off">
                            <label class="btn btn-outline-primary py-2" for="availRef" title="@L["ReferenceOnly"]">
                                <i class="bi bi-lock-fill me-1"></i><span class="d-none d-lg-inline">@L["ReferenceOnlyRule"]</span>
                            </label>

                            <input type="radio" class="btn-check" name="availSearch" id="availUnsp" checked="@(searchBookAvailability == "Unspecified")" @onclick='() => searchBookAvailability = "Unspecified"' autocomplete="off">
                            <label class="btn btn-outline-primary py-2" for="availUnsp" title="@L["Unspecified"]">
                                <i class="bi bi-question-circle me-1"></i><span class="d-none d-lg-inline">@L["UnspecifiedRule"]</span>
                            </label>
                        </div>
                        
                        <div class="btn-group shadow-sm" role="group">
                            <input type="radio" class="btn-check" name="availSearch" id="availNow" checked="@(searchBookAvailability == "ImmediatelyAvailable")" @onclick='() => searchBookAvailability = "ImmediatelyAvailable"' autocomplete="off">
                            <label class="btn btn-outline-success py-2 px-4 fw-bold" for="availNow">
                                <i class="bi bi-lightning-fill me-1"></i>@L["ImmediatelyAvailableOnly"]
                            </label>
                        </div>
                    </div>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary btn-lg w-100 shadow-sm transition-hover py-2 d-flex align-items-center justify-content-center h-75 mb-1">
                        <i class="bi bi-search me-2 fs-5"></i><span>@L["Search"]</span>
                    </button>
                </div>
            </div>

            <div class="row g-3 mt-4 border-top pt-4 @(IsIsbnSearchActive ? "opacity-50" : "") transition-opacity" style="transition: opacity 0.3s ease;">
                <div class="col-md-5">
                    <label class="form-label fw-bold small text-muted text-uppercase mb-2 @(IsIsbnSearchActive ? "text-decoration-line-through" : "")">
                        <i class="bi bi-person-lines-fill me-1"></i>@L["RefineByAuthors"]
                    </label>
                    <fieldset disabled="@IsIsbnSearchActive" class="position-relative">
                        <div class="input-group shadow-sm">
                            <span class="input-group-text bg-white text-primary border-primary border-end-0"><i class="bi bi-person-plus"></i></span>
                            <input type="text" 
                                   class="form-control border-primary border-start-0" 
                                   placeholder="@L["SearchAuthorNamePlaceholder"]" 
                                   value="@authorSearchNameFilter"
                                   @oninput="HandleAuthorSearchInput"
                                   @onfocus='() => { if(foundAuthorsForFilter.Any()) showAuthorSearchResults = true; }' />
                            <button type="button" 
                                    class="btn btn-primary px-3 transition-hover" 
                                    @onclick="AddAuthorToSearchCriteria"
                                    disabled="@(selectedAuthorFromResults == null)">
                                <i class="bi bi-plus-lg me-1"></i>@L["Add"]
                            </button>
                        </div>
                        
                        @if (showAuthorSearchResults)
                        {
                            <div class="list-group position-absolute w-100 shadow mt-1 border-primary-subtle" style="z-index: 1100; max-height: 250px; overflow-y: auto;">
                                @foreach (var author in foundAuthorsForFilter)
                                {
                                    <button type="button" 
                                            class="list-group-item list-group-item-action text-start py-2 animate-fade-in" 
                                            @onclick="() => SelectAuthorFromResults(author)">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div class="fw-bold text-primary">@author.Name.Value</div>
                                            @if (!string.IsNullOrEmpty(author.Isni.Value))
                                            {
                                                <span class="badge bg-light text-muted border small font-monospace">@author.Isni.Value</span>
                                            }
                                        </div>
                                    </button>
                                }
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(authorSearchNameFilter) && authorSearchNameFilter.Length >= 2 && !foundAuthorsForFilter.Any() && !isLoadingAuthors)
                        {
                            <div class="alert alert-light border small mt-1 py-1 px-2 text-muted shadow-sm animate-fade-in">
                                <i class="bi bi-info-circle me-1"></i>@L["NoAuthorsFoundMatching"] "@authorSearchNameFilter"
                            </div>
                        }
                    </fieldset>
                </div>
                
                <div class="col-md-7">
                    <label class="form-label fw-bold small text-muted text-uppercase mb-2">@L["ActiveAuthorCriteria"]</label>
                    <div class="d-flex flex-wrap gap-2 p-3 border border-dashed rounded bg-white shadow-inner min-vh-10" style="min-height: 80px;">
                        @if (!searchAuthorsCriteria.Any())
                        {
                            <div class="w-100 d-flex align-items-center justify-content-center text-muted small italic">
                                <i class="bi bi-info-circle me-2"></i>@L["NoAuthorsSelected"]
                            </div>
                        }
                        else
                        {
                            @foreach (var author in searchAuthorsCriteria)
                            {
                                <div class="badge bg-primary text-white d-flex align-items-center py-2 px-3 rounded-pill shadow-sm animate-pop-in">
                                    <i class="bi bi-person-fill me-2 border-end pe-2 border-white-50"></i>
                                    <span class="me-2 fw-normal">@author.Name.Value</span>
                                    <button type="button" class="btn-close btn-close-white ms-1 small" style="transform: scale(0.7);" title="@L["Remove"]" @onclick="() => { if (!IsIsbnSearchActive) RemoveAuthorFromSearchCriteria(author); }"></button>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>

            <!-- Category Selection Section -->
            <div class="row g-3 mt-4 border-top pt-4 @(IsIsbnSearchActive ? "opacity-50" : "") transition-opacity" style="transition: opacity 0.3s ease;">
                <div class="col-md-5">
                    <label class="form-label fw-bold small text-muted text-uppercase mb-2 @(IsIsbnSearchActive ? "text-decoration-line-through" : "")">
                        <i class="bi bi-tags-fill me-1"></i>@L["RefineByCategory"]
                    </label>
                    <fieldset disabled="@IsIsbnSearchActive">
                        <div class="d-flex gap-2">
                            <select class="form-select border-primary shadow-sm" @bind="selectedCategoryForFilter">
                                <option value="">@L["SelectCategoryPlaceholder"]</option>
                                @foreach (var category in allCategories)
                                {
                                    <option value="@category.Value()">@category.Value()</option>
                                }
                            </select>
                            <button type="button" class="btn btn-info text-white shadow-sm transition-hover d-flex align-items-center" @onclick="AddCategoryToSearchCriteria" disabled="@(string.IsNullOrEmpty(selectedCategoryForFilter))">
                                <i class="bi bi-bookmark-plus-fill me-1"></i>@L["Add"]
                            </button>
                        </div>
                    </fieldset>
                </div>
                
                <div class="col-md-7">
                    <label class="form-label fw-bold small text-muted text-uppercase mb-2">@L["ActiveCategoryCriteria"]</label>
                    <div class="d-flex flex-wrap gap-2 p-3 border border-dashed rounded bg-white shadow-inner" style="min-height: 80px;">
                        @if (!searchCategoriesCriteria.Any())
                        {
                            <div class="w-100 d-flex align-items-center justify-content-center text-muted small italic">
                                <i class="bi bi-info-circle me-2"></i>@L["NoCategoriesSelected"]
                            </div>
                        }
                        else
                        {
                            @foreach (var category in searchCategoriesCriteria)
                            {
                                <div class="badge bg-info text-white d-flex align-items-center py-2 px-3 rounded shadow-sm animate-pop-in">
                                    <i class="bi bi-tag-fill me-2 border-end pe-2 border-white-50"></i>
                                    <span class="me-2 fw-normal">@category.Value()</span>
                                    <button type="button" class="btn-close btn-close-white ms-1 small" style="transform: scale(0.7);" title="@L["Remove"]" @onclick="() => { if (!IsIsbnSearchActive) RemoveCategoryFromSearchCriteria(category); }"></button>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        </EditForm>
    </div>
</div>

@code {
    [Parameter] public EventCallback<List<Book>> OnSearchResultsFound { get; set; }
    [Parameter] public EventCallback<string> OnError { get; set; }
    [Parameter] public EventCallback<bool> OnSearchStarted { get; set; }

    private bool _isLoading = false;

    private string searchBookTitle = "";
    private string searchBookIsbn = "";
    private int? searchBookYear = null;
    private int? searchBookYearTo = null;
    private string yearSearchMode = "exact"; // exact, after, before, between
    
    private string authorSearchNameFilter ="";
    private List<Author> foundAuthorsForFilter = new();
    private Author? selectedAuthorFromResults = null;
    private bool showAuthorSearchResults = false;
    private bool isLoadingAuthors = false;
    private List<Author> searchAuthorsCriteria = new();

    private string selectedCategoryForFilter = "";
    private List<Category> searchCategoriesCriteria = new();

    private bool IsIsbnSearchActive => !string.IsNullOrWhiteSpace(searchBookIsbn);

    private FSharpList<Category> allCategories = Category.AllCases();

    private string searchBookAvailability = "All"; // All, Circulating, ReferenceOnly, Unspecified, ImmediatelyAvailable
    private BookSearchCriteria searchCriteria 
    {
        get 
        {
            if (string.IsNullOrEmpty(searchBookAvailability) || searchBookAvailability == "All")
                return _ => true;
            
            if (searchBookAvailability == "ImmediatelyAvailable")
                return book => book.ImmediatelyAvailable;
            
            return book => 
                (searchBookAvailability == "Circulating" && book.Availability.IsCirculating) || 
                (searchBookAvailability == "ReferenceOnly" && book.Availability.IsReferenceOnly) ||
                (searchBookAvailability == "Unspecified" && book.Availability.IsUnspecified);
        }
    }

    private async Task HandleAuthorSearchInput(ChangeEventArgs e)
    {
@* 
        _isLoading = true;
        StateHasChanged(); // immediately show the GIF
        await Task.Yield(); // let UI update *@

        authorSearchNameFilter = e.Value?.ToString() ?? "";
        if (authorSearchNameFilter.Length >= 2)
        {
            isLoadingAuthors = true;
            try
            {
                var name = Name.New(authorSearchNameFilter);
                var result = await AuthorService.SearchByNameAsync(name, FSharpOption<CancellationToken>.None);
                
                if (result.IsOk)
                {
                    foundAuthorsForFilter = result.ResultValue.ToList();
                    showAuthorSearchResults = foundAuthorsForFilter.Any();
                }
                else
                {
                    foundAuthorsForFilter.Clear();
                    showAuthorSearchResults = false;
                    await OnError.InvokeAsync(L["ErrorSearchingAuthors", result.ErrorValue]);
                }
            }
            finally
            {
                isLoadingAuthors = false;
                @* StateHasChanged(); // immediately show the GIF
                await Task.Yield(); // let UI update *@
            }
        }
        else
        {
            foundAuthorsForFilter.Clear();
            showAuthorSearchResults = false;
            selectedAuthorFromResults = null;
        }
    }

    private void SelectAuthorFromResults(Author author)
    {
        selectedAuthorFromResults = author;
        authorSearchNameFilter = author.Name.Value;
        showAuthorSearchResults = false;
    }

    private void AddAuthorToSearchCriteria()
    {
        if (selectedAuthorFromResults == null) return;
        
        if (!searchAuthorsCriteria.Any(a => a.AuthorId == selectedAuthorFromResults.AuthorId))
        {
            searchAuthorsCriteria.Add(selectedAuthorFromResults);
        }
        authorSearchNameFilter = "";
        selectedAuthorFromResults = null;
    }

    private void RemoveAuthorFromSearchCriteria(Author author)
    {
        searchAuthorsCriteria.Remove(author);
    }

    private void AddCategoryToSearchCriteria()
    {
        if (string.IsNullOrEmpty(selectedCategoryForFilter)) return;
        var category = Category.FromString(selectedCategoryForFilter);
        if (!searchCategoriesCriteria.Contains(category))
        {
            searchCategoriesCriteria.Add(category);
        }
    }

    private void RemoveCategoryFromSearchCriteria(Category category)
    {
        searchCategoriesCriteria.Remove(category);
    }

    private async Task HandleBookSearch()
    {
        await OnSearchStarted.InvokeAsync(true);
        
        bool hasTitle = !string.IsNullOrWhiteSpace(searchBookTitle);
        bool hasIsbn = !string.IsNullOrWhiteSpace(searchBookIsbn);
        bool hasYear = searchBookYear.HasValue;
        bool hasBetweenYear = yearSearchMode == "between" && searchBookYear.HasValue && searchBookYearTo.HasValue;

        _isLoading = true;

        FSharpResult<FSharpList<Book>, string> result;

        if (hasIsbn)
        {
            var isbn = Isbn.NewInvalid(searchBookIsbn);
            if (hasTitle)
            {
                result = await BookService.SearchByIsbnOrTitleAsync(isbn, Title.New(searchBookTitle), searchCriteria, CancellationToken.None);
            }
            else
            {
                result = await BookService.SearchByIsbnAsync(isbn, searchCriteria, CancellationToken.None);
            }
        }
        else 
        {
            YearSearch GetYearSearch() {
                var year = searchBookYear ?? 0;
                var yearTo = searchBookYearTo ?? 0;
                return yearSearchMode switch
                {
                    "after" => YearSearch.NewAfter(year),
                    "before" => YearSearch.NewBefore(year),
                    "between" => YearSearch.NewRange(year, yearTo),
                    _ => YearSearch.NewExact(year)
                };
            }
            
            bool hasEffectiveYear = hasYear || hasBetweenYear;
            
            if (searchCategoriesCriteria.Any())
            {
                var authorIds = ListModule.OfSeq(searchAuthorsCriteria.Select(a => a.AuthorId));
                var categories = ListModule.OfSeq(searchCategoriesCriteria);
                var yearSearch = GetYearSearch();
                bool hasAuthors = searchAuthorsCriteria.Any();
                
                if (hasAuthors)
                {
                    if (hasTitle && hasEffectiveYear)
                    {
                        result = await BookService.SearchByTitleAndAuthorsAndYearAndCategoriesAsync(Title.New(searchBookTitle), authorIds, yearSearch, categories, searchCriteria, CancellationToken.None);
                    }
                    else if (hasTitle)
                    {
                        result = await BookService.SearchByTitleAndAuthorsAndCategoriesAsync(Title.New(searchBookTitle), authorIds, categories, searchCriteria, CancellationToken.None);
                    }
                    else if (hasEffectiveYear)
                    {
                        result = await BookService.SearchByAuthorsAndYearAndCategoriesAsync(authorIds, yearSearch, categories, searchCriteria, CancellationToken.None);
                    }
                    else
                    {
                        result = await BookService.SearchByAuthorsAndCategoriesAsync(authorIds, categories, searchCriteria, CancellationToken.None);
                    }
                }
                else
                {
                    if (hasTitle && hasEffectiveYear)
                    {
                        result = await BookService.SearchByTitleAndYearAndCategoriesAsync(Title.New(searchBookTitle), yearSearch, categories, searchCriteria, CancellationToken.None);
                    }
                    else if (hasTitle)
                    {
                        result = await BookService.SearchByTitleAndCategoriesAsync(Title.New(searchBookTitle), categories, searchCriteria, CancellationToken.None);
                    }
                    else if (hasEffectiveYear)
                    {
                        result = await BookService.SearchByYearAndCategoriesAsync(yearSearch, categories, searchCriteria, CancellationToken.None); 
                    }
                    else
                    {
                        result = await BookService.SearchByCategoriesAsync(categories, searchCriteria, CancellationToken.None); 
                    }
                }
            }
            else if (searchAuthorsCriteria.Any())
            {
                var authorIds = ListModule.OfSeq(searchAuthorsCriteria.Select(a => a.AuthorId));
                if (hasTitle && hasEffectiveYear)
                {
                    result = await BookService.SearchByTitleAndAuthorsAndYearAsync(Title.New(searchBookTitle), authorIds, GetYearSearch(), searchCriteria, CancellationToken.None);
                }
                else if (hasTitle)
                {
                    result = await BookService.SearchByTitleAndAuthorsAsync(Title.New(searchBookTitle), authorIds, searchCriteria, CancellationToken.None);
                }
                else if (hasEffectiveYear)
                {
                    result = await BookService.SearchByAuthorsAndYearAsync(authorIds, GetYearSearch(), searchCriteria, CancellationToken.None);
                }
                else
                {
                    result = await BookService.SearchByAuthorsAsync(authorIds, searchCriteria, CancellationToken.None);
                }
            }
            else if (hasTitle && hasEffectiveYear)
            {
                result = await BookService.SearchByTitleAndYearAsync(Title.New(searchBookTitle), GetYearSearch(), searchCriteria, CancellationToken.None);
            }
            else if (hasTitle)
            {
                result = await BookService.SearchByTitleAsync(Title.New(searchBookTitle), searchCriteria, CancellationToken.None);
            }
            else if (hasEffectiveYear)
            {
                result = await BookService.SearchByYearAsync(GetYearSearch(), searchCriteria, CancellationToken.None);
            }
            else
            {
                result = await BookService.GetAllAsync(searchCriteria, CancellationToken.None);
            }
        }

        _isLoading = false;
        if (result.IsOk)
        {
            await OnSearchResultsFound.InvokeAsync(result.ResultValue.ToList());
        }
        else
        {
            await OnError.InvokeAsync(L["ErrorSearchingBooks", result.ErrorValue]);
        }

    }
}
